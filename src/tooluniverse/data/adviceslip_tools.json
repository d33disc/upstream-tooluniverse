  {
    "name": "AdviceSlip_search_advice",
    "description": "Search for advice slips by keyword from the Advice Slip API (adviceslip.com). Returns all matching advice slips with their IDs and text. Free, no API key required. Useful for finding topical advice on specific subjects (e.g., 'life', 'money', 'friends', 'work').",
    "parameter": {
      "type": "object",
      "properties": {
        "query": {
          "type": "string",
          "description": "Search query keyword (e.g., 'life', 'money', 'friends', 'work', 'happiness')"
        }
      },
      "required": ["query"]
    },
    "fields": {
      "endpoint": "https://api.adviceslip.com/advice/search/{query}"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"query": "life"},
      {"query": "money"},
      {"query": "friends"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Search results",
              "properties": {
                "total_results": {"type": "string", "description": "Total number of matching advice slips"},
                "query": {"type": "string", "description": "The search query used"},
                "slips": {
                  "type": "array",
                  "description": "Matching advice slips",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {"type": "integer", "description": "Advice slip ID"},
                      "advice": {"type": "string", "description": "The advice text"},
                      "date": {"type": "string", "description": "Date advice was created"}
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
