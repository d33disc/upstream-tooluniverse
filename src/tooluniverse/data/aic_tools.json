[
  {
    "name": "ArtIC_search_artworks",
    "description": "Search the Art Institute of Chicago's collection of 130,000+ artworks using their public API. Returns artworks with title, artist, date, medium, dimensions, and image information. Covers impressionism, modern art, ancient art, photography, sculpture, textiles, and more. Useful for art research, finding artworks by artist or style, and cultural studies.",
    "parameter": {
      "type": "object",
      "properties": {
        "q": {
          "type": "string",
          "description": "Search query. Examples: 'monet', 'impressionism', 'ancient egypt', 'self portrait'"
        },
        "limit": {
          "type": ["integer", "null"],
          "description": "Number of results to return (default 10, max 100)"
        },
        "page": {
          "type": ["integer", "null"],
          "description": "Page number for pagination"
        },
        "is_public_domain": {
          "type": ["boolean", "null"],
          "description": "Filter to public domain works (true/false)"
        },
        "fields": {
          "type": ["string", "null"],
          "description": "Comma-separated fields to return. Default includes: id,title,artist_display,date_display,medium_display,dimensions,image_id,is_public_domain,department_title,artwork_type_title"
        }
      },
      "required": ["q"]
    },
    "fields": {
      "endpoint": "https://api.artic.edu/api/v1/artworks/search",
      "params": {
        "fields": "id,title,artist_display,date_display,medium_display,dimensions,image_id,is_public_domain,department_title,artwork_type_title,style_title,classification_title,subject_titles"
      }
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"q": "monet", "limit": 5},
      {"q": "picasso", "is_public_domain": true, "limit": 5},
      {"q": "ancient egypt sculpture", "limit": 5}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Artwork search results",
              "properties": {
                "pagination": {
                  "type": "object",
                  "properties": {
                    "total": {"type": "integer", "description": "Total matching artworks"},
                    "limit": {"type": "integer"},
                    "offset": {"type": "integer"},
                    "current_page": {"type": "integer"},
                    "total_pages": {"type": "integer"}
                  }
                },
                "data": {
                  "type": "array",
                  "description": "List of artworks",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {"type": "integer", "description": "Artwork ID"},
                      "title": {"type": "string", "description": "Artwork title"},
                      "artist_display": {"type": ["string", "null"], "description": "Artist name and nationality"},
                      "date_display": {"type": ["string", "null"], "description": "Creation date"},
                      "medium_display": {"type": ["string", "null"], "description": "Materials/medium used"},
                      "dimensions": {"type": ["string", "null"], "description": "Physical dimensions"},
                      "image_id": {"type": ["string", "null"], "description": "Image ID for IIIF image server"},
                      "is_public_domain": {"type": ["boolean", "null"], "description": "Public domain status"},
                      "department_title": {"type": ["string", "null"], "description": "Museum department"},
                      "artwork_type_title": {"type": ["string", "null"], "description": "Type of artwork"},
                      "style_title": {"type": ["string", "null"], "description": "Art style"},
                      "classification_title": {"type": ["string", "null"], "description": "Classification"},
                      "subject_titles": {"type": ["array", "null"], "description": "Subject tags", "items": {"type": "string"}}
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "ArtIC_get_artwork",
    "description": "Get detailed information about a specific artwork from the Art Institute of Chicago by its ID. Returns comprehensive metadata including full artist information, provenance, exhibition history, catalog entries, and high-resolution image details. Use ArtIC_search_artworks first to find artwork IDs.",
    "parameter": {
      "type": "object",
      "properties": {
        "artwork_id": {
          "type": "integer",
          "description": "Artwork ID from the Art Institute of Chicago. Examples: 27992 (Grant Wood 'American Gothic'), 111628 (Seurat 'A Sunday'), 20684 (Picasso 'The Old Guitarist')"
        }
      },
      "required": ["artwork_id"]
    },
    "fields": {
      "endpoint": "https://api.artic.edu/api/v1/artworks/{artwork_id}"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"artwork_id": 27992},
      {"artwork_id": 111628},
      {"artwork_id": 20684}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Artwork details",
              "properties": {
                "data": {
                  "type": "object",
                  "description": "Full artwork metadata",
                  "properties": {
                    "id": {"type": "integer"},
                    "title": {"type": "string"},
                    "artist_display": {"type": ["string", "null"]},
                    "date_display": {"type": ["string", "null"]},
                    "date_start": {"type": ["integer", "null"]},
                    "date_end": {"type": ["integer", "null"]},
                    "medium_display": {"type": ["string", "null"]},
                    "dimensions": {"type": ["string", "null"]},
                    "is_public_domain": {"type": ["boolean", "null"]},
                    "image_id": {"type": ["string", "null"]},
                    "department_title": {"type": ["string", "null"]},
                    "artwork_type_title": {"type": ["string", "null"]},
                    "style_title": {"type": ["string", "null"]},
                    "description": {"type": ["string", "null"]},
                    "provenance_text": {"type": ["string", "null"]},
                    "publication_history": {"type": ["string", "null"]},
                    "exhibition_history": {"type": ["string", "null"]}
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
