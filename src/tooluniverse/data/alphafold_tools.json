[
  {
    "name": "alphafold_get_prediction",
    "description": "Retrieve full AlphaFold 3D structure predictions for a given protein. IMPORTANT: The qualifier must be a UniProt ACCESSION (e.g., 'P69905' for HBA_HUMAN). Do NOT use UniProt entry names like 'HBA_HUMAN' - they will cause API errors. To find UniProt accession from a gene/protein name, use `UniProt_search` (e.g., query='gene:HBA' organism='human') or `UniProt_id_mapping` for ID conversion. Returns residue-level metadata including sequence, per-residue confidence scores (pLDDT), and structure download links (PDB, CIF, PAE). If you already have the accession and want UniProt details, call `UniProt_get_entry_by_accession`. For a quick overview, use `alphafold_get_summary`. For mutation/variant impact, see `alphafold_get_annotations`.",
    "type": "AlphaFoldRESTTool",
    "parameter": {
      "type": "object",
      "properties": {
        "qualifier": {
          "type": "string",
          "description": "UniProt ACCESSION (e.g., 'P69905'). Do NOT use entry names like 'HBA_HUMAN'. Aliases: uniprot_id, uniprot_accession."
        },
        "uniprot_id": {
          "type": "string",
          "description": "Alias for qualifier: UniProt accession (e.g., 'P69905')."
        },
        "uniprot_accession": {
          "type": "string",
          "description": "Alias for qualifier: UniProt accession (e.g., 'P69905')."
        },
        "sequence_checksum": {
          "type": "string",
          "description": "Optional CRC64 checksum of the UniProt sequence."
        }
      },
      "required": []
    },
    "fields": {
      "endpoint": "/prediction/{qualifier}",
      "return_format": "JSON"
    },
    "test_examples": [
      {
        "qualifier": "P04637"
      },
      {
        "uniprot_accession": "P00533"
      }
    ],
    "return_schema": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "toolUsed": {
            "type": "string"
          },
          "providerId": {
            "type": "string"
          },
          "entityType": {
            "type": "string"
          },
          "isUniProt": {
            "type": "boolean"
          },
          "modelEntityId": {
            "type": "string"
          },
          "modelCreatedDate": {
            "type": "string"
          },
          "sequenceVersionDate": {
            "type": "string"
          },
          "globalMetricValue": {
            "type": "number"
          },
          "fractionPlddtVeryLow": {
            "type": "number"
          },
          "fractionPlddtLow": {
            "type": "number"
          },
          "fractionPlddtConfident": {
            "type": "number"
          },
          "fractionPlddtVeryHigh": {
            "type": "number"
          },
          "latestVersion": {
            "type": "integer"
          },
          "allVersions": {
            "type": "array",
            "items": {}
          },
          "sequence": {
            "type": "string"
          },
          "sequenceStart": {
            "type": "integer"
          },
          "sequenceEnd": {
            "type": "integer"
          },
          "sequenceChecksum": {
            "type": "string"
          },
          "isUniProtReviewed": {
            "type": "boolean"
          },
          "gene": {
            "type": "string"
          },
          "uniprotAccession": {
            "type": "string"
          },
          "uniprotId": {
            "type": "string"
          },
          "uniprotDescription": {
            "type": "string"
          },
          "taxId": {
            "type": "integer"
          },
          "organismScientificName": {
            "type": "string"
          },
          "isUniProtReferenceProteome": {
            "type": "boolean"
          },
          "bcifUrl": {
            "type": "string"
          },
          "cifUrl": {
            "type": "string"
          },
          "pdbUrl": {
            "type": "string"
          },
          "paeImageUrl": {
            "type": "string"
          },
          "msaUrl": {
            "type": "string"
          },
          "plddtDocUrl": {
            "type": "string"
          },
          "paeDocUrl": {
            "type": "string"
          },
          "amAnnotationsUrl": {
            "type": "string"
          },
          "amAnnotationsHg19Url": {
            "type": "string"
          },
          "amAnnotationsHg38Url": {
            "type": "string"
          },
          "isComplex": {
            "type": "boolean"
          },
          "entryId": {
            "type": "string"
          },
          "uniprotSequence": {
            "type": "string"
          },
          "uniprotStart": {
            "type": "integer"
          },
          "uniprotEnd": {
            "type": "integer"
          },
          "isReferenceProteome": {
