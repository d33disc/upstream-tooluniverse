[
  {
    "name": "SomeRandomAPI_get_animal_fact",
    "description": "Get a random animal image URL and interesting fact for various animals using the Some Random API. Returns a cute animal image and an educational fact. Supports dogs, cats, pandas, foxes, birds, kangaroos, koalas, and more. No authentication required. Useful for educational applications, fun bots, and animal trivia.",
    "parameter": {
      "type": "object",
      "properties": {
        "animal": {
          "type": "string",
          "description": "Animal type. Values: 'dog', 'cat', 'panda', 'fox', 'bird', 'kangaroo', 'koala', 'redpanda', 'raccoon'"
        }
      },
      "required": ["animal"]
    },
    "fields": {
      "endpoint": "https://some-random-api.com/animal/{animal}",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"animal": "dog"},
      {"animal": "cat"},
      {"animal": "panda"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Random animal image and fact",
              "properties": {
                "image": {"type": "string", "description": "URL to a random animal image"},
                "fact": {"type": "string", "description": "Interesting educational fact about the animal"}
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
