[
  {
    "name": "BindingDB_get_by_uniprot",
    "description": "Get protein-ligand binding affinity data from BindingDB by UniProt accession. Returns compounds with measured IC50, Ki, or Kd values. BindingDB contains 3.2M binding measurements for 1.4M compounds. No authentication required.",
    "type": "BindingDBTool",
    "parameter": {
      "type": "object",
      "properties": {
        "operation": {
          "type": "string",
          "const": "get_by_uniprot",
          "description": "Operation type (fixed: get_by_uniprot)"
        },
        "uniprot_id": {
          "type": "string",
          "description": "UniProt accession (e.g., P00533 for EGFR, P04637 for TP53)"
        },
        "affinity_cutoff": {
          "type": "integer",
          "description": "Maximum binding affinity in nM (default: 10000). Lower = more potent compounds only.",
          "default": 10000
        }
      },
      "required": ["operation", "uniprot_id"]
    },
    "return_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string"
        },
        "data": {
          "type": "object",
          "properties": {
            "uniprot_id": {
              "type": "string"
            },
            "ligands": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "monomerid": {
                    "type": "string",
                    "description": "BindingDB compound ID"
                  },
                  "smiles": {
                    "type": "string",
                    "description": "Compound SMILES"
                  },
                  "affinity_type": {
                    "type": "string",
                    "description": "IC50, Ki, or Kd"
                  },
                  "affinity_value": {
                    "type": "number",
                    "description": "Affinity value in nM"
                  }
                }
              }
            },
            "count": {
              "type": "integer"
            }
          }
        }
      }
    },
    "test_examples": [
      {
        "operation": "get_by_uniprot",
        "uniprot_id": "P00533",
        "affinity_cutoff": 1000
      }
    ]
  },
  {
    "name": "BindingDB_get_by_pdb",
    "description": "Get binding affinity data for protein structures by PDB ID. Returns ligands with binding data for proteins matching the PDB structure above a sequence identity threshold. Useful for structure-based drug design.",
    "type": "BindingDBTool",
    "parameter": {
      "type": "object",
      "properties": {
        "operation": {
          "type": "string",
          "const": "get_by_pdb",
          "description": "Operation type (fixed: get_by_pdb)"
        },
        "pdb_ids": {
          "type": "string",
          "description": "PDB ID(s), comma-separated (e.g., '1M17' or '1M17,3POZ')"
        },
        "affinity_cutoff": {
          "type": "integer",
          "description": "Maximum affinity in nM (default: 100)",
          "default": 100
        },
        "sequence_identity": {
          "type": "integer",
          "description": "Minimum sequence identity % to PDB structure (default: 90)",
          "default": 90,
          "minimum": 50,
          "maximum": 100
        }
      },
      "required": ["operation", "pdb_ids"]
    },
    "return_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string"
        },
        "data": {
          "type": "object",
          "properties": {
            "pdb_ids": {
              "type": "string"
            },
            "ligands": {
              "type": "array"
            },
            "count": {
              "type": "integer"
            }
          }
        }
      }
    },
    "test_examples": [
      {
        "operation": "get_by_pdb",
        "pdb_ids": "1M17",
        "affinity_cutoff": 100
      }
    ]
  },
  {
    "name": "BindingDB_get_by_target_name",
    "description": "Search BindingDB by target protein name. Returns binding data for all ligands matching the target name with affinity below the cutoff. Good for exploring compound libraries against a target class.",
    "type": "BindingDBTool",
    "parameter": {
      "type": "object",
      "properties": {
        "operation": {
          "type": "string",
          "const": "get_by_target_name",
          "description": "Operation type (fixed: get_by_target_name)"
        },
        "target_name": {
          "type": "string",
          "description": "Target protein name (e.g., 'EGFR', 'ABL kinase', 'COX-2')"
        },
        "affinity_cutoff": {
          "type": "integer",
          "description": "Maximum affinity in nM (default: 1000)",
          "default": 1000
        }
      },
      "required": ["operation", "target_name"]
    },
    "return_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string"
        },
        "data": {
          "type": "object",
          "properties": {
            "target_name": {
              "type": "string"
            },
            "ligands": {
              "type": "array"
            },
            "count": {
              "type": "integer"
            }
          }
        }
      }
    },
    "test_examples": [
      {
        "operation": "get_by_target_name",
        "target_name": "EGFR",
        "affinity_cutoff": 100
      }
    ]
  }
]
