[
  {
    "name": "BioSamples_get_sample",
    "description": "Get detailed metadata for a specific biological sample from the EBI BioSamples database by accession. Returns sample name, organism, tissue, disease, experimental context, and links to associated data archives (ENA, ArrayExpress, EVA). BioSamples contains 60+ million samples from all major sequence and functional genomics archives. Example: SAMEA104228123 returns a metagenomic sample from the Qiita microbiome project.",
    "parameter": {
      "type": "object",
      "properties": {
        "accession": {
          "type": "string",
          "description": "BioSamples accession. Formats: SAMEA* (EBI), SAMN* (NCBI), SAMD* (DDBJ). Examples: 'SAMEA104228123', 'SAMD00000603'."
        }
      },
      "required": [
        "accession"
      ]
    },
    "fields": {
      "endpoint_type": "get_sample"
    },
    "type": "BioSamplesTool",
    "test_examples": [
      {
        "accession": "SAMEA104228123"
      },
      {
        "accession": "SAMD00000603"
      }
    ],
    "return_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "description": "Success or error status"
        },
        "data": {
          "type": "object",
          "properties": {
            "accession": {
              "type": "string",
              "description": "BioSample accession ID"
            },
            "name": {
              "type": "string",
              "description": "Sample name"
            },
            "taxon_id": {
              "type": "integer",
              "description": "NCBI taxonomy ID"
            },
            "status": {
              "type": "string",
              "description": "Sample status (e.g. PUBLIC)"
            },
            "release_date": {
              "type": "string",
              "description": "ISO 8601 release date"
            },
            "update_date": {
              "type": "string",
              "description": "ISO 8601 last update date"
            },
            "characteristics": {
              "type": "object",
              "description": "Key-value pairs of sample attributes",
              "additionalProperties": {
                "type": "string"
              }
            },
            "external_references": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "url": {
                    "type": "string",
                    "description": "URL of external reference"
                  },
                  "duo": {
                    "type": "array",
                    "description": "Data use ontology terms"
                  }
                }
              },
              "description": "Links to external databases"
            }
          },
          "description": "Sample data object"
        },
        "metadata": {
          "type": "object",
          "properties": {
            "source": {
              "type": "string",
              "description": "Data source"
            },
            "query": {
              "type": "string",
              "description": "Query accession"
            },
            "endpoint": {
              "type": "string",
              "description": "API endpoint used"
            }
          },
          "description": "Query metadata"
        }
      }
    }
  },
  {
    "name": "BioSamples_search",
    "description": "Search the EBI BioSamples database by text query across 60+ million biological samples. Returns matching samples with accessions, names, organisms, and key characteristics. Useful for finding source material metadata for sequencing, proteomics, and other experiments. Example: searching 'breast cancer' returns thousands of tumor samples with tissue/disease annotations.",
    "parameter": {
      "type": "object",
      "properties": {
        "query": {
          "type": "string",
          "description": "Free-text search query. Examples: 'breast cancer', 'liver tissue', 'CRISPR screen', 'Mus musculus brain'."
        },
        "limit": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Maximum results to return (1-50, default 10)."
        },
        "page": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Page number (0-indexed, default 0)."
        }
      },
      "required": [
        "query"
      ]
    },
    "fields": {
      "endpoint_type": "search"
    },
    "type": "BioSamplesTool",
    "test_examples": [
      {
        "query": "breast cancer",
        "limit": 5
      },
      {
        "query": "Arabidopsis thaliana root",
        "limit": 3
      }
    ],
    "return_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "description": "Success or error status"
        },
        "data": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "accession": {
                "type": "string",
                "description": "BioSample accession ID"
              },
              "name": {
                "type": "string",
                "description": "Sample name"
              },
              "taxon_id": {
                "type": "integer",
                "description": "NCBI taxonomy ID"
              },
              "status": {
                "type": "string",
                "description": "Sample status"
              },
              "key_characteristics": {
                "type": "object",
                "description": "Key sample attributes",
                "additionalProperties": {
                  "type": "string"
                }
              }
            }
          },
          "description": "List of matching samples"
        },
        "metadata": {
          "type": "object",
          "properties": {
            "source": {
              "type": "string",
              "description": "Data source"
            },
            "total_elements": {
              "type": "integer",
              "description": "Total matching samples"
            },
            "total_pages": {
              "type": "integer",
              "description": "Total pages available"
            },
            "current_page": {
              "type": "integer",
              "description": "Current page number"
            },
            "returned": {
              "type": "integer",
              "description": "Number of results returned"
            },
            "query": {
              "type": "string",
              "description": "Search query used"
            },
            "endpoint": {
              "type": "string",
              "description": "API endpoint used"
            }
          },
          "description": "Query metadata and pagination"
        }
      }
    }
  },
  {
    "name": "BioSamples_search_by_filter",
    "description": "Search the EBI BioSamples database with structured attribute filters. More precise than text search - filters by specific metadata fields like organism, tissue, or disease. Example: attribute='organism', value='Homo sapiens' returns human samples; attribute='disease', value='melanoma' returns melanoma-specific samples.",
    "parameter": {
      "type": "object",
      "properties": {
        "attribute": {
          "type": "string",
          "description": "Attribute name to filter on. Common attributes: 'organism', 'tissue', 'disease', 'cell type', 'sex', 'age'."
        },
        "value": {
          "type": "string",
          "description": "Value to match for the attribute. Examples: 'Homo sapiens', 'liver', 'melanoma', 'female'."
        },
        "limit": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Maximum results to return (1-50, default 10)."
        }
      },
      "required": [
        "attribute",
        "value"
      ]
    },
    "fields": {
      "endpoint_type": "search_by_filter"
    },
    "type": "BioSamplesTool",
    "test_examples": [
      {
        "attribute": "organism",
        "value": "Homo sapiens",
        "limit": 5
      },
      {
        "attribute": "organism",
        "value": "Mus musculus",
        "limit": 3
      }
    ],
    "return_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "description": "Success or error status"
        },
        "data": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "accession": {
                "type": "string",
                "description": "BioSample accession ID"
              },
              "name": {
                "type": "string",
                "description": "Sample name"
              },
              "taxon_id": {
                "type": "integer",
                "description": "NCBI taxonomy ID"
              },
              "key_characteristics": {
                "type": "object",
                "description": "Key sample attributes",
                "additionalProperties": {
                  "type": "string"
                }
              }
            }
          },
          "description": "List of matching samples"
        },
        "metadata": {
          "type": "object",
          "properties": {
            "source": {
              "type": "string",
              "description": "Data source"
            },
            "total_elements": {
              "type": [
                "integer",
                "null"
              ],
              "description": "Total matching samples or null"
            },
            "returned": {
              "type": "integer",
              "description": "Number of results returned"
            },
            "filter": {
              "type": "string",
              "description": "Filter expression used"
            },
            "endpoint": {
              "type": "string",
              "description": "API endpoint used"
            }
          },
          "description": "Query metadata"
        }
      }
    }
  }
