      "type": "object",
      "properties": {},
      "required": []
    },
    "fields": {
      "endpoint": "https://blockchain.info/ticker",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Bitcoin prices keyed by currency code (USD, EUR, GBP, etc.)",
              "additionalProperties": {
                "type": "object",
                "properties": {
                  "15m": {"type": "number", "description": "15-minute delayed price"},
