[
  {
    "name": "BLS_get_timeseries",
    "description": "Get economic time series data from the U.S. Bureau of Labor Statistics (BLS) public API. Returns monthly, quarterly, or annual data for indicators like CPI, unemployment rate, employment levels, wage statistics, and productivity. No API key required for v1. Common series IDs: CUUR0000SA0 (CPI-U All Urban), LNS14000000 (Unemployment Rate), CES0000000001 (Total Nonfarm Employment). Useful for economic research, inflation analysis, and labor market studies.",
    "parameter": {
      "type": "object",
      "properties": {
        "seriesid": {
          "type": "string",
          "description": "BLS series ID(s). Examples: 'CUUR0000SA0' (CPI All Urban), 'LNS14000000' (Unemployment Rate), 'CES0000000001' (Total Nonfarm Payrolls), 'WPUFD4' (PPI Finished Goods), 'EIUELECTRICITY' (Electricity Price). Use comma-separated for multiple series."
        }
      },
      "required": ["seriesid"]
    },
    "fields": {
      "endpoint": "https://api.bls.gov/publicAPI/v1/timeseries/data/{seriesid}",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"seriesid": "CUUR0000SA0"},
      {"seriesid": "LNS14000000"},
      {"seriesid": "CES0000000001"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "BLS time series response",
              "properties": {
                "status": {"type": "string", "description": "REQUEST_SUCCEEDED or REQUEST_FAILED"},
                "responseTime": {"type": "integer"},
                "Results": {
                  "type": "object",
                  "properties": {
                    "series": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "seriesID": {"type": "string"},
                          "data": {
                            "type": "array",
                            "description": "Time series data points (most recent first)",
                            "items": {
                              "type": "object",
                              "properties": {
                                "year": {"type": "string"},
                                "period": {"type": "string", "description": "M01-M13 (monthly), Q01-Q05 (quarterly), A01 (annual)"},
                                "periodName": {"type": "string", "description": "Month/quarter name"},
                                "value": {"type": "string", "description": "Index or rate value"},
                                "footnotes": {"type": "array"}
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
