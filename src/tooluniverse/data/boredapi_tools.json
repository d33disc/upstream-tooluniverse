  {
    "name": "BoredAPI_get_random_activity",
    "description": "Get a random activity suggestion from the Bored API. Returns an activity with metadata including type, participants needed, price estimate, accessibility, duration, and kid-friendliness. No authentication required. Useful for overcoming boredom, team-building ideas, or generating activity recommendations.",
    "parameter": {
      "type": "object",
      "properties": {},
      "required": []
    },
    "fields": {
      "endpoint": "https://bored-api.appbrewery.com/random",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {},
      {},
      {}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Random activity suggestion",
              "properties": {
                "activity": {"type": "string", "description": "The suggested activity"},
                "availability": {"type": "number", "description": "Availability factor (0.0 to 1.0)"},
                "type": {"type": "string", "description": "Activity type: education, recreational, social, diy, charity, cooking, relaxation, music, busywork"},
                "participants": {"type": "integer", "description": "Number of participants needed"},
                "price": {"type": "number", "description": "Cost factor (0.0 = free, 1.0 = expensive)"},
                "accessibility": {"type": "string", "description": "Accessibility level: 'Few to no challenges', 'Minor challenges', 'Major challenges'"},
                "duration": {"type": "string", "description": "Estimated duration: minutes, hours, days, weeks"},
                "kidFriendly": {"type": "boolean", "description": "Whether the activity is suitable for kids"},
                "link": {"type": "string", "description": "URL with more info about the activity (may be empty)"},
                "key": {"type": "string", "description": "Unique activity key/ID"}
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
