    "required_api_keys": [
      "BRENDA_EMAIL",
      "BRENDA_PASSWORD"
    ],
    "parameter": {
      "type": "object",
      "properties": {
        "operation": {
          "type": "string",
          "const": "get_inhibitors",
          "description": "Operation type (fixed: get_inhibitors)"
        },
        "ec_number": {
          "type": "string",
          "description": "EC number"
        },
        "organism": {
          "type": "string",
          "description": "Optional organism filter"
        },
        "enzyme_id": {
          "type": "string",
          "description": "Alias for ec_number. Enzyme identifier in EC notation (e.g., 1.1.1.1)."
        }
      },
      "required": []
    },
    "return_schema": {
      "type": "object",
      "properties": {
        "inhibitors": {
          "type": "array"
        },
        "count": {
          "type": "integer"
        }
      }
    },
    "test_examples": [
      {
        "operation": "get_inhibitors",
