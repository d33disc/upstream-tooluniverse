[
  {
    "name": "BRENDA_get_km",
    "description": "Get Km (Michaelis constant) values from BRENDA enzyme database. Km indicates substrate affinity - lower Km means higher affinity. Returns values in mM with organism and substrate information. Requires free BRENDA account (register at brenda-enzymes.org/register.php).",
    "type": "BRENDATool",
    "required_api_keys": [
      "BRENDA_EMAIL",
      "BRENDA_PASSWORD"
    ],
    "parameter": {
      "type": "object",
      "properties": {
        "operation": {
          "type": "string",
          "const": "get_km",
          "description": "Operation type (fixed: get_km)"
        },
        "ec_number": {
          "type": "string",
          "description": "EC number (e.g., 1.1.1.1 for alcohol dehydrogenase, 2.7.1.1 for hexokinase)"
        },
        "organism": {
          "type": "string",
          "description": "Optional organism filter (e.g., 'Homo sapiens', 'Escherichia coli')"
        },
        "enzyme_id": {
          "type": "string",
          "description": "Alias for ec_number. Enzyme identifier in EC notation (e.g., 1.1.1.1)."
        }
      },
      "required": []
    },
    "return_schema": {
      "type": "object",
      "properties": {
        "ec_number": {
          "type": "string"
        },
        "km_values": {
          "type": "array"
        },
        "count": {
          "type": "integer"
        }
      }
    },
    "test_examples": [
      {
        "operation": "get_km",
        "ec_number": "2.7.1.1",
        "organism": "Homo sapiens"
      },
      {
        "operation": "get_km",
        "ec_number": "1.1.1.27",
        "organism": "Mus musculus"
      }
    ]
  },
  {
