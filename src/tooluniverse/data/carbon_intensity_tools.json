[
  {
    "name": "CarbonIntensity_get_current",
    "description": "Get the current carbon intensity of electricity generation for the UK national grid. Returns actual and forecast carbon intensity in gCO2/kWh and an index (very low, low, moderate, high, very high). Data provided by National Grid ESO.",
    "parameter": {
      "type": "object",
      "properties": {},
      "required": []
    },
    "fields": {
      "endpoint": "https://api.carbonintensity.org.uk/intensity"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Current carbon intensity data",
              "properties": {
                "data": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "from": {"type": "string", "description": "ISO datetime start of period"},
                      "to": {"type": "string", "description": "ISO datetime end of period"},
                      "intensity": {
                        "type": "object",
                        "properties": {
                          "forecast": {"type": "integer", "description": "Forecast intensity in gCO2/kWh"},
                          "actual": {"type": ["integer", "null"], "description": "Actual intensity in gCO2/kWh"},
                          "index": {"type": "string", "description": "Index: very low, low, moderate, high, very high"}
                        }
                      }
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {
            "error": {"type": "string"}
          },
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "CarbonIntensity_get_by_date",
    "description": "Get carbon intensity data for a specific date in the UK. Returns half-hourly actual and forecast carbon intensity values (48 data points per day) in gCO2/kWh. Useful for analyzing daily carbon patterns.",
    "parameter": {
      "type": "object",
      "properties": {
        "date": {
          "type": "string",
          "description": "Date in YYYY-MM-DD format (e.g., '2024-01-15')"
        }
      },
      "required": ["date"]
    },
    "fields": {
      "endpoint": "https://api.carbonintensity.org.uk/intensity/date/{date}"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"date": "2024-01-15"},
      {"date": "2024-06-21"},
      {"date": "2024-12-25"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Carbon intensity data for the date",
              "properties": {
                "data": {
                  "type": "array",
                  "description": "Half-hourly carbon intensity readings (48 per day)",
                  "items": {
                    "type": "object",
                    "properties": {
                      "from": {"type": "string"},
                      "to": {"type": "string"},
                      "intensity": {
                        "type": "object",
                        "properties": {
                          "forecast": {"type": "integer"},
                          "actual": {"type": ["integer", "null"]},
                          "index": {"type": "string"}
                        }
                      }
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {
            "error": {"type": "string"}
          },
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "CarbonIntensity_get_generation_mix",
    "description": "Get the current electricity generation mix for the UK national grid. Returns the percentage breakdown by fuel type (gas, coal, nuclear, wind, solar, biomass, imports, hydro, etc.).",
    "parameter": {
      "type": "object",
      "properties": {},
      "required": []
    },
    "fields": {
      "endpoint": "https://api.carbonintensity.org.uk/generation"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Electricity generation mix",
              "properties": {
                "data": {
                  "type": "object",
                  "properties": {
                    "from": {"type": "string"},
                    "to": {"type": "string"},
                    "generationmix": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "fuel": {"type": "string", "description": "Fuel type (gas, coal, nuclear, wind, solar, biomass, imports, hydro, other)"},
                          "perc": {"type": "number", "description": "Percentage of total generation"}
                        }
                      }
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {
            "error": {"type": "string"}
          },
          "required": ["error"]
        }
      ]
    }
  }
]
