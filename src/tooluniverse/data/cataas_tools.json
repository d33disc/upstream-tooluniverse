[
  {
    "name": "Cataas_get_random_cat",
    "description": "Get a random cat image from the Cat as a Service (CATAAS) API. Returns metadata about a random cat image including its ID, tags, URL, and MIME type. The image URL can be constructed as https://cataas.com/cat/{id}. Optionally filter by tag (e.g., 'cute', 'funny', 'sleeping'). Free, no API key required.",
    "parameter": {
      "type": "object",
      "properties": {
        "tag": {
          "type": ["string", "null"],
          "description": "Filter by tag (e.g., 'cute', 'funny', 'sleeping', 'black', 'orange', 'kitten'). Leave null for any cat."
        }
      },
      "required": []
    },
    "fields": {
      "endpoint": "https://cataas.com/cat",
      "params": {
        "json": "true"
      }
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {},
      {"tag": "cute"},
      {"tag": "funny"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Random cat image metadata",
              "properties": {
                "id": {"type": "string", "description": "Cat image ID"},
                "tags": {"type": "array", "items": {"type": "string"}, "description": "Image tags"},
                "url": {"type": "string", "description": "Direct image URL"},
                "mimetype": {"type": "string", "description": "Image MIME type (image/jpeg, image/png, image/gif)"},
                "created_at": {"type": "string", "description": "Upload date"}
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "Cataas_browse_cats",
    "description": "Browse cat images from the Cat as a Service (CATAAS) API. Returns a paginated list of cat image metadata. Optionally filter by tag and control pagination with skip/limit. Image URLs can be constructed as https://cataas.com/cat/{id}. Free, no API key required.",
    "parameter": {
      "type": "object",
      "properties": {
        "tags": {
          "type": ["string", "null"],
          "description": "Filter by tag (e.g., 'cute', 'funny', 'sleeping', 'black', 'orange'). Leave null for all cats."
        },
        "skip": {
          "type": ["integer", "null"],
          "description": "Number of results to skip for pagination (default 0)"
        },
        "limit": {
          "type": ["integer", "null"],
          "description": "Number of results to return (default 10, max 100)"
        }
      },
      "required": []
    },
    "fields": {
      "endpoint": "https://cataas.com/api/cats"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"limit": 5},
      {"tags": "cute", "limit": 3},
      {"tags": "funny", "skip": 0, "limit": 5}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "array",
              "description": "List of cat image metadata",
              "items": {
                "type": "object",
                "properties": {
                  "id": {"type": "string", "description": "Cat image ID"},
                  "tags": {"type": "array", "items": {"type": "string"}},
                  "mimetype": {"type": "string"},
                  "createdAt": {"type": "string"}
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "Cataas_get_tags",
    "description": "Get all available cat image tags from the Cat as a Service (CATAAS) API. Returns the complete list of tags used to categorize cat images. Tags can be used to filter results in Cataas_get_random_cat and Cataas_browse_cats. Free, no API key required.",
    "parameter": {
      "type": "object",
      "properties": {},
      "required": []
    },
    "fields": {
      "endpoint": "https://cataas.com/api/tags"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {},
      {},
      {}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "array",
              "description": "List of all available tags",
              "items": {"type": "string"}
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
