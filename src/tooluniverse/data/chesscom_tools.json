[
  {
    "name": "ChessCom_get_player_profile",
    "description": "Get a Chess.com player's public profile including rating, title (GM, IM, FM, etc.), country, followers, and account info using the Chess.com Public API. Returns player details like username, FIDE title, total games played, and last online time. No authentication required. Useful for chess analytics, player comparison, and sports data research.",
    "parameter": {
      "type": "object",
      "properties": {
        "username": {
          "type": "string",
          "description": "Chess.com username (case-insensitive). Examples: 'magnuscarlsen', 'hikaru', 'fabianocaruana', 'alireza2003', 'rpragchess'"
        }
      },
      "required": ["username"]
    },
    "fields": {
      "endpoint": "https://api.chess.com/pub/player/{username}",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"username": "magnuscarlsen"},
      {"username": "hikaru"},
      {"username": "fabianocaruana"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Chess.com player profile",
              "properties": {
                "player_id": {"type": "integer"},
                "username": {"type": "string"},
                "name": {"type": ["string", "null"], "description": "Real name"},
                "title": {"type": ["string", "null"], "description": "FIDE title (GM, IM, FM, WGM, CM, NM, etc.)"},
                "followers": {"type": "integer", "description": "Number of Chess.com followers"},
                "country": {"type": "string", "description": "Country URL (e.g., https://api.chess.com/pub/country/US)"},
                "location": {"type": ["string", "null"]},
                "last_online": {"type": "integer", "description": "Unix timestamp of last online"},
                "joined": {"type": "integer", "description": "Unix timestamp when joined"},
                "status": {"type": "string", "description": "Account status (premium, basic, etc.)"},
                "is_streamer": {"type": "boolean"},
                "verified": {"type": "boolean"},
                "league": {"type": ["string", "null"]}
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "ChessCom_get_player_stats",
    "description": "Get a Chess.com player's game statistics including ratings for bullet, blitz, rapid, and daily chess formats using the Chess.com Public API. Returns current rating, number of wins/losses/draws, and best rating achieved for each time control. No authentication required.",
    "parameter": {
      "type": "object",
      "properties": {
        "username": {
          "type": "string",
          "description": "Chess.com username. Examples: 'magnuscarlsen', 'hikaru', 'fabianocaruana', 'alireza2003'"
        }
      },
      "required": ["username"]
    },
    "fields": {
      "endpoint": "https://api.chess.com/pub/player/{username}/stats",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"username": "magnuscarlsen"},
      {"username": "hikaru"},
      {"username": "fabianocaruana"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Player game statistics by time control",
              "properties": {
                "chess_bullet": {
                  "type": "object",
                  "description": "Bullet chess stats (< 3 min)",
                  "properties": {
                    "last": {"type": "object", "properties": {"rating": {"type": "integer"}, "date": {"type": "integer"}}},
                    "best": {"type": "object", "properties": {"rating": {"type": "integer"}, "date": {"type": "integer"}}},
                    "record": {"type": "object", "properties": {"win": {"type": "integer"}, "loss": {"type": "integer"}, "draw": {"type": "integer"}}}
                  }
                },
                "chess_blitz": {
                  "type": "object",
                  "description": "Blitz chess stats (3-10 min)"
                },
                "chess_rapid": {
                  "type": "object",
                  "description": "Rapid chess stats (10-60 min)"
                },
                "chess_daily": {
                  "type": "object",
                  "description": "Daily correspondence chess stats"
                },
                "tactics": {
                  "type": "object",
                  "description": "Puzzle tactics rating and statistics"
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "ChessCom_get_titled_players",
    "description": "Get a list of Chess.com usernames for players with a specific FIDE title (GM, IM, FM, etc.) using the Chess.com Public API. Returns thousands of player usernames for each title class. No authentication required. Useful for finding top players, building chess datasets, and statistical analysis.",
    "parameter": {
      "type": "object",
      "properties": {
        "title_abbrev": {
          "type": "string",
          "description": "FIDE title abbreviation. Values: 'GM' (Grandmaster), 'WGM' (Women's GM), 'IM' (International Master), 'WIM', 'FM' (FIDE Master), 'WFM', 'NM' (National Master), 'WNM', 'CM' (Candidate Master), 'WCM'"
        }
      },
      "required": ["title_abbrev"]
    },
    "fields": {
      "endpoint": "https://api.chess.com/pub/titled/{title_abbrev}",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"title_abbrev": "GM"},
      {"title_abbrev": "WGM"},
      {"title_abbrev": "IM"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "List of Chess.com usernames with the specified title",
              "properties": {
                "players": {
                  "type": "array",
                  "description": "Array of Chess.com usernames",
                  "items": {"type": "string"}
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
