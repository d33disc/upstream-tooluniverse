[
  {
    "name": "ChroniclingAmerica_search_newspapers",
    "description": "Search historic US newspaper pages from the Library of Congress Chronicling America collection. Contains millions of digitized newspaper pages from 1777 to 1963 across all US states and territories. Returns matching newspaper pages with OCR text excerpts, dates, titles, and page images. Useful for historical research, genealogy, finding primary source reporting on past events, and studying media coverage over time. Example: searching 'civil war' with dates=1863 returns 16,000+ newspaper pages from the Civil War era.",
    "parameter": {
      "type": "object",
      "properties": {
        "q": {
          "type": "string",
          "description": "Search query for full-text search of newspaper content. Supports AND/OR/NOT and quoted phrases. Examples: 'moon landing', 'Abraham Lincoln assassination', '\"gold rush\"', 'suffrage OR suffragette'."
        },
        "dates": {
          "type": ["string", "null"],
          "description": "Year or year range to filter results. Examples: '1863' (single year), '1900/1910' (range from 1900 to 1910), '1776' (founding era). Coverage spans 1777-1963."
        },
        "c": {
          "type": ["integer", "null"],
          "description": "Number of results per page (default 20, max 160). Each result is one newspaper page."
        },
        "sp": {
          "type": ["integer", "null"],
          "description": "Page number for pagination (starts at 1)."
        }
      },
      "required": ["q"]
    },
    "fields": {
      "endpoint": "https://www.loc.gov/collections/chronicling-america/",
      "params": {
        "fo": "json",
        "c": "10"
      }
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"q": "civil war", "dates": "1863"},
      {"q": "moon landing", "dates": "1969"},
      {"q": "darwin", "c": 5}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Chronicling America newspaper search results",
              "properties": {
                "pagination": {
                  "type": "object",
                  "properties": {
                    "total": {"type": "integer", "description": "Total matching pages"},
                    "of": {"type": "integer", "description": "Total pages in result set"},
                    "perpage": {"type": "integer", "description": "Results per page"},
                    "from": {"type": "integer"},
                    "to": {"type": "integer"}
                  }
                },
                "results": {
                  "type": "array",
                  "description": "List of matching newspaper pages",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {"type": "string", "description": "LOC item URL identifier"},
                      "title": {"type": ["string", "null"], "description": "Newspaper page title"},
                      "date": {"type": ["string", "null"], "description": "Publication date (YYYY-MM-DD)"},
                      "description": {"type": ["array", "null"], "items": {"type": "string"}, "description": "OCR text excerpt from the page"},
                      "contributor": {"type": ["array", "null"], "items": {"type": "string"}, "description": "Contributing institution"},
                      "batch": {"type": ["array", "null"], "items": {"type": "string"}, "description": "Digitization batch identifier"},
                      "composite_location": {"type": ["array", "null"], "items": {"type": "string"}, "description": "Geographic location hierarchy"},
                      "image_url": {"type": ["array", "null"], "items": {"type": "string"}, "description": "URLs for page images"},
                      "url": {"type": ["string", "null"], "description": "Direct URL to the newspaper page on LOC.gov"}
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
