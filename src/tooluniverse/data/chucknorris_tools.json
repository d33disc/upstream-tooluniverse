[
  {
    "name": "ChuckNorris_get_random_joke",
    "description": "Get a random Chuck Norris joke from the Chuck Norris API (chucknorris.io). Free hand-curated database of Chuck Norris facts/jokes. Optionally filter by category (animal, career, celebrity, dev, fashion, food, history, money, movie, music, political, religion, science, sport, travel). No API key required.",
    "parameter": {
      "type": "object",
      "properties": {
        "category": {
          "type": ["string", "null"],
          "description": "Joke category to filter by. Options: animal, career, celebrity, dev, explicit, fashion, food, history, money, movie, music, political, religion, science, sport, travel. Leave null for any category."
        }
      },
      "required": []
    },
    "fields": {
      "endpoint": "https://api.chucknorris.io/jokes/random"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {},
      {"category": "dev"},
      {"category": "science"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Chuck Norris joke",
              "properties": {
                "id": {"type": "string", "description": "Unique joke ID"},
                "value": {"type": "string", "description": "The joke text"},
                "categories": {"type": "array", "items": {"type": "string"}, "description": "Joke categories"},
                "url": {"type": "string", "description": "Permalink to this joke"},
                "icon_url": {"type": "string"},
                "created_at": {"type": "string"},
                "updated_at": {"type": "string"}
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "ChuckNorris_search_jokes",
    "description": "Search for Chuck Norris jokes by keyword from the Chuck Norris API (chucknorris.io). Returns all matching jokes (usually 1-100+ results). Query must be at least 3 characters. No API key required.",
    "parameter": {
      "type": "object",
      "properties": {
        "query": {
          "type": "string",
          "description": "Search query (minimum 3 characters). Examples: 'internet', 'computer', 'karate', 'roundhouse'"
        }
      },
      "required": ["query"]
    },
    "fields": {
      "endpoint": "https://api.chucknorris.io/jokes/search"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"query": "internet"},
      {"query": "computer"},
      {"query": "karate"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Search results",
              "properties": {
                "total": {"type": "integer", "description": "Total number of matching jokes"},
                "result": {
                  "type": "array",
                  "description": "Matching jokes",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {"type": "string"},
                      "value": {"type": "string", "description": "The joke text"},
                      "categories": {"type": "array", "items": {"type": "string"}},
                      "url": {"type": "string"}
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "ChuckNorris_get_categories",
    "description": "Get the list of all available Chuck Norris joke categories from chucknorris.io. Returns category names that can be used to filter random jokes via ChuckNorris_get_random_joke. No API key required.",
    "parameter": {
      "type": "object",
      "properties": {},
      "required": []
    },
    "fields": {
      "endpoint": "https://api.chucknorris.io/jokes/categories"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {},
      {},
      {}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "array",
              "description": "List of available joke categories",
              "items": {"type": "string"}
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
