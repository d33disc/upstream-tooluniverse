[
  {
    "name": "CityBikes_list_networks",
    "description": "List all bike-sharing networks worldwide available in the CityBikes API. Returns 800+ networks across 50+ countries including Santander Cycles (London), Citi Bike (New York), Vélib (Paris), and regional networks. Each network includes name, city, country, GPS coordinates, and company. Useful for urban mobility research, transportation studies, and sustainable transport analysis.",
    "parameter": {
      "type": "object",
      "properties": {
        "fields": {
          "type": ["string", "null"],
          "description": "Comma-separated fields to include. Default: all. Options: id, name, location, company, gbfs_href"
        }
      },
      "required": []
    },
    "fields": {
      "endpoint": "https://api.citybik.es/v2/networks",
      "params": {
        "fields": "id,name,location,company"
      }
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"fields": "id,name,location,company"},
      {},
      {"fields": "id,name,location"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Worldwide bike-sharing networks",
              "properties": {
                "networks": {
                  "type": "array",
                  "description": "List of bike-sharing networks",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {"type": "string", "description": "Network identifier (use in CityBikes_get_network_stations)"},
                      "name": {"type": "string", "description": "Network name"},
                      "company": {"type": ["array", "null"], "items": {"type": "string"}, "description": "Operating company"},
                      "location": {
                        "type": "object",
                        "description": "Network location",
                        "properties": {
                          "city": {"type": "string", "description": "City name"},
                          "country": {"type": "string", "description": "ISO 2-letter country code"},
                          "latitude": {"type": "number"},
                          "longitude": {"type": "number"}
                        }
                      }
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "CityBikes_get_network_stations",
    "description": "Get real-time station data for a specific bike-sharing network using the CityBikes API. Returns all stations with GPS coordinates, available bikes, empty slots, and bike type details. Data is updated in real-time. Use CityBikes_list_networks to find network IDs. Examples: 'santander-cycles' (London), 'citi-bike-nyc' (New York), 'velib' (Paris), 'nextbike-berlin' (Berlin).",
    "parameter": {
      "type": "object",
      "properties": {
        "network_id": {
          "type": "string",
          "description": "Network ID from CityBikes_list_networks. Examples: 'santander-cycles', 'citi-bike-nyc', 'velib', 'bicing' (Barcelona), 'callabike' (Germany)"
        }
      },
      "required": ["network_id"]
    },
    "fields": {
      "endpoint": "https://api.citybik.es/v2/networks/{network_id}"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"network_id": "santander-cycles"},
      {"network_id": "citi-bike-nyc"},
      {"network_id": "velib"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Bike-sharing network with real-time station data",
              "properties": {
                "network": {
                  "type": "object",
                  "properties": {
                    "id": {"type": "string"},
                    "name": {"type": "string", "description": "Network name"},
                    "company": {"type": ["array", "null"], "items": {"type": "string"}},
                    "location": {
                      "type": "object",
                      "properties": {
                        "city": {"type": "string"},
                        "country": {"type": "string"},
                        "latitude": {"type": "number"},
                        "longitude": {"type": "number"}
                      }
                    },
                    "stations": {
                      "type": "array",
                      "description": "Real-time data for each station",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {"type": "string", "description": "Station ID"},
                          "name": {"type": "string", "description": "Station name"},
                          "latitude": {"type": "number", "description": "Station latitude"},
                          "longitude": {"type": "number", "description": "Station longitude"},
                          "free_bikes": {"type": "integer", "description": "Number of available bikes"},
                          "empty_slots": {"type": "integer", "description": "Number of available docking slots"},
                          "timestamp": {"type": "string", "description": "Last update time (ISO 8601)"},
                          "extra": {"type": ["object", "null"], "description": "Additional info (electric bikes, capacity, etc.)"}
                        }
                      }
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
