[
  {
    "name": "ClevelandArt_search_artworks",
    "description": "Search the Cleveland Museum of Art's open access collection of 61,000+ artworks through their public API. Returns artworks with title, artist, creation date, medium, dimensions, and image links. The collection spans 5,000 years including ancient Egyptian art, European paintings, Asian art, and modern works. All open access artworks are available for unrestricted use.",
    "parameter": {
      "type": "object",
      "properties": {
        "q": {
          "type": ["string", "null"],
          "description": "Search query. Examples: 'van gogh', 'chinese bronze', 'impressionism', 'portrait'"
        },
        "department": {
          "type": ["string", "null"],
          "description": "Filter by department. Examples: 'Egyptian and Ancient Near Eastern Art', 'European Paintings', 'Asian Art', 'Prints', 'Photography'"
        },
        "type": {
          "type": ["string", "null"],
          "description": "Filter by artwork type. Examples: 'Painting', 'Sculpture', 'Drawing', 'Print', 'Photograph'"
        },
        "culture": {
          "type": ["string", "null"],
          "description": "Filter by culture. Examples: 'American', 'French', 'Chinese', 'Japanese', 'Egyptian'"
        },
        "technique": {
          "type": ["string", "null"],
          "description": "Filter by technique. Examples: 'Oil on canvas', 'Watercolor', 'Bronze casting'"
        },
        "limit": {
          "type": ["integer", "null"],
          "description": "Number of results (default 10, max 1000)"
        },
        "skip": {
          "type": ["integer", "null"],
          "description": "Number of records to skip for pagination"
        }
      },
      "required": []
    },
    "fields": {
      "endpoint": "https://openaccess-api.clevelandart.org/api/artworks",
      "params": {
        "limit": "10"
      }
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"q": "monet", "limit": 5},
      {"department": "Egyptian and Ancient Near Eastern Art", "limit": 5},
      {"type": "Painting", "culture": "French", "limit": 5}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Artwork search results",
              "properties": {
                "info": {
                  "type": "object",
                  "properties": {
                    "total": {"type": "integer", "description": "Total number of matching artworks"},
                    "parameters": {"type": "object"}
                  }
                },
                "data": {
                  "type": "array",
                  "description": "List of artworks",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {"type": "integer", "description": "Artwork ID"},
                      "accession_number": {"type": "string", "description": "Museum accession number"},
                      "title": {"type": "string", "description": "Artwork title"},
                      "creation_date": {"type": ["string", "null"], "description": "Creation date"},
                      "artists_tags": {"type": "array", "items": {"type": "string"}, "description": "Artist names"},
                      "culture": {"type": ["array", "null"], "items": {"type": "string"}, "description": "Cultural origin"},
                      "technique": {"type": ["array", "null"], "items": {"type": "string"}, "description": "Technique used"},
                      "department": {"type": ["string", "null"], "description": "Museum department"},
                      "type": {"type": ["string", "null"], "description": "Artwork type"},
                      "url": {"type": ["string", "null"], "description": "URL to artwork on museum website"},
                      "images": {"type": ["object", "null"], "description": "Image URLs (web, print, full)"},
                      "share_license_status": {"type": ["string", "null"], "description": "License (CC0 = fully open)"}
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
