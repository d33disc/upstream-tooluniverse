[
  {
    "name": "ClinicalTrials_search_studies",
    "description": "Search ClinicalTrials.gov for clinical trials and interventional/observational studies. Returns study NCT IDs, titles, status, conditions, interventions, sponsors, phases, enrollment numbers, and dates. ClinicalTrials.gov contains 500,000+ studies from 230 countries. No authentication required. Useful for clinical research, drug development tracking, and evidence-based medicine.",
    "parameter": {
      "type": "object",
      "properties": {
        "query.cond": {
          "type": ["string", "null"],
          "description": "Search condition/disease. Examples: 'diabetes', 'breast cancer', 'COVID-19', 'Alzheimer disease', 'hypertension'"
        },
        "query.intr": {
          "type": ["string", "null"],
          "description": "Search intervention/treatment. Examples: 'metformin', 'immunotherapy', 'CRISPR', 'mRNA vaccine'"
        },
        "query.term": {
          "type": ["string", "null"],
          "description": "General text search across all fields. Examples: 'BRCA1', 'phase 3 trial', 'placebo controlled'"
        },
        "filter.overallStatus": {
          "type": ["string", "null"],
          "description": "Filter by status. Values: 'RECRUITING', 'COMPLETED', 'ACTIVE_NOT_RECRUITING', 'TERMINATED', 'NOT_YET_RECRUITING'"
        },
        "filter.phase": {
          "type": ["string", "null"],
          "description": "Filter by phase. Values: 'PHASE1', 'PHASE2', 'PHASE3', 'PHASE4', 'NA' (not applicable)"
        },
        "pageSize": {
          "type": ["integer", "null"],
          "description": "Number of results per page (default 10, max 1000)"
        },
        "pageToken": {
          "type": ["string", "null"],
          "description": "Token for next page from previous response"
        }
      },
      "required": []
    },
    "fields": {
      "endpoint": "https://clinicaltrials.gov/api/v2/studies",
      "params": {
        "format": "json",
        "pageSize": "10",
        "fields": "NCTId,BriefTitle,OverallStatus,Phase,Condition,InterventionName,StudyType,EnrollmentCount,StartDate,CompletionDate,Sponsor,LeadSponsorName"
      }
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"query.cond": "diabetes", "filter.overallStatus": "RECRUITING"},
      {"query.cond": "breast cancer", "filter.phase": "PHASE3", "pageSize": 5},
      {"query.intr": "metformin", "query.cond": "obesity"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Clinical trials search results",
              "properties": {
                "nextPageToken": {"type": ["string", "null"], "description": "Token for next page"},
                "studies": {
                  "type": "array",
                  "description": "List of clinical studies",
                  "items": {
                    "type": "object",
                    "description": "Clinical study data (nested protocolSection structure)",
                    "properties": {
                      "protocolSection": {
                        "type": "object",
                        "properties": {
                          "identificationModule": {
                            "type": "object",
                            "properties": {
                              "nctId": {"type": "string", "description": "ClinicalTrials.gov identifier (e.g., NCT01234567)"},
                              "briefTitle": {"type": "string", "description": "Short study title"},
                              "officialTitle": {"type": ["string", "null"]}
                            }
                          },
                          "statusModule": {
                            "type": "object",
                            "properties": {
                              "overallStatus": {"type": "string", "description": "Study status"},
                              "startDateStruct": {"type": "object"},
                              "completionDateStruct": {"type": "object"}
                            }
                          },
                          "designModule": {
                            "type": "object",
                            "properties": {
                              "studyType": {"type": "string"},
                              "phases": {"type": "array", "items": {"type": "string"}},
                              "enrollmentInfo": {"type": "object"}
                            }
                          },
                          "conditionsModule": {
                            "type": "object",
                            "properties": {
                              "conditions": {"type": "array", "items": {"type": "string"}}
                            }
                          },
                          "armsInterventionsModule": {
                            "type": "object",
                            "properties": {
                              "interventions": {
                                "type": "array",
                                "items": {
                                  "type": "object",
                                  "properties": {
                                    "type": {"type": "string"},
                                    "name": {"type": "string"}
                                  }
                                }
                              }
                            }
                          },
                          "sponsorCollaboratorsModule": {
                            "type": "object",
                            "properties": {
                              "leadSponsor": {"type": "object"}
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
