[
  {
    "name": "ClinicalTrials_search_studies",
    "description": "Search ClinicalTrials.gov for clinical trial studies by condition, intervention, sponsor, or other criteria. Returns NCT IDs, titles, status, phase, enrollment, and key trial metadata. Example: search for 'breast cancer' trials with 'pembrolizumab' that are RECRUITING in Phase 3.",
    "parameter": {
      "type": "object",
      "properties": {
        "query_cond": {
          "type": [
            "string",
            "null"
          ],
          "description": "Disease or condition to search for (e.g., 'breast cancer', 'type 2 diabetes', 'COVID-19'). Supports Boolean operators (AND, OR, NOT)."
        },
        "query_intr": {
          "type": [
            "string",
            "null"
          ],
          "description": "Intervention or drug to search for (e.g., 'pembrolizumab', 'metformin', 'chemotherapy')."
        },
        "query_term": {
          "type": [
            "string",
            "null"
          ],
          "description": "Free-text search across all study fields. Use for general keyword search."
        },
        "filter_status": {
          "type": [
            "string",
            "null"
          ],
          "description": "Filter by recruitment status. Options: 'RECRUITING', 'NOT_YET_RECRUITING', 'ACTIVE_NOT_RECRUITING', 'COMPLETED', 'WITHDRAWN', 'SUSPENDED', 'TERMINATED', 'ENROLLING_BY_INVITATION'. Comma-separate multiple values."
        },
        "filter_phase": {
          "type": [
            "string",
            "null"
          ],
          "description": "Filter by trial phase. Options: 'EARLY_PHASE1', 'PHASE1', 'PHASE2', 'PHASE3', 'PHASE4', 'NA'. Comma-separate multiple (e.g., 'PHASE2,PHASE3')."
        },
        "filter_study_type": {
          "type": [
            "string",
            "null"
          ],
          "description": "Filter by study type: 'INTERVENTIONAL', 'OBSERVATIONAL', 'EXPANDED_ACCESS'."
        },
        "page_size": {
          "type": "integer",
          "description": "Number of results per page (default 10, max 1000).",
          "default": 10,
          "minimum": 1,
          "maximum": 1000
        },
        "next_page_token": {
          "type": [
            "string",
            "null"
          ],
          "description": "Token for retrieving the next page of results (obtained from previous response)."
        }
      },
      "required": []
    },
    "fields": {
      "operation": "search"
    },
    "type": "CTGovAPITool",
    "test_examples": [
      {
        "query_cond": "breast cancer",
        "query_intr": "pembrolizumab",
        "filter_status": "RECRUITING",
        "page_size": 5
      },
      {
        "query_cond": "type 2 diabetes",
        "filter_phase": "PHASE3",
        "page_size": 5
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "properties": {
                "studies": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "nct_id": {
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "brief_title": {
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "status": {
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "study_type": {
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "phases": {
                        "type": "array"
                      },
                      "enrollment": {
                        "type": [
                          "integer",
                          "null"
                        ]
                      },
                      "conditions": {
                        "type": "array"
                      },
                      "interventions": {
                        "type": "array"
                      },
                      "sponsor": {
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "start_date": {
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "completion_date": {
                        "type": [
                          "string",
                          "null"
                        ]
                      }
                    }
                  }
                },
                "total_count": {
                  "type": [
                    "integer",
                    "null"
                  ]
                },
                "next_page_token": {
                  "type": [
                    "string",
                    "null"
                  ]
                }
              }
            },
            "metadata": {
              "type": "object"
            }
          },
          "required": [
            "data"
          ]
        },
        {
          "type": "object",
          "properties": {
            "error": {
              "type": "string"
            }
          },
          "required": [
            "error"
          ]
        }
      ]
    },
    "label": [
      "ClinicalTrials",
      "Clinical Trials",
      "Drug Development",
      "Clinical Research"
    ],
    "metadata": {
      "tags": [
        "clinical_trials",
        "drug_development",
        "interventional_studies",
        "clinical_research"
      ],
      "estimated_execution_time": "< 3 seconds"
    }
