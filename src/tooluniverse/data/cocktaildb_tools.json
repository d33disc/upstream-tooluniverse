  {
    "name": "TheCocktailDB_search_ingredient",
    "description": "Search for ingredient details in TheCocktailDB by name. Returns the ingredient's description, type (e.g., Spirit, Liqueur, Juice), whether it contains alcohol, and its alcohol by volume (ABV). Useful for understanding cocktail ingredients, learning about spirits and liqueurs, and building ingredient databases for recipe analysis.",
    "parameter": {
      "type": "object",
      "properties": {
        "i": {
          "type": "string",
          "description": "Ingredient name to look up. Examples: 'vodka', 'gin', 'rum', 'tequila', 'triple sec', 'kahlua', 'lime juice', 'angostura bitters'"
        }
      },
      "required": ["i"]
    },
    "fields": {
      "endpoint": "https://www.thecocktaildb.com/api/json/v1/1/search.php"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"i": "vodka"},
      {"i": "gin"},
      {"i": "lime juice"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Ingredient search results",
              "properties": {
                "ingredients": {
                  "type": ["array", "null"],
                  "description": "List of matching ingredients (null if not found)",
                  "items": {
                    "type": "object",
                    "properties": {
                      "idIngredient": {"type": "string", "description": "Ingredient ID"},
                      "strIngredient": {"type": "string", "description": "Ingredient name"},
                      "strDescription": {"type": ["string", "null"], "description": "Detailed description of the ingredient, its history, and production"},
                      "strType": {"type": ["string", "null"], "description": "Type/category (e.g., 'Vodka', 'Spirit', 'Liqueur', 'Juice')"},
                      "strAlcohol": {"type": ["string", "null"], "description": "Whether it contains alcohol ('Yes' or 'No')"},
                      "strABV": {"type": ["string", "null"], "description": "Alcohol by volume percentage (e.g., '40')"}
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
