[
  {
    "name": "TheCocktailDB_search_cocktails",
    "description": "Search for cocktail recipes by name in TheCocktailDB, a comprehensive free cocktail database. Returns cocktails with full ingredients, measurements, instructions, glass type, category (Ordinary Drink, Cocktail, Shot, etc.), and whether they are alcoholic. Useful for food science, mixology research, chemistry of flavor compounds, and culinary AI applications.",
    "parameter": {
      "type": "object",
      "properties": {
        "s": {
          "type": ["string", "null"],
          "description": "Search by cocktail name. Examples: 'margarita', 'mojito', 'martini', 'negroni', 'old fashioned'"
        },
        "f": {
          "type": ["string", "null"],
          "description": "Search by first letter of cocktail name. Single character: 'a', 'b', 'm', etc."
        }
      },
      "required": []
    },
    "fields": {
      "endpoint": "https://www.thecocktaildb.com/api/json/v1/1/search.php"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"s": "margarita"},
      {"s": "mojito"},
      {"f": "a"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Cocktail search results",
              "properties": {
                "drinks": {
                  "type": ["array", "null"],
                  "description": "List of matching cocktails (null if no results)",
                  "items": {
                    "type": "object",
                    "properties": {
                      "idDrink": {"type": "string", "description": "Cocktail ID"},
                      "strDrink": {"type": "string", "description": "Cocktail name"},
                      "strCategory": {"type": ["string", "null"], "description": "Cocktail category"},
                      "strAlcoholic": {"type": ["string", "null"], "description": "Alcoholic/Non alcoholic"},
                      "strGlass": {"type": ["string", "null"], "description": "Glass type"},
                      "strInstructions": {"type": ["string", "null"], "description": "Preparation instructions"},
                      "strDrinkThumb": {"type": ["string", "null"], "description": "Cocktail image URL"},
                      "strTags": {"type": ["string", "null"], "description": "Comma-separated tags (e.g., 'IBA,ContemporaryClassic')"},
                      "strIBA": {"type": ["string", "null"], "description": "IBA (International Bartenders Association) category"},
                      "strIngredient1": {"type": ["string", "null"], "description": "First ingredient"},
                      "strMeasure1": {"type": ["string", "null"], "description": "First ingredient measure"},
                      "strIngredient2": {"type": ["string", "null"]},
                      "strIngredient3": {"type": ["string", "null"]},
                      "strIngredient4": {"type": ["string", "null"]},
                      "strIngredient5": {"type": ["string", "null"]}
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "TheCocktailDB_lookup_cocktail",
    "description": "Look up full details of a specific cocktail by its ID in TheCocktailDB. Returns complete recipe including all ingredients (up to 15), measurements, preparation instructions in multiple languages, glass type, category, IBA classification, and image. Use this after finding cocktail IDs from search or filter results.",
    "parameter": {
      "type": "object",
      "properties": {
        "i": {
          "type": "string",
          "description": "Cocktail ID. Examples: '11007' (Margarita), '11000' (Mojito), '11001' (Old Fashioned), '11003' (Negroni), '17216' (Tommy's Margarita)"
        }
      },
      "required": ["i"]
    },
    "fields": {
      "endpoint": "https://www.thecocktaildb.com/api/json/v1/1/lookup.php"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"i": "11007"},
      {"i": "11000"},
      {"i": "11003"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Cocktail lookup result",
              "properties": {
                "drinks": {
                  "type": ["array", "null"],
                  "description": "Array with single cocktail object (null if ID not found)",
                  "items": {
                    "type": "object",
                    "properties": {
                      "idDrink": {"type": "string"},
                      "strDrink": {"type": "string", "description": "Cocktail name"},
                      "strCategory": {"type": ["string", "null"]},
                      "strAlcoholic": {"type": ["string", "null"]},
                      "strGlass": {"type": ["string", "null"]},
                      "strInstructions": {"type": ["string", "null"], "description": "English instructions"},
                      "strInstructionsES": {"type": ["string", "null"], "description": "Spanish instructions"},
                      "strInstructionsDE": {"type": ["string", "null"], "description": "German instructions"},
                      "strInstructionsFR": {"type": ["string", "null"], "description": "French instructions"},
                      "strInstructionsIT": {"type": ["string", "null"], "description": "Italian instructions"},
                      "strDrinkThumb": {"type": ["string", "null"]},
                      "strIngredient1": {"type": ["string", "null"]},
                      "strMeasure1": {"type": ["string", "null"]},
                      "strIngredient2": {"type": ["string", "null"]},
                      "strMeasure2": {"type": ["string", "null"]},
                      "strIngredient3": {"type": ["string", "null"]},
                      "strMeasure3": {"type": ["string", "null"]}
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "TheCocktailDB_filter_cocktails",
    "description": "Filter cocktails by ingredient, category, glass type, or alcoholic content in TheCocktailDB. Returns a list of matching cocktail names, thumbnails, and IDs (not full recipes -- use lookup for full details). Useful for discovering cocktails that use a specific ingredient or finding all drinks in a category.",
    "parameter": {
      "type": "object",
      "properties": {
        "i": {
          "type": ["string", "null"],
          "description": "Filter by ingredient name. Examples: 'Vodka', 'Gin', 'Rum', 'Tequila', 'Whiskey', 'Lime juice', 'Triple sec'"
        },
        "c": {
          "type": ["string", "null"],
          "description": "Filter by category. Values: 'Ordinary Drink', 'Cocktail', 'Milk / Float / Shake', 'Other / Unknown', 'Cocoa', 'Shot', 'Coffee / Tea', 'Homemade Liqueur', 'Punch / Party Drink', 'Beer', 'Soft Drink'"
        },
        "g": {
          "type": ["string", "null"],
          "description": "Filter by glass type. Examples: 'Cocktail glass', 'Highball glass', 'Old-fashioned glass', 'Shot glass', 'Champagne flute', 'Collins glass'"
        },
        "a": {
          "type": ["string", "null"],
          "description": "Filter by alcoholic content. Values: 'Alcoholic', 'Non_Alcoholic', 'Optional_Alcohol'"
        }
      },
      "required": []
    },
    "fields": {
      "endpoint": "https://www.thecocktaildb.com/api/json/v1/1/filter.php"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"i": "Vodka"},
      {"c": "Cocktail"},
      {"a": "Non_Alcoholic"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Filtered cocktail list",
              "properties": {
                "drinks": {
                  "type": ["array", "null"],
                  "description": "List of matching cocktails (abbreviated -- name, thumb, and ID only)",
                  "items": {
                    "type": "object",
                    "properties": {
                      "strDrink": {"type": "string", "description": "Cocktail name"},
                      "strDrinkThumb": {"type": "string", "description": "Cocktail thumbnail image URL"},
                      "idDrink": {"type": "string", "description": "Cocktail ID (use with lookup endpoint for full details)"}
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
