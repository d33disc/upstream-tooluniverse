[
  {
    "name": "COD_search_structures",
    "description": "Search the Crystallography Open Database (COD) for crystal structures by chemical formula, elements, space group, mineral name, or compound name. COD is the largest open-access collection of crystal structures with 500,000+ experimentally determined structures. Returns unit cell parameters (a, b, c, alpha, beta, gamma), space group, chemical formula, mineral/compound name, and publication details (DOI, journal, authors). Useful for materials science, chemistry, mineralogy, and solid-state physics research.",
    "parameter": {
      "type": "object",
      "properties": {
        "formula": {
          "type": ["string", "null"],
          "description": "Chemical formula to search. Examples: 'SiO2', 'NaCl', 'CaCO3', 'Al2O3'. Exact formula matching."
        },
        "el1": {
          "type": ["string", "null"],
          "description": "First required element (chemical symbol). Examples: 'Cu', 'Fe', 'Si', 'C', 'N'"
        },
        "el2": {
          "type": ["string", "null"],
          "description": "Second required element (chemical symbol)"
        },
        "el3": {
          "type": ["string", "null"],
          "description": "Third required element (chemical symbol)"
        },
        "nel": {
          "type": ["string", "null"],
          "description": "Number of distinct elements in formula (e.g., '2' for binary compounds, '3' for ternary)"
        },
        "commonname": {
          "type": ["string", "null"],
          "description": "Common/trivial name search (partial match). Examples: 'quartz', 'perovskite', 'zeolite', 'diamond'"
        },
        "mineral": {
          "type": ["string", "null"],
          "description": "Mineral name search (partial match). Examples: 'calcite', 'feldspar', 'pyrite', 'magnetite'"
        },
        "sg": {
          "type": ["string", "null"],
          "description": "Space group symbol (Hermann-Mauguin notation). Examples: 'P 21/c', 'Fm -3 m', 'P 1'"
        },
        "sgNumber": {
          "type": ["string", "null"],
          "description": "Space group number (1-230). Examples: '225' (Fm-3m, FCC metals), '62' (Pnma, common for perovskites)"
        },
        "limit": {
          "type": ["integer", "null"],
          "description": "Maximum number of results (default 100, use smaller values for speed)"
        }
      },
      "required": []
    },
    "fields": {
      "endpoint": "https://www.crystallography.net/cod/result",
      "params": {
        "format": "json"
      }
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"el1": "Si", "el2": "O", "nel": "2", "limit": 10},
      {"mineral": "calcite", "limit": 5},
      {"el1": "Cu", "el2": "O", "nel": "2", "sgNumber": "225", "limit": 5}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "array",
              "description": "List of crystal structures matching the search criteria",
              "items": {
                "type": "object",
                "properties": {
                  "file": {"type": "string", "description": "COD structure file ID"},
                  "formula": {"type": ["string", "null"], "description": "Chemical formula"},
                  "calcformula": {"type": ["string", "null"]},
                  "commonname": {"type": ["string", "null"], "description": "Common compound name"},
                  "mineral": {"type": ["string", "null"], "description": "Mineral name"},
                  "chemname": {"type": ["string", "null"]},
                  "sg": {"type": ["string", "null"], "description": "Space group symbol"},
                  "sgNumber": {"type": ["string", "null"], "description": "Space group number (1-230)"},
                  "a": {"type": ["string", "null"], "description": "Unit cell parameter a (Angstroms)"},
                  "b": {"type": ["string", "null"], "description": "Unit cell parameter b (Angstroms)"},
                  "c": {"type": ["string", "null"], "description": "Unit cell parameter c (Angstroms)"},
                  "alpha": {"type": ["string", "null"], "description": "Unit cell angle alpha (degrees)"},
                  "beta": {"type": ["string", "null"], "description": "Unit cell angle beta (degrees)"},
                  "gamma": {"type": ["string", "null"], "description": "Unit cell angle gamma (degrees)"},
                  "vol": {"type": ["string", "null"], "description": "Unit cell volume (Angstroms^3)"},
                  "doi": {"type": ["string", "null"], "description": "Publication DOI"},
                  "journal": {"type": ["string", "null"]},
                  "year": {"type": ["string", "null"]},
                  "title": {"type": ["string", "null"]},
                  "authors": {"type": ["string", "null"]},
                  "status": {"type": ["string", "null"]},
                  "method": {"type": ["string", "null"], "description": "Diffraction method"},
                  "radiation": {"type": ["string", "null"]}
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
