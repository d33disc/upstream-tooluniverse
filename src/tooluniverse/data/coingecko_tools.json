[
  {
    "name": "CoinGecko_get_coin_price",
    "description": "Get current price, market cap, and 24h change for one or more cryptocurrencies using the CoinGecko public API. No authentication required for basic queries. Coin IDs use lowercase with hyphens: 'bitcoin', 'ethereum', 'solana'. Use CoinGecko_list_coins to find coin IDs.",
    "parameter": {
      "type": "object",
      "properties": {
        "ids": {
          "type": "string",
          "description": "Comma-separated coin IDs. Examples: 'bitcoin', 'bitcoin,ethereum', 'bitcoin,ethereum,solana,cardano'. Use lowercase with hyphens."
        },
        "vs_currencies": {
          "type": ["string", "null"],
          "description": "Target currency for prices, comma-separated. Default: 'usd'. Examples: 'usd', 'usd,eur,gbp', 'btc'"
        },
        "include_market_cap": {
          "type": ["string", "null"],
          "description": "Include market cap in response. Values: 'true', 'false'. Default: false"
        },
        "include_24hr_change": {
          "type": ["string", "null"],
          "description": "Include 24h price change percentage. Values: 'true', 'false'. Default: false"
        }
      },
      "required": ["ids"]
    },
    "fields": {
      "endpoint": "https://api.coingecko.com/api/v3/simple/price",
      "params": {"vs_currencies": "usd"}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"ids": "bitcoin,ethereum", "vs_currencies": "usd"},
      {"ids": "bitcoin", "vs_currencies": "usd,eur", "include_24hr_change": "true"},
      {"ids": "solana,cardano,polkadot", "vs_currencies": "usd", "include_market_cap": "true"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Price data keyed by coin ID. Each coin maps to currency->price pairs.",
              "additionalProperties": {
                "type": "object",
                "description": "Price data for a coin",
                "properties": {
                  "usd": {"type": "number", "description": "Price in USD"},
                  "eur": {"type": "number", "description": "Price in EUR"},
                  "usd_market_cap": {"type": "number", "description": "Market cap in USD (if requested)"},
                  "usd_24h_change": {"type": "number", "description": "24h change % in USD (if requested)"}
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "CoinGecko_get_coin_info",
    "description": "Get comprehensive information about a specific cryptocurrency from CoinGecko, including description, market data, links, and metadata. No authentication required. Returns detailed coin profile with market cap rank, circulating supply, all-time high/low, and social links.",
    "parameter": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "CoinGecko coin ID. Examples: 'bitcoin', 'ethereum', 'solana', 'cardano', 'polkadot'. Use lowercase with hyphens."
        },
        "localization": {
          "type": ["string", "null"],
          "description": "Include localized names. Values: 'true', 'false'. Default: false (set to false for smaller response)"
        }
      },
      "required": ["id"]
    },
    "fields": {
      "endpoint": "https://api.coingecko.com/api/v3/coins/{id}",
      "params": {"localization": "false", "tickers": "false", "community_data": "false", "developer_data": "false"}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"id": "bitcoin"},
      {"id": "ethereum"},
      {"id": "solana"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Comprehensive coin information",
              "properties": {
                "id": {"type": "string"},
                "symbol": {"type": "string", "description": "Ticker symbol (e.g., btc, eth)"},
                "name": {"type": "string"},
                "description": {"type": "object", "properties": {"en": {"type": "string"}}},
                "market_cap_rank": {"type": ["integer", "null"]},
                "market_data": {
                  "type": "object",
                  "properties": {
                    "current_price": {"type": "object", "properties": {"usd": {"type": "number"}}},
                    "market_cap": {"type": "object", "properties": {"usd": {"type": "number"}}},
                    "total_volume": {"type": "object", "properties": {"usd": {"type": "number"}}},
                    "price_change_percentage_24h": {"type": ["number", "null"]},
                    "circulating_supply": {"type": ["number", "null"]},
                    "total_supply": {"type": ["number", "null"]},
                    "ath": {"type": "object", "properties": {"usd": {"type": "number"}}},
                    "atl": {"type": "object", "properties": {"usd": {"type": "number"}}}
                  }
                },
                "links": {
                  "type": "object",
                  "properties": {
                    "homepage": {"type": "array", "items": {"type": "string"}},
                    "blockchain_site": {"type": "array", "items": {"type": "string"}},
                    "repos_url": {"type": "object"}
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
