[
  {
    "name": "CollegeScorecard_search_schools",
    "description": "Search for US higher education institutions using the US Department of Education's College Scorecard API. Returns comprehensive data on 6000+ colleges and universities including admission rates, graduation rates, student costs, average earnings after graduation, and student demographics. Uses DEMO_KEY for basic access (limited rate). Essential for educational research, college selection analysis, and higher education policy studies.",
    "parameter": {
      "type": "object",
      "properties": {
        "school_name": {
          "type": ["string", "null"],
          "description": "Search by school name (partial match). Examples: 'Harvard', 'MIT', 'Stanford', 'California'"
        },
        "school_state": {
          "type": ["string", "null"],
          "description": "Filter by US state (2-letter abbreviation). Examples: 'CA', 'NY', 'TX', 'MA'"
        },
        "school_type": {
          "type": ["integer", "null"],
          "description": "School ownership type: 1=Public, 2=Private nonprofit, 3=Private for-profit"
        },
        "fields": {
          "type": ["string", "null"],
          "description": "Comma-separated fields to return. Default returns key metrics. Options include: school.name, school.state, latest.admissions.admission_rate.overall, latest.cost.tuition.in_state, latest.cost.tuition.out_of_state, latest.student.size, latest.completion.completion_rate_4yr_150nt, latest.earnings.10_yrs_after_entry.median"
        },
        "per_page": {
          "type": ["integer", "null"],
          "description": "Results per page (default 20, max 100)"
        },
        "page": {
          "type": ["integer", "null"],
          "description": "Page number for pagination"
        }
      },
      "required": []
    },
    "fields": {
      "endpoint": "https://api.data.gov/ed/collegescorecard/v1/schools",
      "params": {
        "api_key": "DEMO_KEY",
        "fields": "school.name,school.state,school.city,school.school_url,latest.admissions.admission_rate.overall,latest.student.size,latest.cost.tuition.in_state,latest.cost.tuition.out_of_state,latest.completion.completion_rate_4yr_150nt,latest.earnings.10_yrs_after_entry.median",
        "per_page": "10"
      }
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"school_name": "Harvard", "per_page": 5},
      {"school_name": "MIT", "per_page": 5},
      {"school_state": "CA", "school_type": 1, "per_page": 5}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "College Scorecard search results",
              "properties": {
                "metadata": {
                  "type": "object",
                  "properties": {
                    "total": {"type": "integer", "description": "Total matching schools"},
                    "page": {"type": "integer"},
                    "per_page": {"type": "integer"}
                  }
                },
                "results": {
                  "type": "array",
                  "description": "List of institutions",
                  "items": {
                    "type": "object",
                    "description": "School data (field names depend on 'fields' parameter)",
                    "properties": {
                      "school.name": {"type": ["string", "null"], "description": "Institution name"},
                      "school.state": {"type": ["string", "null"], "description": "State code"},
                      "school.city": {"type": ["string", "null"], "description": "City"},
                      "school.school_url": {"type": ["string", "null"], "description": "School website"},
                      "latest.admissions.admission_rate.overall": {"type": ["number", "null"], "description": "Admission rate (0-1)"},
                      "latest.student.size": {"type": ["integer", "null"], "description": "Total students enrolled"},
                      "latest.cost.tuition.in_state": {"type": ["integer", "null"], "description": "In-state tuition (USD)"},
                      "latest.cost.tuition.out_of_state": {"type": ["integer", "null"], "description": "Out-of-state tuition (USD)"},
                      "latest.completion.completion_rate_4yr_150nt": {"type": ["number", "null"], "description": "4-year graduation rate"},
                      "latest.earnings.10_yrs_after_entry.median": {"type": ["integer", "null"], "description": "Median earnings 10 years after enrollment"}
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
