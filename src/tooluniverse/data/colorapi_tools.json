[
  {
    "name": "ColorAPI_identify_color",
    "description": "Identify a color by its hex code or RGB values using The Color API. Returns the color name, complementary color, HSL/HSV/CMYK values, and links to color scheme. No authentication required. Useful for design tools, accessibility testing, color accessibility research, and UI/UX color management.",
    "parameter": {
      "type": "object",
      "properties": {
        "hex": {
          "type": ["string", "null"],
          "description": "Hex color code without '#'. Examples: 'ff5733', '4287f5', '000000' (black), 'ffffff' (white), '00ff00' (green)"
        },
        "rgb": {
          "type": ["string", "null"],
          "description": "RGB color values as comma-separated string. Examples: '255,87,51', '66,135,245', '0,0,0'"
        },
        "hsl": {
          "type": ["string", "null"],
          "description": "HSL color values as comma-separated string. Examples: '14,100%,60%'"
        }
      },
      "required": []
    },
    "fields": {
      "endpoint": "https://www.thecolorapi.com/id",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"hex": "ff5733"},
      {"hex": "4287f5"},
      {"rgb": "128,0,128"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Color identification result",
              "properties": {
                "hex": {"type": "object", "properties": {"value": {"type": "string"}, "clean": {"type": "string"}}},
                "rgb": {"type": "object", "properties": {"value": {"type": "string"}, "r": {"type": "integer"}, "g": {"type": "integer"}, "b": {"type": "integer"}}},
                "hsl": {"type": "object", "properties": {"value": {"type": "string"}, "h": {"type": "number"}, "s": {"type": "number"}, "l": {"type": "number"}}},
                "hsv": {"type": "object", "properties": {"value": {"type": "string"}}},
                "cmyk": {"type": "object", "properties": {"value": {"type": "string"}}},
                "name": {"type": "object", "properties": {"value": {"type": "string", "description": "Human-readable color name"}, "exact_match_name": {"type": "boolean"}}},
                "contrast": {"type": "object", "properties": {"value": {"type": "string", "description": "Contrast color (black or white)"}}},
                "links": {"type": "object", "properties": {"self": {"type": "object", "properties": {"href": {"type": "string"}}}}}
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "ColorAPI_generate_scheme",
    "description": "Generate a color scheme (palette) from a base color using The Color API. Returns harmonically related colors based on the scheme type. No authentication required. Useful for design systems, UI/UX prototyping, palette generation, and color theory education.",
    "parameter": {
      "type": "object",
      "properties": {
        "hex": {
          "type": "string",
          "description": "Base hex color code without '#'. Examples: 'ff5733', '4287f5', '2e86ab'"
        },
        "mode": {
          "type": ["string", "null"],
          "description": "Color scheme type. Values: 'monochrome', 'monochrome-dark', 'monochrome-light', 'analogic', 'complement', 'analogic-complement', 'triad', 'quad'. Default: 'monochrome'"
        },
        "count": {
          "type": ["integer", "null"],
          "description": "Number of colors in the scheme (default 5, max 10)"
        }
      },
      "required": ["hex"]
    },
    "fields": {
      "endpoint": "https://www.thecolorapi.com/scheme",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"hex": "ff5733", "mode": "analogic", "count": 5},
      {"hex": "4287f5", "mode": "complement", "count": 4},
      {"hex": "2e86ab", "mode": "triad", "count": 3}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Color scheme result",
              "properties": {
                "mode": {"type": "string"},
                "count": {"type": "string"},
                "colors": {
                  "type": "array",
                  "description": "List of colors in the scheme",
                  "items": {
                    "type": "object",
                    "properties": {
                      "hex": {"type": "object", "properties": {"value": {"type": "string"}}},
                      "rgb": {"type": "object", "properties": {"value": {"type": "string"}}},
                      "name": {"type": "object", "properties": {"value": {"type": "string", "description": "Color name"}}}
                    }
                  }
                },
                "seed": {
                  "type": "object",
                  "properties": {
                    "hex": {"type": "object", "properties": {"value": {"type": "string"}}},
                    "name": {"type": "object", "properties": {"value": {"type": "string"}}}
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
