[
  {
    "name": "ComplexPortal_search_complexes",
    "description": "Search for curated protein complexes by gene/protein name from the EBI Complex Portal (includes CORUM mammalian complexes). Returns complex names, subunit compositions, and cross-references. Use to find which protein complexes a target participates in.",
    "parameter": {
      "type": "object",
      "properties": {
        "query": {
          "type": "string",
          "description": "Gene symbol, protein name, or complex name to search (e.g., 'WDR7', 'RAVE complex', 'proteasome')"
        },
        "species": {
          "type": "string",
          "description": "NCBI taxonomy ID to filter by species (default: '9606' for human). Use '10090' for mouse, '10116' for rat, '' for all species.",
          "default": "9606"
        },
        "number": {
          "type": "integer",
          "description": "Maximum complexes to return (default: 25)",
          "default": 25,
          "minimum": 1,
          "maximum": 100
        }
      },
      "required": [
        "query"
      ]
    },
    "fields": {
      "operation": "search_complexes"
    },
    "type": "ComplexPortalTool",
    "test_examples": [
      {
        "query": "TP53",
        "species": "9606",
        "number": 10
      },
      {
        "query": "proteasome",
        "species": "9606"
      }
    ],
    "return_schema": {
      "type": "object",
      "properties": {
        "query": {
          "type": "string"
        },
        "complexes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "complex_id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "species": {
                "type": "string"
              },
              "subunits": {
                "type": "array"
              }
            }
          }
        },
        "count": {
          "type": "integer"
        },
        "total_found": {
          "type": "integer"
        }
      }
    },
    "label": [
      "Complex Portal",
      "CORUM",
      "PPI",
      "Protein Complex"
    ],
    "metadata": {
      "tags": [
        "protein_complex",
        "subunit",
        "corum",
        "ppi",
        "complex_composition"
      ],
      "estimated_execution_time": "< 5 seconds"
    }
  },
  {
    "name": "ComplexPortal_get_complex",
    "description": "Get detailed information for a specific protein complex by Complex Portal ID (e.g., CPX-1234). Returns full subunit composition with stoichiometry, function description, disease associations, GO annotations, and cross-references to PDB/Reactome.",
    "parameter": {
      "type": "object",
      "properties": {
        "complex_id": {
          "type": "string",
          "description": "Complex Portal accession ID (e.g., 'CPX-1', 'CPX-6512')"
        }
      },
      "required": [
        "complex_id"
      ]
    },
    "fields": {
      "operation": "get_complex"
    },
    "type": "ComplexPortalTool",
    "test_examples": [
      {
        "complex_id": "CPX-1"
      },
      {
        "complex_id": "CPX-100"
      }
    ],
    "label": [
      "Complex Portal",
      "CORUM",
      "Protein Complex"
    ],
    "metadata": {
      "tags": [
        "protein_complex",
        "stoichiometry",
        "complex_detail"
      ],
      "estimated_execution_time": "< 3 seconds"
    },
    "return_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "description": "Success or error status of the request"
        },
        "data": {
          "type": "object",
          "description": "Complex portal entry data",
          "properties": {
            "complex_id": {
              "type": "string",
              "description": "Complex Portal identifier"
            },
            "name": {
              "type": "string",
              "description": "Common name of the complex"
            },
            "systematic_name": {
              "type": "string",
              "description": "Systematic name listing subunit composition"
            },
            "species": {
              "type": "string",
              "description": "Species of origin"
            },
            "taxonomy_id": {
              "type": "string",
              "description": "NCBI taxonomy ID"
            },
            "description": {
              "type": "string",
              "description": "Functional description of the complex"
            },
            "properties": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Biophysical or functional properties"
            },
            "complex_type": {
              "type": "string",
              "description": "Type classification of the complex"
            },
            "evidence_type": {
              "type": "object",
              "description": "Evidence supporting complex existence",
              "properties": {
                "identifier": {
                  "type": "string",
                  "description": "ECO ontology identifier"
                },
                "description": {
                  "type": "string",
                  "description": "Evidence type description"
                },
                "searchURL": {
                  "type": "string",
                  "description": "OLS URL for the evidence term"
                },
                "confidenceScore": {
                  "type": "number",
                  "description": "Confidence score for the evidence"
                }
              }
            },
            "subunits": {
              "type": "array",
              "description": "Protein subunits of the complex",
              "items": {
                "type": "object",
                "properties": {
                  "identifier": {
                    "type": "string",
                    "description": "UniProt accession of the subunit"
                  },
                  "name": {
                    "type": "string",
                    "description": "Gene/protein name"
                  },
                  "description": {
                    "type": "string",
                    "description": "Full protein name"
                  },
                  "stoichiometry": {
                    "type": "string",
                    "description": "Min/max stoichiometry"
                  },
                  "interactor_type": {
                    "type": "string",
                    "description": "Type of interactor (e.g. protein)"
                  }
                }
              }
            },
            "cross_references": {
              "type": "array",
              "description": "External database cross-references",
              "items": {
                "type": "object",
                "properties": {
                  "database": {
                    "type": "string",
                    "description": "Source database name"
                  },
                  "identifier": {
                    "type": "string",
                    "description": "External identifier"
                  },
                  "description": {
                    "type": "string",
                    "description": "Description of the reference"
                  }
                }
              }
            },
            "diseases": {
              "type": "array",
              "description": "Associated diseases",
              "items": {
                "type": "object"
              }
            },
            "go_annotations": {
              "type": "array",
              "description": "Gene Ontology annotations",
              "items": {
                "type": "object"
              }
            }
          }
        },
        "source": {
          "type": "string",
          "description": "Data source identifier"
        }
      }
    }
  }
]