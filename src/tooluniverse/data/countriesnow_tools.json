  {
    "name": "CountriesNow_get_country_info",
    "description": "Get detailed country information including population, area, currency, phone dial code, timezone, and flag from CountriesNow. Returns comprehensive metadata for a specific country by name or ISO code. Useful for geographic research, demographic analysis, and enriching location-based datasets.",
    "parameter": {
      "type": "object",
      "properties": {
        "country": {
          "type": "string",
          "description": "Country name. Examples: 'Germany', 'Japan', 'Brazil', 'United States', 'India', 'Australia'"
        }
      },
      "required": ["country"]
    },
    "fields": {
      "endpoint": "https://countriesnow.space/api/v0.1/countries/info",
      "params": {
        "returns": "unicodeFlag,flag,dialCode,capital,altSpellings,latlng,region,subregion,population,timezones,currencies,languages,emoji"
      }
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"country": "Germany"},
      {"country": "Japan"},
      {"country": "Brazil"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Country information",
              "properties": {
                "error": {"type": "boolean"},
                "msg": {"type": "string"},
                "data": {
                  "type": "object",
                  "description": "Country details",
                  "properties": {
                    "name": {"type": "string"},
                    "capital": {"type": "string"},
                    "region": {"type": "string"},
                    "subregion": {"type": "string"},
                    "population": {"type": "integer"},
                    "latlng": {"type": "array", "items": {"type": "number"}},
                    "dialCode": {"type": "string"},
                    "timezones": {"type": "array", "items": {"type": "string"}},
                    "currencies": {"type": "array"},
                    "languages": {"type": "object"},
                    "flag": {"type": "string", "description": "Flag image URL"},
                    "emoji": {"type": "string", "description": "Country flag emoji"}
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
