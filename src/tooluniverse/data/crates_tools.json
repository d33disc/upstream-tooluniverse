[
  {
    "name": "Crates_search_packages",
    "description": "Search for Rust crates (packages) on crates.io, the Rust package registry. Returns matching crates with name, description, download count, latest version, homepage, repository URL, and license. Useful for discovering Rust libraries for specific functionality like serialization, async runtimes, web frameworks, or CLI tools. The registry hosts 150K+ crates.",
    "parameter": {
      "type": "object",
      "properties": {
        "q": {
          "type": "string",
          "description": "Search query string (e.g., 'serde', 'async runtime', 'web framework', 'cli parser')"
        },
        "per_page": {
          "type": ["integer", "null"],
          "description": "Number of results per page (default 10, max 100)"
        },
        "page": {
          "type": ["integer", "null"],
          "description": "Page number for pagination (default 1)"
        },
        "sort": {
          "type": ["string", "null"],
          "description": "Sort order: 'relevance' (default), 'downloads', 'recent-downloads', 'recent-updates', 'new', 'alphabetical'"
        }
      },
      "required": ["q"]
    },
    "fields": {
      "endpoint": "https://crates.io/api/v1/crates",
      "headers": {
        "User-Agent": "ToolUniverseBot/1.0 (scientific research tool)"
      }
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"q": "serde"},
      {"q": "tokio", "per_page": 5},
      {"q": "web framework", "sort": "downloads", "per_page": 3}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Search results from crates.io",
              "properties": {
                "crates": {
                  "type": "array",
                  "description": "List of matching Rust crates",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {"type": "string", "description": "Crate name (unique identifier)"},
                      "name": {"type": "string", "description": "Crate name"},
                      "description": {"type": ["string", "null"], "description": "Brief description of the crate"},
                      "downloads": {"type": "integer", "description": "Total all-time download count"},
                      "recent_downloads": {"type": ["integer", "null"], "description": "Downloads in the last 90 days"},
                      "max_version": {"type": "string", "description": "Latest published version"},
                      "homepage": {"type": ["string", "null"], "description": "Project homepage URL"},
                      "repository": {"type": ["string", "null"], "description": "Source code repository URL"},
                      "documentation": {"type": ["string", "null"], "description": "Documentation URL (usually docs.rs)"},
                      "created_at": {"type": "string", "description": "ISO 8601 creation timestamp"},
                      "updated_at": {"type": "string", "description": "ISO 8601 last update timestamp"},
                      "exact_match": {"type": "boolean", "description": "Whether this is an exact name match"}
                    }
                  }
                },
                "meta": {
                  "type": "object",
                  "properties": {
                    "total": {"type": "integer", "description": "Total number of matching crates"}
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "Crates_get_package",
    "description": "Get detailed information about a specific Rust crate from crates.io. Returns the crate's full metadata including description, all version numbers, download statistics, homepage, repository, documentation URL, license, keywords, categories, and dependency information. Use the exact crate name as it appears on crates.io.",
    "parameter": {
      "type": "object",
      "properties": {
        "crate_name": {
          "type": "string",
          "description": "Exact crate name (e.g., 'serde', 'tokio', 'reqwest', 'clap')"
        }
      },
      "required": ["crate_name"]
    },
    "fields": {
      "endpoint": "https://crates.io/api/v1/crates/{crate_name}",
      "headers": {
        "User-Agent": "ToolUniverseBot/1.0 (scientific research tool)"
      }
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"crate_name": "serde"},
      {"crate_name": "tokio"},
      {"crate_name": "reqwest"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Full crate details from crates.io",
              "properties": {
                "crate": {
                  "type": "object",
                  "properties": {
                    "id": {"type": "string"},
                    "name": {"type": "string"},
                    "description": {"type": ["string", "null"]},
                    "downloads": {"type": "integer", "description": "Total download count"},
                    "recent_downloads": {"type": ["integer", "null"]},
                    "max_version": {"type": "string", "description": "Latest version string"},
                    "max_stable_version": {"type": ["string", "null"]},
                    "homepage": {"type": ["string", "null"]},
                    "repository": {"type": ["string", "null"]},
                    "documentation": {"type": ["string", "null"]},
                    "created_at": {"type": "string"},
                    "updated_at": {"type": "string"},
                    "keywords": {"type": ["array", "null"], "items": {"type": "string"}},
                    "categories": {"type": ["array", "null"], "items": {"type": "string"}}
                  }
                },
                "versions": {
                  "type": "array",
                  "description": "Version history with IDs"
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
