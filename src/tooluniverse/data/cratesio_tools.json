[
  {
    "name": "CratesIO_search_crates",
    "description": "Search for Rust crates (packages) on crates.io, the official Rust package registry. Returns crate names, descriptions, download counts, latest versions, and repository links. No authentication required. Useful for discovering Rust libraries, comparing package popularity, finding dependencies for Rust projects, and tracking the Rust ecosystem.",
    "parameter": {
      "type": "object",
      "properties": {
        "q": {
          "type": "string",
          "description": "Search query for crate name or description. Examples: 'serde', 'web framework', 'async runtime', 'database driver', 'logging'"
        },
        "per_page": {
          "type": ["integer", "null"],
          "description": "Results per page (1-100). Default: 10"
        },
        "page": {
          "type": ["integer", "null"],
          "description": "Page number. Default: 1"
        },
        "sort": {
          "type": ["string", "null"],
          "description": "Sort order. Values: 'relevance' (default), 'downloads', 'recent-downloads', 'recent-updates', 'new', 'alphabetical'"
        }
      },
      "required": ["q"]
    },
    "fields": {
      "endpoint": "https://crates.io/api/v1/crates"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"q": "serde", "per_page": 5},
      {"q": "web framework", "sort": "downloads", "per_page": 5},
      {"q": "async runtime", "per_page": 3}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Crate search results",
              "properties": {
                "crates": {
                  "type": "array",
                  "description": "List of matching crates",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {"type": "string", "description": "Crate name (unique identifier)"},
                      "name": {"type": "string", "description": "Crate name"},
                      "description": {"type": ["string", "null"], "description": "Crate description"},
                      "max_version": {"type": "string", "description": "Latest non-yanked version"},
                      "max_stable_version": {"type": ["string", "null"], "description": "Latest stable version"},
                      "downloads": {"type": "integer", "description": "Total all-time downloads"},
                      "recent_downloads": {"type": ["integer", "null"], "description": "Downloads in last 90 days"},
                      "homepage": {"type": ["string", "null"], "description": "Homepage URL"},
                      "repository": {"type": ["string", "null"], "description": "Source code repository URL"},
                      "documentation": {"type": ["string", "null"], "description": "Documentation URL"},
                      "created_at": {"type": "string", "description": "First published date"},
                      "updated_at": {"type": "string", "description": "Last updated date"},
                      "exact_match": {"type": "boolean", "description": "Whether this is an exact name match"}
                    }
                  }
                },
                "meta": {
                  "type": "object",
                  "properties": {
                    "total": {"type": "integer", "description": "Total matching crates"}
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "CratesIO_get_crate",
    "description": "Get detailed information about a specific Rust crate from crates.io including version history, download counts, dependencies, and links. No authentication required. Useful for evaluating a Rust library before adding it as a dependency, checking version history, and understanding crate maintenance status.",
    "parameter": {
      "type": "object",
      "properties": {
        "crate_name": {
          "type": "string",
          "description": "Exact crate name. Examples: 'tokio', 'serde', 'reqwest', 'actix-web', 'clap', 'rayon', 'tracing'"
        }
      },
      "required": ["crate_name"]
    },
    "fields": {
      "endpoint": "https://crates.io/api/v1/crates/{crate_name}"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"crate_name": "tokio"},
      {"crate_name": "serde"},
      {"crate_name": "reqwest"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Crate detail response",
              "properties": {
                "crate": {
                  "type": "object",
                  "description": "Crate metadata",
                  "properties": {
                    "id": {"type": "string"},
                    "name": {"type": "string"},
                    "description": {"type": ["string", "null"]},
                    "max_version": {"type": "string"},
                    "max_stable_version": {"type": ["string", "null"]},
                    "downloads": {"type": "integer", "description": "Total all-time downloads"},
                    "recent_downloads": {"type": ["integer", "null"]},
                    "homepage": {"type": ["string", "null"]},
                    "repository": {"type": ["string", "null"]},
                    "documentation": {"type": ["string", "null"]},
                    "created_at": {"type": "string"},
                    "updated_at": {"type": "string"}
                  }
                },
                "versions": {
                  "type": "array",
                  "description": "Version history (most recent first)",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {"type": "integer"},
                      "num": {"type": "string", "description": "Version number (semver)"},
                      "downloads": {"type": "integer", "description": "Downloads for this version"},
                      "created_at": {"type": "string"},
                      "yanked": {"type": "boolean", "description": "Whether this version was yanked"},
                      "license": {"type": ["string", "null"], "description": "SPDX license expression"},
                      "crate_size": {"type": ["integer", "null"], "description": "Size in bytes"},
                      "rust_version": {"type": ["string", "null"], "description": "Minimum Rust version"}
                    }
                  }
                },
                "keywords": {
                  "type": "array",
                  "description": "Crate keywords",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {"type": "string"},
                      "keyword": {"type": "string"},
                      "crates_cnt": {"type": "integer"}
                    }
                  }
                },
                "categories": {
                  "type": "array",
                  "description": "Crate categories",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {"type": "string"},
                      "category": {"type": "string"},
                      "crates_cnt": {"type": "integer"}
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
