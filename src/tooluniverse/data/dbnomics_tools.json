[
  {
    "name": "DBnomics_search_datasets",
    "description": "Search DBnomics for economic and statistical datasets from 90+ providers including IMF, World Bank, ECB, Eurostat, OECD, and national statistical agencies. DBnomics aggregates over 70 billion time series covering GDP, inflation, employment, trade, demographics, and more. Returns matching datasets with provider info, series counts, and descriptions. Use this to discover available datasets before fetching specific series with DBnomics_get_series.",
    "parameter": {
      "type": "object",
      "properties": {
        "q": {
          "type": "string",
          "description": "Search query for datasets. Examples: 'GDP growth', 'inflation USA', 'unemployment rate', 'trade balance', 'population', 'interest rate'"
        },
        "limit": {
          "type": ["integer", "null"],
          "description": "Maximum number of results to return (default: 10, max: 1000)"
        },
        "offset": {
          "type": ["integer", "null"],
          "description": "Number of results to skip for pagination (default: 0)"
        }
      },
      "required": ["q"]
    },
    "fields": {
      "endpoint": "https://api.db.nomics.world/v22/search"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"q": "GDP growth", "limit": 5},
      {"q": "inflation USA", "limit": 3},
      {"q": "unemployment rate Europe"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "DBnomics search results",
              "properties": {
                "_meta": {
                  "type": "object",
                  "description": "Request metadata including query parameters and API version"
                },
                "results": {
                  "type": "object",
                  "properties": {
                    "num_found": {"type": "integer", "description": "Total number of matching datasets"},
                    "limit": {"type": "integer"},
                    "offset": {"type": "integer"},
                    "docs": {
                      "type": "array",
                      "description": "Matching datasets",
                      "items": {
                        "type": "object",
                        "properties": {
                          "code": {"type": "string", "description": "Dataset code (use with provider_code in DBnomics_get_dataset)"},
                          "name": {"type": "string", "description": "Dataset name"},
                          "description": {"type": "string", "description": "Dataset description (may contain HTML)"},
                          "provider_code": {"type": "string", "description": "Provider code (e.g., 'IMF', 'Eurostat', 'OECD')"},
                          "provider_name": {"type": "string", "description": "Full provider name"},
                          "nb_series": {"type": "integer", "description": "Total number of time series in this dataset"},
                          "nb_matching_series": {"type": "integer", "description": "Number of series matching the search query"},
                          "indexed_at": {"type": "string", "description": "When the dataset was last indexed"},
                          "updated_at": {"type": "string", "description": "When the dataset was last updated"}
                        }
                      }
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "DBnomics_get_dataset",
    "description": "Get detailed information about a specific DBnomics dataset including its dimensions, available values, and metadata. A dataset belongs to a provider (e.g., IMF, Eurostat) and contains multiple time series. Use DBnomics_search_datasets first to find provider_code and dataset_code, then use this tool to explore the dataset structure before fetching individual series with DBnomics_get_series.",
    "parameter": {
      "type": "object",
      "properties": {
        "provider_code": {
          "type": "string",
          "description": "Provider code (e.g., 'IMF', 'Eurostat', 'OECD', 'WorldBank', 'ECB')"
        },
        "dataset_code": {
          "type": "string",
          "description": "Dataset code (e.g., 'WEO:2024-10' for IMF World Economic Outlook, 'GOV_10A_EXP' for Eurostat government expenditure)"
        }
      },
      "required": ["provider_code", "dataset_code"]
    },
    "fields": {
      "endpoint": "https://api.db.nomics.world/v22/datasets/{provider_code}/{dataset_code}"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"provider_code": "IMF", "dataset_code": "WEO:2024-10"},
      {"provider_code": "Eurostat", "dataset_code": "GOV_10A_EXP"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Dataset details",
              "properties": {
                "_meta": {"type": "object"},
                "datasets": {
                  "type": "object",
                  "properties": {
                    "docs": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "code": {"type": "string", "description": "Dataset code"},
                          "name": {"type": "string", "description": "Dataset name"},
                          "nb_series": {"type": "integer", "description": "Total number of time series"},
                          "provider_code": {"type": "string"},
                          "provider_name": {"type": "string"},
                          "dimensions_codes_order": {"type": "array", "items": {"type": "string"}, "description": "Dimension codes that define series (e.g., country, indicator, unit)"},
                          "dimensions_labels": {"type": "object", "description": "Human-readable labels for each dimension"},
                          "dimensions_values_labels": {"type": "object", "description": "Mapping of dimension codes to their possible values and labels"},
                          "doc_href": {"type": "string", "description": "URL to dataset documentation"},
                          "source_href": {"type": "string", "description": "URL to original data source"}
                        }
                      }
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "DBnomics_get_series",
    "description": "Get time series data (observations) from DBnomics. Returns actual data values with time periods for a specific economic indicator. Series are identified by provider/dataset/series_code (e.g., IMF/WEO:2024-10/USA.NGDP_RPCH.pcent_change for US GDP growth). Includes period dates, values, frequency, and dimension metadata. Set observations=1 to include the actual data points.",
    "parameter": {
      "type": "object",
      "properties": {
        "provider_code": {
          "type": "string",
          "description": "Provider code (e.g., 'IMF', 'Eurostat', 'OECD', 'WorldBank', 'ECB', 'BLS')"
        },
        "dataset_code": {
          "type": "string",
          "description": "Dataset code within the provider (e.g., 'WEO:2024-10', 'CPIH01')"
        },
        "series_code": {
          "type": "string",
          "description": "Series code within the dataset (e.g., 'USA.NGDP_RPCH.pcent_change' for US GDP growth rate). Use DBnomics_get_dataset to explore available dimension values."
        },
        "observations": {
          "type": ["integer", "null"],
          "description": "Set to 1 to include data observations (period and value arrays). Default: 0 (metadata only)"
        }
      },
      "required": ["provider_code", "dataset_code", "series_code"]
    },
    "fields": {
      "endpoint": "https://api.db.nomics.world/v22/series/{provider_code}/{dataset_code}/{series_code}"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"provider_code": "IMF", "dataset_code": "WEO:2024-10", "series_code": "USA.NGDP_RPCH.pcent_change", "observations": 1},
      {"provider_code": "IMF", "dataset_code": "WEO:2024-10", "series_code": "CHN.NGDP_RPCH.pcent_change", "observations": 1}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Series data with time series observations",
              "properties": {
                "_meta": {"type": "object"},
                "series": {
                  "type": "object",
                  "properties": {
                    "docs": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "series_code": {"type": "string", "description": "Full series code"},
                          "series_name": {"type": "string", "description": "Human-readable series name"},
                          "dataset_code": {"type": "string"},
                          "provider_code": {"type": "string"},
                          "@frequency": {"type": "string", "description": "Data frequency: 'annual', 'quarterly', 'monthly', 'daily'"},
                          "dimensions": {"type": "object", "description": "Dimension values for this series (country, indicator, unit)"},
                          "period": {"type": "array", "items": {"type": "string"}, "description": "Time period labels (e.g., ['1980', '1981', ...] or ['2020-Q1', '2020-Q2', ...])"},
                          "value": {"type": "array", "description": "Data values corresponding to each period (may contain null for missing data)"},
                          "period_start_day": {"type": "array", "items": {"type": "string"}, "description": "ISO date for start of each period"}
                        }
                      }
                    }
                  }
                },
                "dataset": {"type": "object", "description": "Parent dataset metadata"},
                "provider": {"type": "object", "description": "Data provider information"}
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
