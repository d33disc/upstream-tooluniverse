[
  {
    "name": "DEVto_search_articles",
    "description": "Search and browse developer articles from DEV.to (dev.to), a community of software developers sharing programming tutorials, career advice, tool reviews, and tech industry discussions. No authentication required for public content. Returns article titles, authors, tags, cover images, reading times, and reaction counts. Useful for finding programming guides, best practices, career insights, and developer community perspectives.",
    "parameter": {
      "type": "object",
      "properties": {
        "tag": {
          "type": ["string", "null"],
          "description": "Filter by tag. Examples: 'python', 'javascript', 'rust', 'webdev', 'beginners', 'career', 'ai', 'tutorial', 'opensource', 'devops'"
        },
        "top": {
          "type": ["integer", "null"],
          "description": "Return top articles from last N days. Examples: 7 (week), 30 (month), 365 (year). Cannot be combined with state=fresh."
        },
        "per_page": {
          "type": ["integer", "null"],
          "description": "Number of articles to return (1-30). Default: 10"
        },
        "page": {
          "type": ["integer", "null"],
          "description": "Page number for pagination. Default: 1"
        }
      },
      "required": []
    },
    "fields": {
      "endpoint": "https://dev.to/api/articles",
      "params": {"per_page": 10}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"tag": "python", "top": 30, "per_page": 5},
      {"tag": "javascript", "per_page": 5},
      {"tag": "ai", "top": 7, "per_page": 5}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "array",
              "description": "List of DEV.to articles",
              "items": {
                "type": "object",
                "properties": {
                  "id": {"type": "integer", "description": "Article ID"},
                  "title": {"type": "string", "description": "Article title"},
                  "description": {"type": ["string", "null"], "description": "Short description/excerpt"},
                  "url": {"type": "string", "description": "Full URL to article"},
                  "published_at": {"type": "string", "description": "Publication timestamp (ISO 8601)"},
                  "tag_list": {"type": "array", "description": "List of tags", "items": {"type": "string"}},
                  "reading_time_minutes": {"type": "integer", "description": "Estimated reading time in minutes"},
                  "public_reactions_count": {"type": "integer", "description": "Number of reactions (likes, unicorns, etc.)"},
                  "comments_count": {"type": "integer", "description": "Number of comments"},
                  "user": {
                    "type": "object",
                    "properties": {
                      "name": {"type": "string", "description": "Author display name"},
                      "username": {"type": "string", "description": "DEV.to username"}
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
