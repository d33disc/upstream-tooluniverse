[
  {
    "name": "Dictionary_lookup_word",
    "description": "Look up the definition, pronunciation, and usage of an English word using the Free Dictionary API. Returns phonetic transcription, audio pronunciation URLs, definitions organized by part of speech (noun, verb, adjective, etc.), usage examples, synonyms, and antonyms. Useful for natural language processing, vocabulary building, word games, and language learning applications.",
    "parameter": {
      "type": "object",
      "properties": {
        "word": {
          "type": "string",
          "description": "English word to look up. Examples: 'serendipity', 'algorithm', 'photosynthesis', 'ubiquitous'"
        }
      },
      "required": ["word"]
    },
    "fields": {
      "endpoint": "https://api.dictionaryapi.dev/api/v2/entries/en/{word}"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"word": "serendipity"},
      {"word": "algorithm"},
      {"word": "photosynthesis"},
      {"word": "ubiquitous"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "array",
              "description": "Dictionary entries for the word (usually one entry, but may include multiple for words with distinct origins)",
              "items": {
                "type": "object",
                "properties": {
                  "word": {"type": "string", "description": "The looked-up word"},
                  "phonetic": {"type": "string", "description": "IPA phonetic transcription (e.g., '/ˌsɛ.ɹən.ˈdɪ.pɪ.ti/')"},
                  "phonetics": {
                    "type": "array",
                    "description": "Phonetic variants with optional audio",
                    "items": {
                      "type": "object",
                      "properties": {
                        "text": {"type": "string", "description": "IPA transcription"},
                        "audio": {"type": "string", "description": "URL to MP3 pronunciation audio"}
                      }
                    }
                  },
                  "origin": {"type": "string", "description": "Etymology/origin of the word"},
                  "meanings": {
                    "type": "array",
                    "description": "Definitions grouped by part of speech",
                    "items": {
                      "type": "object",
                      "properties": {
                        "partOfSpeech": {"type": "string", "description": "Part of speech: 'noun', 'verb', 'adjective', 'adverb', etc."},
                        "definitions": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "definition": {"type": "string", "description": "Definition text"},
                              "example": {"type": "string", "description": "Usage example sentence"},
                              "synonyms": {"type": "array", "items": {"type": "string"}},
                              "antonyms": {"type": "array", "items": {"type": "string"}}
                            }
                          }
                        },
                        "synonyms": {"type": "array", "items": {"type": "string"}, "description": "Synonyms for this part of speech"},
                        "antonyms": {"type": "array", "items": {"type": "string"}, "description": "Antonyms for this part of speech"}
                      }
                    }
                  },
                  "sourceUrls": {"type": "array", "items": {"type": "string"}, "description": "Source URLs (typically Wiktionary)"}
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
