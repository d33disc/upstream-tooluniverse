  {
    "name": "DigiKey_get_categories",
    "description": "Get electronic component product categories from Digi-Key. Returns category hierarchy including category ID, name, and product counts. Optionally get details for a specific category ID. Useful for browsing Digi-Key's product taxonomy (e.g., 'Integrated Circuits (ICs)', 'Capacitors', 'Connectors'). Requires free Digi-Key developer account. Set DIGIKEY_CLIENT_ID and DIGIKEY_CLIENT_SECRET env vars.",
    "parameter": {
      "type": "object",
      "properties": {
        "category_id": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Optional category ID to get details for a specific category. Omit to get top-level categories."
        }
      }
    },
    "fields": {
      "operation": "categories"
    },
    "type": "DigiKeyTool",
    "test_examples": [
      {},
      {
        "category_id": 32
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "category_id": {
                    "type": [
                      "integer",
                      "string"
                    ]
                  },
                  "name": {
                    "type": "string"
                  },
                  "product_count": {
                    "type": [
                      "integer",
                      "null"
                    ]
                  },
                  "parent_id": {
                    "type": [
                      "integer",
                      "string",
                      "null"
                    ]
                  },
                  "children_count": {
                    "type": "integer"
                  }
                }
              }
            },
            "metadata": {
              "type": "object",
              "properties": {
                "source": {
                  "type": "string"
                },
                "endpoint": {
                  "type": "string"
                },
                "total_results": {
                  "type": "integer"
                }
              }
            }
          },
          "required": [
            "data"
          ]
        },
        {
          "type": "object",
          "properties": {
            "error": {
              "type": "string"
            }
