[
  {
    "name": "DigiKey_search_by_keyword",
    "description": "Search Digi-Key Electronics for electronic components by keyword. Returns matching products with Digi-Key part numbers, manufacturer info, pricing tiers, stock levels, and detailed specifications. Supports broad searches ('FPGA') or specific queries ('100nF 0402 capacitor'). Requires free Digi-Key developer account (register at https://developer.digikey.com/). Set DIGIKEY_CLIENT_ID and DIGIKEY_CLIENT_SECRET environment variables. Rate limits: 120 req/min, 1000 req/day.",
    "parameter": {
      "type": "object",
      "properties": {
        "keywords": {
          "type": "string",
          "description": "Search keywords - part description, MPN, or component type. Examples: 'STM32F103C8T6', 'op amp low noise', 'ESP32 module', '10uF 25V capacitor'."
        },
        "limit": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Maximum number of results to return (1-50). Default is 10."
        },
        "offset": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Starting record offset for pagination. Default is 0."
        }
      },
      "required": [
        "keywords"
      ]
    },
    "fields": {
      "operation": "keyword_search"
    },
    "type": "DigiKeyTool",
    "test_examples": [
      {
        "keywords": "STM32F103C8T6",
        "limit": 5
      },
      {
        "keywords": "LM7805 voltage regulator",
        "limit": 3
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "digikey_part_number": {
                    "type": "string",
                    "description": "Digi-Key's part number"
                  },
                  "manufacturer_part_number": {
                    "type": "string",
                    "description": "Manufacturer's part number (MPN)"
                  },
                  "manufacturer": {
                    "type": "string",
                    "description": "Component manufacturer name"
                  },
                  "description": {
                    "type": "string",
                    "description": "Product description"
                  },
                  "detailed_description": {
                    "type": "string",
                    "description": "Detailed product description"
                  },
                  "quantity_available": {
                    "type": "integer",
                    "description": "Quantity in stock"
                  },
                  "unit_price": {
                    "type": [
                      "number",
                      "null"
                    ],
                    "description": "Unit price in USD"
                  },
                  "product_url": {
                    "type": "string",
                    "description": "URL to Digi-Key product page"
                  },
                  "datasheet_url": {
                    "type": "string",
                    "description": "URL to component datasheet"
                  },
                  "category": {
                    "type": "string",
                    "description": "Product category"
                  },
                  "family": {
                    "type": "string",
                    "description": "Product family"
                  },
                  "product_status": {
                    "type": "string",
                    "description": "Active/Obsolete/NRND status"
                  },
                  "min_order_quantity": {
                    "type": [
                      "integer",
                      "null"
                    ],
                    "description": "Minimum order quantity"
                  },
                  "pricing": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "break_quantity": {
                          "type": "integer"
                        },
                        "unit_price": {
                          "type": [
                            "number",
                            "null"
                          ]
                        },
                        "total_price": {
                          "type": [
                            "number",
                            "null"
                          ]
                        }
                      }
                    }
                  },
                  "parameters": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "name": {
                          "type": "string"
                        },
                        "value": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              }
            },
            "metadata": {
              "type": "object",
              "properties": {
                "source": {
                  "type": "string"
                },
                "endpoint": {
                  "type": "string"
                },
                "query": {
                  "type": "string"
                },
                "total_results": {
                  "type": [
                    "integer",
                    "null"
                  ]
                },
                "results_returned": {
                  "type": "integer"
                }
              }
            }
          },
          "required": [
            "data"
          ]
        },
        {
          "type": "object",
          "properties": {
            "error": {
              "type": "string"
            }
          },
          "required": [
            "error"
          ]
        }
      ]
    }
  },
  {
    "name": "DigiKey_get_product_details",
    "description": "Get detailed product information from Digi-Key by part number (Digi-Key PN or manufacturer PN). Returns comprehensive data including full specifications/parameters, pricing tiers, stock quantity, datasheet URL, category, packaging options, and lifecycle status. Use this for detailed lookup of a specific component. Requires free Digi-Key developer account. Set DIGIKEY_CLIENT_ID and DIGIKEY_CLIENT_SECRET environment variables.",
    "parameter": {
      "type": "object",
      "properties": {
        "product_number": {
          "type": "string",
          "description": "Digi-Key part number or manufacturer part number. Examples: 'STM32F103C8T6', '497-STM32F103C8T6-ND', 'LM358DR', 'CC0402KRX7R9BB104'."
        }
      },
      "required": [
        "product_number"
      ]
    },
    "fields": {
      "operation": "product_details"
    },
    "type": "DigiKeyTool",
    "test_examples": [
