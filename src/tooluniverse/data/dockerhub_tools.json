[
  {
    "name": "DockerHub_search_repositories",
    "description": "Search Docker Hub for container image repositories. Returns matching repositories with name, description, star count, pull count, and whether the image is official or automated. Docker Hub hosts millions of container images for application deployment, microservices, CI/CD, and development environments. Useful for finding pre-built images for databases, web servers, programming languages, and scientific tools.",
    "parameter": {
      "type": "object",
      "properties": {
        "query": {
          "type": "string",
          "description": "Search query (e.g., 'python', 'nginx', 'postgres', 'bioinformatics', 'jupyter')"
        },
        "page_size": {
          "type": ["integer", "null"],
          "description": "Number of results per page (default 25, max 100)"
        },
        "page": {
          "type": ["integer", "null"],
          "description": "Page number for pagination (default 1)"
        }
      },
      "required": ["query"]
    },
    "fields": {
      "endpoint": "https://hub.docker.com/v2/search/repositories/"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"query": "python", "page_size": 5},
      {"query": "nginx", "page_size": 3},
      {"query": "bioinformatics", "page_size": 5}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Docker Hub search results",
              "properties": {
                "count": {"type": "integer", "description": "Total number of matching repositories"},
                "next": {"type": ["string", "null"], "description": "URL for next page of results"},
                "previous": {"type": ["string", "null"], "description": "URL for previous page"},
                "results": {
                  "type": "array",
                  "description": "List of matching Docker repositories",
                  "items": {
                    "type": "object",
                    "properties": {
                      "repo_name": {"type": "string", "description": "Repository name (e.g., 'python', 'library/nginx', 'biocontainers/blast')"},
                      "short_description": {"type": ["string", "null"], "description": "Brief repository description"},
                      "star_count": {"type": "integer", "description": "Number of stars (community rating)"},
                      "pull_count": {"type": "integer", "description": "Total number of image pulls (downloads)"},
                      "is_official": {"type": "boolean", "description": "Whether this is an official Docker image"},
                      "is_automated": {"type": "boolean", "description": "Whether builds are automated"}
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "DockerHub_get_tags",
    "description": "Get available tags (versions) for a Docker Hub repository. Returns tag names with architecture details, image sizes, and timestamps. For official images, use 'library/{name}' format (e.g., 'library/python'). For user/org images, use '{namespace}/{name}' format (e.g., 'biocontainers/blast'). Useful for finding specific image versions, checking multi-architecture support, and verifying image sizes.",
    "parameter": {
      "type": "object",
      "properties": {
        "namespace": {
          "type": "string",
          "description": "Repository namespace and name. For official images: 'library/python', 'library/nginx'. For user images: 'biocontainers/blast', 'bitnami/postgresql'"
        },
        "page_size": {
          "type": ["integer", "null"],
          "description": "Number of tags to return (default 10, max 100)"
        },
        "page": {
          "type": ["integer", "null"],
          "description": "Page number for pagination (default 1)"
        }
      },
      "required": ["namespace"]
    },
    "fields": {
      "endpoint": "https://hub.docker.com/v2/repositories/{namespace}/tags"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"namespace": "library/python", "page_size": 5},
      {"namespace": "library/nginx", "page_size": 3},
      {"namespace": "biocontainers/blast", "page_size": 5}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Tag listing for the Docker repository",
              "properties": {
                "count": {"type": "integer", "description": "Total number of available tags"},
                "next": {"type": ["string", "null"], "description": "URL for next page"},
                "previous": {"type": ["string", "null"]},
                "results": {
                  "type": "array",
                  "description": "List of image tags",
                  "items": {
                    "type": "object",
                    "properties": {
                      "name": {"type": "string", "description": "Tag name (e.g., 'latest', '3.12-slim', 'alpine')"},
                      "full_size": {"type": ["integer", "null"], "description": "Compressed image size in bytes"},
                      "last_updated": {"type": ["string", "null"], "description": "ISO 8601 timestamp of last push"},
                      "images": {
                        "type": "array",
                        "description": "Platform-specific image variants",
                        "items": {
                          "type": "object",
                          "properties": {
                            "architecture": {"type": ["string", "null"], "description": "CPU architecture (amd64, arm64, arm/v7)"},
                            "os": {"type": ["string", "null"], "description": "Operating system (linux, windows)"},
                            "size": {"type": ["integer", "null"], "description": "Compressed layer size in bytes"},
                            "digest": {"type": ["string", "null"], "description": "Image digest (sha256)"},
                            "status": {"type": ["string", "null"], "description": "Image status (active, stale)"}
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
