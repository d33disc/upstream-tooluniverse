[
  {
    "name": "EPMC_get_text_mined_annotations",
    "description": "Get all text-mined annotations from a biomedical article via Europe PMC. Returns gene/protein mentions, diseases, chemicals, organisms, and GO terms automatically extracted from the full text. Useful for quickly identifying which genes, drugs, or diseases are discussed in a paper. Example: pmid='33332779' (COVID-19 tocilizumab trial) returns IL-6 receptor, tocilizumab, SARS-CoV-2, etc.",
    "parameter": {
      "type": "object",
      "properties": {
        "pmid": {
          "type": "string",
          "description": "PubMed ID (e.g., '33332779'). Either pmid or pmcid is required."
        },
        "pmcid": {
          "type": "string",
          "description": "PubMed Central ID (e.g., 'PMC7781101'). Alternative to pmid."
        },
        "annotation_type": {
          "type": "string",
          "description": "Filter by annotation type. Options: 'Gene_Proteins', 'Diseases', 'Chemicals', 'Organisms', 'Gene_Ontology', 'EFO'. Leave empty for all types."
        }
      },
      "required": []
    },
    "fields": {
      "operation": "get_annotations"
    },
    "type": "EPMCAnnotationsTool",
    "test_examples": [
      {
        "pmid": "33332779"
      },
      {
        "pmcid": "PMC7781101",
        "annotation_type": "Gene_Proteins"
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "article_id": {"type": "string"},
            "pmcid": {"type": ["string", "null"]},
            "annotations": {"type": ["object", "array"]},
            "annotation_counts": {"type": "object"}
          },
          "required": ["article_id", "annotations"]
        },
        {
          "type": "object",
          "properties": {
            "error": {"type": "string"}
          },
          "required": ["error"]
        }
      ]
    }
  },
  {
