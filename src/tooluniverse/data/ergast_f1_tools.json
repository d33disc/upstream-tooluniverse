[
  {
    "name": "ErgastF1_get_race_results",
    "description": "Get Formula 1 race results for a specific season and round from the Ergast API (via Jolpi mirror). Returns finishing positions, drivers, constructors, times, grid positions, and status for each race. Covers all F1 seasons from 1950 to present.",
    "parameter": {
      "type": "object",
      "properties": {
        "season": {
          "type": "string",
          "description": "F1 season year (e.g., '2024', '2023', '1950'). Use 'current' for the current season."
        },
        "round": {
          "type": "string",
          "description": "Race round number within the season (e.g., '1' for first race, '5' for fifth)"
        },
        "limit": {
          "type": ["integer", "null"],
          "description": "Maximum number of result entries to return (default: 30)"
        }
      },
      "required": ["season", "round"]
    },
    "fields": {
      "endpoint": "https://api.jolpi.ca/ergast/f1/{season}/{round}/results.json"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"season": "2024", "round": "1", "limit": 10},
      {"season": "2023", "round": "5"},
      {"season": "current", "round": "1"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Ergast API response wrapped in MRData",
              "properties": {
                "MRData": {
                  "type": "object",
                  "properties": {
                    "xmlns": {"type": "string"},
                    "series": {"type": "string"},
                    "url": {"type": "string"},
                    "limit": {"type": "string"},
                    "offset": {"type": "string"},
                    "total": {"type": "string"},
                    "RaceTable": {
                      "type": "object",
                      "properties": {
                        "season": {"type": "string"},
                        "round": {"type": "string"},
                        "Races": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "season": {"type": "string"},
                              "round": {"type": "string"},
                              "raceName": {"type": "string"},
                              "date": {"type": "string"},
                              "Circuit": {"type": "object"},
                              "Results": {
                                "type": "array",
                                "items": {
                                  "type": "object",
                                  "properties": {
                                    "number": {"type": "string"},
                                    "position": {"type": "string"},
                                    "positionText": {"type": "string"},
                                    "points": {"type": "string"},
                                    "Driver": {"type": "object"},
                                    "Constructor": {"type": "object"},
                                    "grid": {"type": "string"},
                                    "laps": {"type": "string"},
                                    "status": {"type": "string"},
                                    "Time": {"type": "object"}
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {
            "error": {"type": "string"}
          },
          "required": ["error"]
        }
      ]
    }
  },
  {
