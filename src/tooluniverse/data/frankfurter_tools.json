[
  {
    "name": "Frankfurter_get_exchange_rates",
    "description": "Get current or historical currency exchange rates from the Frankfurter API (based on European Central Bank data). Returns exchange rates for 30+ currencies including EUR, USD, GBP, JPY, CHF, AUD, CAD. No authentication required. Useful for financial analysis, currency conversion, and economic research.",
    "parameter": {
      "type": "object",
      "properties": {
        "base": {
          "type": ["string", "null"],
          "description": "Base currency code (ISO 4217). Examples: 'USD', 'EUR', 'GBP', 'JPY', 'CHF'. Default: EUR"
        },
        "to": {
          "type": ["string", "null"],
          "description": "Target currency codes (comma-separated). Examples: 'USD,GBP', 'EUR,JPY,CHF'. Default: all currencies"
        },
        "date": {
          "type": ["string", "null"],
          "description": "Historical date in YYYY-MM-DD format. Omit for latest rates. Example: '2024-01-15'"
        }
      },
      "required": []
    },
    "fields": {
      "endpoint": "https://api.frankfurter.app/latest",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"base": "USD"},
      {"base": "EUR", "to": "USD,GBP,JPY"},
      {"base": "GBP", "date": "2024-01-15"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Currency exchange rate data",
              "properties": {
                "amount": {"type": "number", "description": "Base amount (always 1.0)"},
                "base": {"type": "string", "description": "Base currency code"},
                "date": {"type": "string", "description": "Date of rates (YYYY-MM-DD)"},
                "rates": {
                  "type": "object",
                  "description": "Exchange rates keyed by currency code (e.g., {'USD': 1.08, 'GBP': 0.85})"
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "Frankfurter_convert_currency",
    "description": "Convert an amount from one currency to another using European Central Bank rates. Returns the converted amount with the exchange rate used. Supports 30+ major world currencies.",
    "parameter": {
      "type": "object",
      "properties": {
        "amount": {
          "type": "number",
          "description": "Amount to convert. Examples: 100, 1500.50, 0.5"
        },
        "from": {
          "type": "string",
          "description": "Source currency code (ISO 4217). Examples: 'USD', 'EUR', 'GBP', 'JPY'"
        },
        "to": {
          "type": "string",
          "description": "Target currency code (ISO 4217). Examples: 'EUR', 'USD', 'CHF'"
        },
        "date": {
          "type": ["string", "null"],
          "description": "Historical date in YYYY-MM-DD format. Omit for latest rates."
        }
      },
      "required": ["amount", "from", "to"]
    },
    "fields": {
      "endpoint": "https://api.frankfurter.app/latest",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"amount": 100, "from": "USD", "to": "EUR"},
      {"amount": 1000, "from": "GBP", "to": "JPY"},
      {"amount": 500, "from": "EUR", "to": "CHF", "date": "2024-06-01"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Currency conversion result",
              "properties": {
                "amount": {"type": "number", "description": "Original amount"},
                "base": {"type": "string", "description": "Source currency"},
                "date": {"type": "string", "description": "Date of rates"},
                "rates": {
                  "type": "object",
                  "description": "Converted amount in target currency"
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
