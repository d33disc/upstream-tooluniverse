[
  {
    "name": "Guardian_search_news",
    "description": "Search The Guardian newspaper for news articles by keyword, section, and date range. The Guardian is one of the world's leading English-language newspapers (2M+ articles since 1999), covering politics, science, technology, environment, culture, sports, and more. Returns article titles, URLs, publication dates, and section metadata. Uses the free public Guardian Open Platform API with the demo 'test' key (limited to 12 calls/second). Useful for retrieving recent news on any topic, tracking media coverage of scientific breakthroughs, policy changes, or current events. Supports filtering by section (e.g., 'science', 'technology', 'environment', 'politics', 'world') and date range.",
    "parameter": {
      "type": "object",
      "properties": {
        "q": {
          "type": "string",
          "description": "Search query keywords. Supports AND/OR/NOT operators and phrase search with quotes. Examples: 'CRISPR', 'climate change', '\"gene therapy\" AND cancer', 'AI NOT chatbot'"
        },
        "section": {
          "type": ["string", "null"],
          "description": "Filter by Guardian section. Common sections: 'science', 'technology', 'environment', 'politics', 'world', 'business', 'sport', 'culture', 'education', 'us-news', 'uk-news', 'commentisfree' (opinion). Leave null for all sections."
        },
        "from-date": {
          "type": ["string", "null"],
          "description": "Start date filter in YYYY-MM-DD format (e.g., '2025-01-01'). Returns articles published on or after this date."
        },
        "to-date": {
          "type": ["string", "null"],
          "description": "End date filter in YYYY-MM-DD format (e.g., '2025-12-31'). Returns articles published on or before this date."
        },
        "page-size": {
          "type": ["integer", "null"],
          "description": "Number of results per page (1-50, default 10). Use smaller values for quick lookups, larger for comprehensive searches."
        },
        "page": {
          "type": ["integer", "null"],
          "description": "Page number for pagination (starts at 1). Use with page-size to retrieve more results."
        },
        "order-by": {
          "type": ["string", "null"],
          "description": "Sort order for results. Options: 'relevance' (default), 'newest', 'oldest'."
        }
      },
      "required": ["q"]
    },
    "fields": {
      "endpoint": "https://content.guardianapis.com/search",
      "params": {
        "api-key": "test"
      },
      "extract_path": "response"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"q": "CRISPR", "page-size": 5},
      {"q": "climate change", "section": "environment", "page-size": 3},
      {"q": "artificial intelligence", "from-date": "2025-01-01", "page-size": 5}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Guardian search response with article results",
              "properties": {
                "status": {
                  "type": "string",
                  "description": "Response status ('ok' on success)"
                },
                "total": {
                  "type": "integer",
                  "description": "Total number of matching articles"
                },
                "startIndex": {
                  "type": "integer",
                  "description": "1-based index of first result on this page"
                },
                "pageSize": {
                  "type": "integer",
                  "description": "Number of results per page"
                },
                "currentPage": {
                  "type": "integer",
                  "description": "Current page number"
                },
                "pages": {
                  "type": "integer",
                  "description": "Total number of pages"
                },
                "orderBy": {
                  "type": "string",
                  "description": "Sort order used ('relevance', 'newest', 'oldest')"
                },
                "results": {
                  "type": "array",
                  "description": "Array of matching Guardian articles",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string",
                        "description": "Article path ID (e.g., 'science/2025/jan/15/crispr-breakthrough')"
                      },
                      "type": {
                        "type": "string",
                        "description": "Content type ('article', 'liveblog', 'gallery', 'interactive', 'video')"
                      },
                      "sectionId": {
                        "type": "string",
                        "description": "Section identifier (e.g., 'science', 'technology')"
                      },
                      "sectionName": {
                        "type": "string",
                        "description": "Human-readable section name (e.g., 'Science', 'Technology')"
                      },
                      "webPublicationDate": {
                        "type": "string",
                        "description": "Publication date in ISO 8601 format"
                      },
                      "webTitle": {
                        "type": "string",
                        "description": "Article headline/title"
                      },
                      "webUrl": {
                        "type": "string",
                        "description": "Full URL to the article on theguardian.com"
                      },
                      "pillarName": {
                        "type": ["string", "null"],
                        "description": "Content pillar (e.g., 'News', 'Opinion', 'Sport', 'Arts')"
                      }
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
