[
  {
    "name": "HackerNews_get_top_stories",
    "description": "Get the IDs of top, new, best, ask, show, or job stories from Hacker News using the official Firebase API. Returns an array of up to 500 story IDs. Use HackerNews_get_item to fetch details for each ID. No authentication required. Useful for tracking trending tech news and community discussion.",
    "parameter": {
      "type": "object",
      "properties": {
        "category": {
          "type": ["string", "null"],
          "description": "Story category. Values: 'topstories' (default), 'newstories', 'beststories', 'askstories', 'showstories', 'jobstories'"
        }
      },
      "required": []
    },
    "fields": {
      "endpoint": "https://hacker-news.firebaseio.com/v0/{category}.json",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {},
      {"category": "topstories"},
      {"category": "askstories"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "array",
              "description": "Array of story IDs (up to 500)",
              "items": {"type": "integer", "description": "Story ID"}
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "HackerNews_get_item",
    "description": "Get details of a Hacker News story, comment, job, poll, or poll option by its item ID using the official Firebase API. Returns title, author, score, URL, text, and child comment IDs. No authentication required. Use HackerNews_get_top_stories to get story IDs first.",
    "parameter": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer",
          "description": "Hacker News item ID. Examples: 47082496, 37570568 (can be story, comment, job, etc.)"
        }
      },
      "required": ["id"]
    },
    "fields": {
      "endpoint": "https://hacker-news.firebaseio.com/v0/item/{id}.json",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"id": 40000000},
      {"id": 37570568},
      {"id": 38000000}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Hacker News item details",
              "properties": {
                "id": {"type": "integer", "description": "Item ID"},
                "type": {"type": "string", "description": "Item type: story, comment, job, poll, pollopt"},
                "by": {"type": "string", "description": "Author username"},
                "title": {"type": ["string", "null"], "description": "Story/poll title"},
                "url": {"type": ["string", "null"], "description": "URL for link posts"},
                "text": {"type": ["string", "null"], "description": "HTML text for Ask HN, jobs, or comments"},
                "score": {"type": ["integer", "null"], "description": "Upvote score"},
                "descendants": {"type": ["integer", "null"], "description": "Total number of comments"},
                "kids": {"type": "array", "items": {"type": "integer"}, "description": "IDs of direct child comments"},
                "time": {"type": "integer", "description": "Unix timestamp of creation"}
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
