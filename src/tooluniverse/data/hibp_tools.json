[
  {
    "name": "HIBP_list_breaches",
    "description": "Get the complete list of all public data breaches tracked by Have I Been Pwned (HIBP). Returns all 900+ known data breaches with breach name, domain, date, number of affected accounts, and types of compromised data (passwords, emails, phone numbers, etc.). Useful for cybersecurity research, understanding data breach history, and security awareness.",
    "parameter": {
      "type": "object",
      "properties": {
        "domain": {
          "type": ["string", "null"],
          "description": "Filter breaches by domain name. Example: 'adobe.com', 'linkedin.com', 'yahoo.com'"
        }
      },
      "required": []
    },
    "fields": {
      "endpoint": "https://haveibeenpwned.com/api/v3/breaches"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {},
      {"domain": "adobe.com"},
      {"domain": "linkedin.com"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "array",
              "description": "List of public data breaches",
              "items": {
                "type": "object",
                "properties": {
                  "Name": {"type": "string", "description": "Breach identifier name"},
                  "Title": {"type": "string", "description": "Human-readable breach title"},
                  "Domain": {"type": "string", "description": "Affected website domain"},
                  "BreachDate": {"type": "string", "description": "Date breach occurred (YYYY-MM-DD)"},
                  "AddedDate": {"type": "string", "description": "Date added to HIBP database"},
                  "PwnCount": {"type": "integer", "description": "Number of compromised accounts"},
                  "Description": {"type": "string", "description": "Breach description"},
                  "DataClasses": {
                    "type": "array",
                    "items": {"type": "string"},
                    "description": "Types of compromised data (Passwords, Email addresses, etc.)"
                  },
                  "IsVerified": {"type": "boolean", "description": "Whether breach is verified real"},
                  "IsFabricated": {"type": "boolean"},
                  "IsSensitive": {"type": "boolean"},
                  "IsRetired": {"type": "boolean"},
                  "IsSpamList": {"type": "boolean"},
                  "IsMalware": {"type": "boolean"}
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "HIBP_get_breach",
    "description": "Get details of a specific data breach by its name from Have I Been Pwned. Returns complete breach information including description, date, number of affected accounts, and types of data compromised. Use HIBP_list_breaches to find breach names.",
    "parameter": {
      "type": "object",
      "properties": {
        "breach_name": {
          "type": "string",
          "description": "Breach name (case-insensitive). Examples: 'Adobe', 'LinkedIn', 'Yahoo', 'MyFitnessPal', 'Dropbox', 'Canva'"
        }
      },
      "required": ["breach_name"]
    },
    "fields": {
      "endpoint": "https://haveibeenpwned.com/api/v3/breach/{breach_name}"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"breach_name": "Adobe"},
      {"breach_name": "LinkedIn"},
      {"breach_name": "Yahoo"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Data breach details",
              "properties": {
                "Name": {"type": "string"},
                "Title": {"type": "string"},
                "Domain": {"type": "string"},
                "BreachDate": {"type": "string"},
                "AddedDate": {"type": "string"},
                "ModifiedDate": {"type": "string"},
                "PwnCount": {"type": "integer", "description": "Number of compromised accounts"},
                "Description": {"type": "string"},
                "DataClasses": {"type": "array", "items": {"type": "string"}, "description": "Types of compromised data"},
                "IsVerified": {"type": "boolean"},
                "IsFabricated": {"type": "boolean"},
                "IsSensitive": {"type": "boolean"},
                "IsRetired": {"type": "boolean"},
                "IsSpamList": {"type": "boolean"},
                "IsMalware": {"type": "boolean"}
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
