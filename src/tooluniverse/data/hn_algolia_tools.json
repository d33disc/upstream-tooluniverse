[
  {
    "name": "HackerNewsSearch_search_stories",
    "description": "Search Hacker News stories, Ask HN posts, Show HN posts, and comments via the Algolia HN Search API. Returns relevant stories with title, URL, author, points, comments, and timestamps. No authentication required. More powerful than the official HN API - supports full-text search with relevance ranking. Useful for finding technology discussions, startup news, programming tutorials, and tech community opinions.",
    "parameter": {
      "type": "object",
      "properties": {
        "query": {
          "type": "string",
          "description": "Search query. Examples: 'machine learning', 'rust programming', 'Show HN', 'Ask HN career advice', 'python web framework'"
        },
        "tags": {
          "type": ["string", "null"],
          "description": "Filter by tag. Values: 'story' (default), 'comment', 'ask_hn', 'show_hn', 'front_page', 'poll'. Multiple tags: 'story,ask_hn'"
        },
        "numericFilters": {
          "type": ["string", "null"],
          "description": "Numeric filter string. Examples: 'points>100' (at least 100 upvotes), 'num_comments>50', 'points>200,num_comments>10'"
        },
        "hitsPerPage": {
          "type": ["integer", "null"],
          "description": "Results per page (1-50). Default: 20"
        }
      },
      "required": ["query"]
    },
    "fields": {
      "endpoint": "https://hn.algolia.com/api/v1/search",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"query": "machine learning", "numericFilters": "points>200", "hitsPerPage": 5},
      {"query": "rust programming language", "tags": "story", "hitsPerPage": 5},
      {"query": "Ask HN: career advice", "tags": "ask_hn", "hitsPerPage": 5}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "HN Algolia search results",
              "properties": {
                "hits": {
                  "type": "array",
                  "description": "List of matching stories/posts",
                  "items": {
                    "type": "object",
                    "properties": {
                      "objectID": {"type": "string", "description": "HN item ID"},
                      "title": {"type": ["string", "null"], "description": "Story title"},
                      "url": {"type": ["string", "null"], "description": "Story URL"},
                      "author": {"type": ["string", "null"], "description": "HN username of submitter"},
                      "points": {"type": ["integer", "null"], "description": "Upvotes/karma"},
                      "num_comments": {"type": ["integer", "null"], "description": "Comment count"},
                      "created_at": {"type": "string", "description": "Submission timestamp (ISO 8601)"},
                      "_tags": {"type": "array", "description": "Content tags (story, ask_hn, etc.)"}
                    }
                  }
                },
                "nbHits": {"type": "integer", "description": "Total matching results"},
                "page": {"type": "integer"},
                "nbPages": {"type": "integer"}
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
