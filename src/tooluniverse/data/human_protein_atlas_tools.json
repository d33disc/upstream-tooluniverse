[
  {
    "name": "HumanProteinAtlas_get_protein",
    "description": "Get comprehensive protein data for a gene from the Human Protein Atlas (HPA) by Ensembl gene ID. Returns protein expression across tissues (via RNA-seq nTPM values), subcellular localization (main and additional compartments), protein class membership, disease associations, molecular function, biological process, cancer prognostics from TCGA for 20+ cancer types, blood concentration, single-cell type expression, and brain region expression. Essential for understanding where a protein is expressed and its disease relevance. Example: ENSG00000141510 (TP53) shows Nucleoplasm/Cytosol localization, enriched in many cancer types, prognostic in 20 cancers.",
    "parameter": {
      "type": "object",
      "properties": {
        "ensembl_id": {
          "type": "string",
          "description": "Ensembl gene ID (e.g., 'ENSG00000141510' for TP53, 'ENSG00000012048' for BRCA1, 'ENSG00000139618' for BRCA2). Use the base ID without version suffix."
        }
      },
      "required": ["ensembl_id"]
    },
    "fields": {
      "endpoint": "https://www.proteinatlas.org/{ensembl_id}.json"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"ensembl_id": "ENSG00000141510"},
      {"ensembl_id": "ENSG00000012048"},
      {"ensembl_id": "ENSG00000139618"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Comprehensive Human Protein Atlas gene/protein data",
              "properties": {
                "Gene": {"type": "string", "description": "Gene symbol (e.g., 'TP53')"},
                "Gene synonym": {"type": ["array", "null"], "description": "Alternative gene names"},
                "Ensembl": {"type": "string", "description": "Ensembl gene ID"},
                "Gene description": {"type": "string", "description": "Full gene name/description"},
                "Uniprot": {"type": "array", "items": {"type": "string"}, "description": "UniProt accession(s)"},
                "Chromosome": {"type": "string"},
                "Position": {"type": "string", "description": "Chromosomal position"},
                "Protein class": {"type": ["array", "null"], "description": "Protein functional classes (e.g., Cancer-related genes, Transcription factors)"},
                "Biological process": {"type": ["array", "null"], "description": "GO biological process terms"},
                "Molecular function": {"type": ["array", "null"], "description": "GO molecular function terms"},
                "Disease involvement": {"type": ["array", "null"], "description": "Diseases associated with this protein"},
                "Evidence": {"type": "string", "description": "Evidence level for protein existence"},
                "Subcellular location": {"type": ["array", "null"], "description": "Subcellular compartments where protein is found"},
                "Subcellular main location": {"type": ["array", "null"], "description": "Primary subcellular location(s)"},
                "RNA tissue specificity": {"type": ["string", "null"], "description": "Tissue-specific or broadly expressed"},
                "RNA tissue distribution": {"type": ["string", "null"], "description": "Distribution pattern across tissues"},
                "RNA tissue specific nTPM": {"type": ["string", "null"], "description": "nTPM in tissue-enriched tissues"},
                "RNA single cell type specificity": {"type": ["string", "null"], "description": "Cell-type specific expression"},
                "RNA cancer specificity": {"type": ["string", "null"], "description": "Cancer-specific expression"},
                "Blood concentration - Conc. blood IM [pg/L]": {"type": ["string", "null"], "description": "Blood immunoassay concentration"},
                "Blood concentration - Conc. blood MS [pg/L]": {"type": ["string", "null"], "description": "Blood mass spectrometry concentration"},
                "Interactions": {"type": ["array", "null"], "description": "Protein interaction partners"}
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "HumanProteinAtlas_search_genes",
    "description": "Search the Human Protein Atlas for genes/proteins by name or keyword. Returns a list of matching genes with their UniProt IDs and protein evidence levels. Use this to find the Ensembl ID of a gene before calling HumanProteinAtlas_get_protein for detailed data. Returns all genes where the search term appears in the gene name or description.",
    "parameter": {
      "type": "object",
      "properties": {
        "search": {
          "type": "string",
          "description": "Gene name or search term (e.g., 'TP53', 'BRCA', 'kinase', 'tumor suppressor')"
        }
      },
      "required": ["search"]
    },
    "fields": {
      "endpoint": "https://www.proteinatlas.org/api/search_download.php",
      "params": {
        "columns": "g,pe,up",
        "compress": "no",
        "format": "json"
      }
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"search": "TP53"},
      {"search": "BRCA1"},
      {"search": "CDK4"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "array",
              "description": "List of matching genes/proteins",
              "items": {
                "type": "object",
                "properties": {
                  "Gene": {"type": "string", "description": "Gene symbol"},
                  "Uniprot": {"type": "array", "items": {"type": "string"}, "description": "UniProt accession(s)"},
                  "Evidence": {"type": "string", "description": "Protein evidence level"}
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
