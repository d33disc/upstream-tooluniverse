[
  {
    "name": "IEA_get_ev_data",
    "description": "Get electric vehicle (EV) statistics from the International Energy Agency (IEA) Global EV Data Explorer API. Returns historical and projected data on EV sales, stock, charging infrastructure, and market share by region, mode, and powertrain type. No authentication required. Useful for energy transition research, transportation policy analysis, and EV market studies.",
    "parameter": {
      "type": "object",
      "properties": {
        "category": {
          "type": [
            "string",
            "null"
          ],
          "description": "Data category. Values: 'Historical' (default), 'Projection (STEPS)', 'Projection (APS)'. STEPS=Stated Policies, APS=Announced Pledges."
        },
        "parameter": {
          "type": [
            "string",
            "null"
          ],
          "description": "Data parameter. Values: 'EV sales', 'EV sales share', 'EV stock', 'EV stock share', 'Oil displacement, million lge', 'Electricity demand'. Default: 'EV sales'"
        },
        "mode": {
          "type": [
            "string",
            "null"
          ],
          "description": "Vehicle mode. Values: 'Cars', 'Vans', 'Trucks', 'Buses', 'Two/three-wheelers'. Default: 'Cars'"
        },
        "zone": {
          "type": [
            "string",
            "null"
          ],
          "description": "Geographic zone/region. Examples: 'World', 'China', 'Europe', 'USA', 'India', 'Africa'. Default: 'World'"
        },
        "year": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Year of data. Examples: 2020, 2021, 2022, 2023. Leave null for all years."
        },
        "unit": {
          "type": [
            "string",
            "null"
          ],
          "description": "Unit. Examples: 'Vehicles', 'percent', 'Thousand'. Default: depends on parameter"
        }
      },
      "required": []
    },
    "fields": {
      "endpoint": "https://api.iea.org/evs",
      "params": {
        "category": "Historical",
        "mode": "Cars"
      }
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {
        "parameter": "EV sales",
        "zone": "World",
        "year": 2023
      },
      {
        "parameter": "EV stock share",
        "zone": "China",
        "mode": "Cars"
      },
      {
        "parameter": "EV sales",
        "zone": "Europe",
        "mode": "Cars",
        "year": 2022
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "array",
          "description": "EV data records",
          "items": {
            "type": "object",
            "properties": {
              "region": {
                "type": "string",
                "description": "Geographic region"
              },
              "category": {
                "type": "string",
                "description": "Historical or Projection"
              },
              "parameter": {
                "type": "string",
                "description": "Data parameter type"
              },
              "mode": {
                "type": "string",
                "description": "Vehicle mode"
              },
              "powertrain": {
                "type": "string",
                "description": "BEV (battery), PHEV (plug-in hybrid), FCEV (fuel cell)"
              },
              "year": {
                "type": "integer"
              },
              "unit": {
                "type": "string"
              },
              "value": {
                "type": "number",
                "description": "Data value"
              }
            }
          }
        },
        {
          "type": "object",
          "properties": {
            "error": {
              "type": "string"
            }
          },
          "required": [
            "error"
          ]
        }
      ]
    }
  }
]
