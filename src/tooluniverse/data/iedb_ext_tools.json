                },
                "select": {
                    "description": "Columns to return.",
                    "oneOf": [
                        {"type": "string"},
                        {"type": "array", "items": {"type": "string"}}
                    ]
                },
                "filters": {
                    "type": "object",
                    "description": "PostgREST filters. Key columns: receptor_group_id, receptor_type, receptor_name, chain_type, v_gene, j_gene.",
                    "additionalProperties": {"type": "string"}
                }
            },
            "required": []
        },
        "return_schema": {
            "type": "array",
            "description": "List of BCR/antibody sequence records.",
            "items": {
                "type": "object",
                "properties": {
                    "receptor_group_id": {"type": ["integer", "null"]},
                    "receptor_type": {"type": ["string", "null"]},
                    "receptor_name": {"type": ["string", "null"]}
                },
