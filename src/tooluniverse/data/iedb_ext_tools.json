        }
    },
    {
        "name": "iedb_get_epitope_tcell_assays",
        "type": "IEDBTool",
        "description": "Get T-cell assay data linked to a specific epitope structure ID. Given an epitope_id (from iedb_search_epitopes), returns all T-cell assays that tested this epitope.\n\nUseful for understanding the T-cell immunogenicity of a known epitope.",
        "parameter": {
            "type": "object",
            "properties": {
                "epitope_id": {
                    "type": "integer",
                    "description": "IEDB epitope structure ID (from iedb_search_epitopes results). Example: 20354 for GILGFVFTL."
                },
                "limit": {
                    "type": "integer",
                    "description": "Maximum rows to return.",
                    "default": 20
                },
                "offset": {
                    "type": "integer",
                    "description": "Pagination offset.",
                    "default": 0
                },
                "select": {
                    "description": "Columns to return.",
                    "oneOf": [
                        {"type": "string"},
                        {"type": "array", "items": {"type": "string"}}
                    ]
                },
                "filters": {
                    "type": "object",
                    "description": "Additional PostgREST filters.",
                    "additionalProperties": {"type": "string"}
                }
            },
            "required": ["epitope_id"]
        },
        "return_schema": {
            "type": "array",
            "description": "List of T-cell assay records for the given epitope.",
            "items": {
                "type": "object",
                "properties": {
                    "tcell_id": {"type": ["integer", "null"]},
                    "structure_id": {"type": ["integer", "null"]},
                    "linear_sequence": {"type": ["string", "null"]},
                    "mhc_restriction": {"type": ["string", "null"]},
                    "qualitative_measure": {"type": ["string", "null"]}
                },
                "additionalProperties": true
            }
        },
        "test_examples": [
            {
                "epitope_id": 20354,
                "limit": 5,
                "select": ["tcell_id", "linear_sequence", "mhc_restriction", "qualitative_measure", "pubmed_id"]
            }
        ],
        "fields": {
            "endpoint": "/tcell_search",
            "default_params": {"order": "tcell_id.asc"},
            "shorthand_filters": {
                "epitope_id": {"column": "structure_id", "op": "eq"}
            }
        }
    }
]
