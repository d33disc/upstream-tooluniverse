[
  {
    "name": "InternetArchive_search",
    "description": "Search the Internet Archive's collection of 40M+ items including books, movies, audio, software, web pages, and more. Returns matching items with identifier, title, creator, date, description, media type, and subject tags. Supports free-text queries and field-specific searches (e.g., 'subject:biology', 'creator:Einstein', 'mediatype:texts'). Each result's identifier can be used to fetch full metadata.",
    "parameter": {
      "type": "object",
      "properties": {
        "q": {
          "type": "string",
          "description": "Search query. Free text or field-specific: 'subject:physics', 'creator:Shakespeare', 'mediatype:texts AND title:python', 'collection:opensource'"
        },
        "rows": {
          "type": ["integer", "null"],
          "description": "Number of results to return (default 10, max 10000)"
        },
        "page": {
          "type": ["integer", "null"],
          "description": "Page number for pagination (default 1)"
        },
        "fl": {
          "type": ["string", "null"],
          "description": "Comma-separated list of fields to return (default: 'identifier,title,creator,date,description,subject,mediatype')"
        },
        "sort": {
          "type": ["string", "null"],
          "description": "Sort field and direction (e.g., 'downloads desc', 'date asc', 'title asc', 'avg_rating desc')"
        }
      },
      "required": ["q"]
    },
    "fields": {
      "endpoint": "https://archive.org/advancedsearch.php",
      "params": {
        "output": "json"
      }
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"q": "title:python programming", "rows": 5},
      {"q": "subject:machine learning AND mediatype:texts", "rows": 3},
      {"q": "creator:Shakespeare", "rows": 5, "sort": "downloads desc"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Search response from Internet Archive",
              "properties": {
                "responseHeader": {
                  "type": "object",
                  "properties": {
                    "status": {"type": "integer"},
                    "QTime": {"type": "integer"}
                  }
                },
                "response": {
                  "type": "object",
                  "properties": {
                    "numFound": {"type": "integer", "description": "Total number of matching items"},
                    "start": {"type": "integer"},
                    "docs": {
                      "type": "array",
                      "description": "List of matching archive items",
                      "items": {
                        "type": "object",
                        "properties": {
                          "identifier": {"type": "string", "description": "Unique item identifier (use with InternetArchive_get_metadata)"},
                          "title": {"type": ["string", "null"], "description": "Item title"},
                          "creator": {"type": ["string", "null"], "description": "Author or creator name"},
                          "date": {"type": ["string", "null"], "description": "Publication or creation date"},
                          "description": {"type": ["string", "null"], "description": "Item description text"},
                          "subject": {"type": ["string", "null"], "description": "Subject tags (may be semicolon-separated)"},
                          "mediatype": {"type": ["string", "null"], "description": "Media type: texts, movies, audio, software, web, image, collection, data"}
                        }
                      }
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "InternetArchive_get_metadata",
    "description": "Get full metadata for a specific Internet Archive item by its identifier. Returns comprehensive metadata including title, creator, date, description, subject, collection membership, file list with sizes and formats, and server information. The identifier is obtained from search results or from the URL (e.g., 'archive.org/details/{identifier}'). Files include various formats (PDF, EPUB, MP3, etc.) available for download.",
    "parameter": {
      "type": "object",
      "properties": {
        "identifier": {
          "type": "string",
          "description": "Internet Archive item identifier (e.g., 'ibda3gate.comlearnpythonprogramminglanguage', 'principia_mathematica')"
        }
      },
      "required": ["identifier"]
    },
    "fields": {
      "endpoint": "https://archive.org/metadata/{identifier}"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"identifier": "lifesciencemanbi0000fitc"},
      {"identifier": "einstein-e_mc2-inertia-body-energy"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Full metadata for the archive item",
              "properties": {
                "metadata": {
                  "type": "object",
                  "description": "Core item metadata",
                  "properties": {
                    "identifier": {"type": "string"},
                    "title": {"type": ["string", "null"]},
                    "creator": {"type": ["string", "null"]},
                    "date": {"type": ["string", "null"]},
                    "description": {"type": ["string", "null"]},
                    "subject": {"type": ["string", "null"]},
                    "mediatype": {"type": ["string", "null"]},
                    "collection": {"type": ["string", "null"]}
                  }
                },
                "files": {
                  "type": "array",
                  "description": "List of files in the item",
                  "items": {
                    "type": "object",
                    "properties": {
                      "name": {"type": "string", "description": "File name"},
                      "format": {"type": ["string", "null"], "description": "File format (e.g., 'PDF', 'EPUB', 'MP3')"},
                      "size": {"type": ["string", "null"], "description": "File size in bytes"},
                      "source": {"type": ["string", "null"], "description": "File source: 'original' or 'derivative'"}
                    }
                  }
                },
                "files_count": {"type": "integer", "description": "Total number of files"},
                "d1": {"type": ["string", "null"], "description": "Primary download server"},
                "d2": {"type": ["string", "null"], "description": "Secondary download server"},
                "dir": {"type": ["string", "null"], "description": "Item directory path on server"}
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "InternetArchive_wayback_search",
    "description": "Search the Wayback Machine CDX (Capture inDeX) for archived snapshots of a URL over time. Returns a list of captures with timestamps, HTTP status codes, MIME types, and content digests. Useful for checking web archival history, finding specific snapshots, tracking URL changes, and verifying when content was available. Each capture can be accessed at 'https://web.archive.org/web/{timestamp}/{url}'.",
    "parameter": {
      "type": "object",
      "properties": {
        "url": {
          "type": "string",
          "description": "URL to look up in the Wayback Machine (e.g., 'example.com', 'https://www.python.org/downloads/')"
        },
        "limit": {
          "type": ["integer", "null"],
          "description": "Maximum number of capture records to return (default 10)"
        },
        "from": {
          "type": ["string", "null"],
          "description": "Start date filter (YYYYMMDD format, e.g., '20200101')"
        },
        "to": {
          "type": ["string", "null"],
          "description": "End date filter (YYYYMMDD format, e.g., '20231231')"
        },
        "matchType": {
          "type": ["string", "null"],
          "description": "URL matching: 'exact' (default), 'prefix', 'host', 'domain'"
        },
        "filter": {
          "type": ["string", "null"],
          "description": "Field filter (e.g., 'statuscode:200' for successful captures only, 'mimetype:text/html')"
        }
      },
      "required": ["url"]
    },
    "fields": {
      "endpoint": "https://web.archive.org/cdx/search/cdx",
      "params": {
        "output": "json"
      }
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"url": "example.com", "limit": 5},
      {"url": "python.org", "limit": 5, "filter": "statuscode:200"},
      {"url": "en.wikipedia.org/wiki/Main_Page", "limit": 3, "from": "20240101", "to": "20240131"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "array",
              "description": "List of Wayback Machine capture records. First element is the header row [urlkey, timestamp, original, mimetype, statuscode, digest, length], followed by data rows. Access snapshots at https://web.archive.org/web/{timestamp}/{original}",
              "items": {
                "type": "array",
                "description": "Row of capture data: [urlkey, timestamp (YYYYMMDDHHmmss), original_url, mimetype, statuscode, digest, length]",
                "items": {"type": "string"}
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
