[
  {
    "name": "IPAPI_geolocate_ip",
    "description": "Geolocate an IP address to get country, city, ISP, and timezone information using the ip-api.com service. No authentication required. Returns geographic location and network information for any valid IPv4 or IPv6 address. Useful for network analysis, fraud detection, and geographic targeting research.",
    "parameter": {
      "type": "object",
      "properties": {
        "ip": {
          "type": "string",
          "description": "IPv4 or IPv6 address to geolocate. Examples: '8.8.8.8' (Google DNS), '1.1.1.1' (Cloudflare), '208.67.222.222' (OpenDNS)"
        }
      },
      "required": ["ip"]
    },
    "fields": {
      "endpoint": "http://ip-api.com/json/{ip}",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"ip": "8.8.8.8"},
      {"ip": "1.1.1.1"},
      {"ip": "208.67.222.222"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "IP geolocation data",
              "properties": {
                "status": {"type": "string", "description": "success or fail"},
                "country": {"type": "string", "description": "Full country name"},
                "countryCode": {"type": "string", "description": "Two-letter ISO country code"},
                "region": {"type": "string", "description": "Region/state code"},
                "regionName": {"type": "string", "description": "Region/state name"},
                "city": {"type": "string", "description": "City name"},
                "zip": {"type": "string", "description": "ZIP/postal code"},
                "lat": {"type": "number", "description": "Latitude"},
                "lon": {"type": "number", "description": "Longitude"},
                "timezone": {"type": "string", "description": "Timezone (e.g., America/New_York)"},
                "isp": {"type": "string", "description": "Internet Service Provider"},
                "org": {"type": "string", "description": "Organization"},
                "as": {"type": "string", "description": "Autonomous System number and name"},
                "query": {"type": "string", "description": "Queried IP address"}
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
