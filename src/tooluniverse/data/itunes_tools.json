[
  {
    "name": "iTunes_search_media",
    "description": "Search Apple's iTunes Store catalog for music, movies, podcasts, audiobooks, apps, and more. Returns track/album/artist details including title, artist, collection, preview URLs, prices, release dates, and artwork. Supports filtering by media type and entity type. No authentication required. Useful for finding music tracks, movie metadata, podcast episodes, and app information.",
    "parameter": {
      "type": "object",
      "properties": {
        "term": {
          "type": "string",
          "description": "Search query (e.g., 'radiohead', 'inception', 'serial podcast', 'machine learning')"
        },
        "media": {
          "type": ["string", "null"],
          "description": "Media type filter. Options: 'music', 'movie', 'podcast', 'audiobook', 'shortFilm', 'tvShow', 'software', 'ebook', 'all'. Default: 'all'"
        },
        "entity": {
          "type": ["string", "null"],
          "description": "Entity type within media. Music: 'musicTrack', 'album', 'musicArtist'. Movie: 'movie'. Podcast: 'podcast', 'podcastEpisode'. Software: 'software'. Default varies by media."
        },
        "country": {
          "type": ["string", "null"],
          "description": "Two-letter ISO country code for store region (e.g., 'US', 'GB', 'JP'). Default: 'US'"
        },
        "limit": {
          "type": ["integer", "null"],
          "description": "Number of results to return (1-200). Default: 10"
        }
      },
      "required": ["term"]
    },
    "fields": {
      "endpoint": "https://itunes.apple.com/search"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"term": "radiohead", "media": "music", "limit": 3},
      {"term": "inception", "media": "movie", "limit": 3},
      {"term": "serial", "media": "podcast", "limit": 3}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "iTunes search results",
              "properties": {
                "resultCount": {"type": "integer", "description": "Number of results returned"},
                "results": {
                  "type": "array",
                  "description": "List of matching items",
                  "items": {
                    "type": "object",
                    "properties": {
                      "wrapperType": {"type": "string", "description": "Type: 'track', 'collection', 'artist'"},
                      "kind": {"type": ["string", "null"], "description": "Content kind: 'song', 'feature-movie', 'podcast', etc."},
                      "artistId": {"type": ["integer", "null"]},
                      "artistName": {"type": "string"},
                      "trackName": {"type": ["string", "null"], "description": "Track/item name"},
                      "collectionName": {"type": ["string", "null"], "description": "Album/collection name"},
                      "trackViewUrl": {"type": ["string", "null"], "description": "iTunes Store URL"},
                      "previewUrl": {"type": ["string", "null"], "description": "Audio/video preview URL"},
                      "artworkUrl100": {"type": ["string", "null"], "description": "100x100 artwork URL"},
                      "trackPrice": {"type": ["number", "null"]},
                      "currency": {"type": ["string", "null"]},
                      "releaseDate": {"type": ["string", "null"], "description": "ISO 8601 release date"},
                      "primaryGenreName": {"type": ["string", "null"]},
                      "trackTimeMillis": {"type": ["integer", "null"], "description": "Duration in milliseconds"}
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "iTunes_lookup",
    "description": "Look up a specific item in the iTunes Store by its Apple ID (artist, album, track, app, etc.). Returns detailed metadata including name, genre, price, artwork, and preview URLs. Can also look up items by UPC, ISBN, or AMG ID. No authentication required.",
    "parameter": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Apple iTunes ID to look up. Examples: '657515' (Radiohead artist), '1440833098' (album), '909253' (Jack Johnson artist). Multiple IDs can be comma-separated."
        },
        "entity": {
          "type": ["string", "null"],
          "description": "Related entity type to return. For artist lookup: 'album', 'song'. For album: 'song'. This returns related items along with the main result."
        },
        "limit": {
          "type": ["integer", "null"],
          "description": "Number of related items to return (1-200). Default: 50"
        }
      },
      "required": ["id"]
    },
    "fields": {
      "endpoint": "https://itunes.apple.com/lookup"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"id": "657515"},
      {"id": "909253", "entity": "album", "limit": 5},
      {"id": "657515,909253"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "iTunes lookup results",
              "properties": {
                "resultCount": {"type": "integer"},
                "results": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "wrapperType": {"type": "string"},
                      "artistType": {"type": ["string", "null"]},
                      "artistName": {"type": "string"},
                      "artistId": {"type": "integer"},
                      "primaryGenreName": {"type": ["string", "null"]},
                      "artistLinkUrl": {"type": ["string", "null"]}
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
