        },
        "order_by": {
          "type": ["string", "null"],
          "description": "Order by: 'title', 'score', 'chapters', 'volumes', 'start_date', 'members', 'rank', 'popularity', 'favorites'"
        },
        "sort": {
          "type": ["string", "null"],
