                      "type": {"type": ["string", "null"]},
                      "chapters": {"type": ["integer", "null"]},
                      "volumes": {"type": ["integer", "null"]},
                      "status": {"type": "string"},
                      "score": {"type": ["number", "null"]},
                      "rank": {"type": ["integer", "null"]},
                      "synopsis": {"type": ["string", "null"]},
                      "genres": {"type": "array"},
                      "authors": {"type": "array"},
                      "url": {"type": "string"}
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
