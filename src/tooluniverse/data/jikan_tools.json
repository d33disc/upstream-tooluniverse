[
  {
    "name": "Jikan_search_anime",
    "description": "Search for anime on MyAnimeList via the Jikan API. Returns anime titles matching a query with score, episodes, synopsis, genres, and more. Jikan provides free, open access to MyAnimeList data.",
    "parameter": {
      "type": "object",
      "properties": {
        "q": {
          "type": "string",
          "description": "Search query for anime title (e.g., 'naruto', 'attack on titan', 'spirited away')"
        },
        "type": {
          "type": ["string", "null"],
          "description": "Filter by anime type: 'tv', 'movie', 'ova', 'special', 'ona', 'music', 'cm', 'pv', 'tv_special'"
        },
        "status": {
          "type": ["string", "null"],
          "description": "Filter by airing status: 'airing', 'complete', 'upcoming'"
        },
        "rating": {
          "type": ["string", "null"],
          "description": "Filter by age rating: 'g', 'pg', 'pg13', 'r17', 'r', 'rx'"
        },
        "order_by": {
          "type": ["string", "null"],
          "description": "Order results by: 'title', 'score', 'episodes', 'start_date', 'end_date', 'members', 'rank', 'popularity', 'favorites'"
        },
        "sort": {
          "type": ["string", "null"],
          "description": "Sort direction: 'desc' or 'asc'"
        },
        "limit": {
          "type": ["integer", "null"],
          "description": "Number of results (1-25, default: 10)"
        },
        "page": {
          "type": ["integer", "null"],
          "description": "Page number for pagination"
        }
      },
      "required": ["q"]
    },
    "fields": {
      "endpoint": "https://api.jikan.moe/v4/anime"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"q": "naruto", "limit": 5},
      {"q": "spirited away", "type": "movie", "limit": 3},
      {"q": "death note", "status": "complete", "limit": 5}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Anime search results",
              "properties": {
                "pagination": {
                  "type": "object",
                  "properties": {
                    "last_visible_page": {"type": "integer"},
                    "has_next_page": {"type": "boolean"}
                  }
                },
                "data": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "mal_id": {"type": "integer", "description": "MyAnimeList ID"},
                      "title": {"type": "string"},
                      "title_english": {"type": ["string", "null"]},
                      "title_japanese": {"type": ["string", "null"]},
                      "type": {"type": ["string", "null"]},
                      "episodes": {"type": ["integer", "null"]},
                      "status": {"type": "string"},
                      "score": {"type": ["number", "null"]},
                      "scored_by": {"type": ["integer", "null"]},
                      "rank": {"type": ["integer", "null"]},
                      "popularity": {"type": ["integer", "null"]},
                      "members": {"type": "integer"},
                      "synopsis": {"type": ["string", "null"]},
                      "genres": {"type": "array"},
                      "images": {"type": "object"},
                      "url": {"type": "string"}
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {
            "error": {"type": "string"}
          },
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "Jikan_get_anime",
    "description": "Get detailed information about a specific anime by its MyAnimeList ID. Returns comprehensive data including score, synopsis, episodes, studios, genres, themes, opening/ending themes, and related anime.",
    "parameter": {
      "type": "object",
      "properties": {
        "mal_id": {
          "type": "integer",
          "description": "MyAnimeList anime ID (e.g., 1 for Cowboy Bebop, 20 for Naruto, 16498 for Attack on Titan)"
        }
      },
      "required": ["mal_id"]
    },
    "fields": {
      "endpoint": "https://api.jikan.moe/v4/anime/{mal_id}"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"mal_id": 1},
      {"mal_id": 20},
      {"mal_id": 16498}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Detailed anime information",
              "properties": {
                "data": {
                  "type": "object",
                  "properties": {
                    "mal_id": {"type": "integer"},
                    "title": {"type": "string"},
                    "title_english": {"type": ["string", "null"]},
                    "title_japanese": {"type": ["string", "null"]},
                    "type": {"type": ["string", "null"]},
                    "source": {"type": "string"},
                    "episodes": {"type": ["integer", "null"]},
                    "status": {"type": "string"},
                    "airing": {"type": "boolean"},
                    "aired": {"type": "object"},
                    "duration": {"type": "string"},
                    "rating": {"type": ["string", "null"]},
                    "score": {"type": ["number", "null"]},
                    "scored_by": {"type": ["integer", "null"]},
                    "rank": {"type": ["integer", "null"]},
                    "popularity": {"type": ["integer", "null"]},
                    "members": {"type": "integer"},
                    "favorites": {"type": "integer"},
                    "synopsis": {"type": ["string", "null"]},
                    "background": {"type": ["string", "null"]},
                    "studios": {"type": "array"},
                    "genres": {"type": "array"},
                    "themes": {"type": "array"}
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {
            "error": {"type": "string"}
          },
          "required": ["error"]
        }
      ]
    }
  },
  {
