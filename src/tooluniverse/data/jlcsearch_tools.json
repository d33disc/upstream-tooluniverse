[
    {
        "name": "JLCSearch_search_components",
        "description": "Full-text search across all electronic components available from JLCPCB/LCSC. Searches by manufacturer part number (MPN), keyword, or description. Returns matching components with LCSC part number, manufacturer, package, stock level, and unit price. Useful for finding any type of electronic component including ICs, passives, connectors, and semiconductors. Example: 'LM358' returns op-amp variants, 'NE555' returns 555 timer ICs.",
        "parameter": {
            "type": "object",
            "properties": {
                "query": {
                    "type": "string",
                    "description": "Search query - manufacturer part number, IC name, or keyword. Examples: 'LM358' (op-amp), 'NE555' (timer IC), 'STM32F103' (microcontroller), 'ESP32' (WiFi MCU), '74HC595' (shift register)."
                },
                "limit": {
                    "type": ["integer", "null"],
                    "description": "Maximum number of results to return. Default is 100."
                },
                "package": {
                    "type": ["string", "null"],
                    "description": "Filter by package type. Examples: 'SOIC-8', 'TSSOP-20', 'QFP-48', 'SOP-8', 'DIP-8'."
                }
            },
            "required": ["query"]
        },
        "fields": {
            "endpoint": "search"
        },
        "type": "JLCSearchTool",
        "test_examples": [
            {"query": "LM358"},
            {"query": "NE555", "limit": 5}
        ],
        "return_schema": {
            "oneOf": [
                {
                    "type": "object",
                    "properties": {
                        "data": {
                            "type": "array",
                            "items": {
                                "type": "object",
                                "properties": {
                                    "lcsc": {"type": "integer", "description": "LCSC part number (numeric ID)"},
                                    "mfr": {"type": "string", "description": "Manufacturer part number (MPN)"},
                                    "package": {"type": ["string", "null"], "description": "Component package type (e.g., SOIC-8, QFP-48)"},
                                    "is_basic": {"type": ["boolean", "null"], "description": "Whether this is a JLCPCB basic part (lower assembly fee)"},
                                    "is_preferred": {"type": ["boolean", "null"], "description": "Whether this is a JLCPCB preferred part"},
                                    "description": {"type": ["string", "null"], "description": "Component description"},
                                    "stock": {"type": ["integer", "null"], "description": "Current stock quantity"},
                                    "price": {"type": ["number", "null"], "description": "Unit price in USD"}
                                }
                            }
                        },
                        "metadata": {
                            "type": "object",
                            "properties": {
                                "source": {"type": "string"},
                                "endpoint": {"type": "string"},
                                "query": {"type": "string"},
                                "total_results": {"type": "integer"}
                            }
                        }
                    }
                },
                {
                    "type": "object",
                    "properties": {
                        "error": {"type": "string"}
                    }
                }
            ]
        }
    },
    {
        "name": "JLCSearch_search_resistors",
        "description": "Parametric search for resistors available from JLCPCB/LCSC. Filter by resistance value, package size, and other specifications. Returns detailed resistor data including resistance (ohms), tolerance, power rating, stock, and pricing. Components are sorted by stock quantity (most available first). Example: Search for 10k ohm 0603 resistors for circuit design.",
        "parameter": {
            "type": "object",
            "properties": {
                "resistance": {
                    "type": ["number", "null"],
                    "description": "Resistance value in ohms. Examples: 100 (100 ohm), 1000 (1k), 10000 (10k), 100000 (100k), 1000000 (1M)."
                },
                "package": {
                    "type": ["string", "null"],
                    "description": "SMD package size. Examples: '0201', '0402', '0603', '0805', '1206', '2512'."
                },
                "limit": {
                    "type": ["integer", "null"],
                    "description": "Maximum number of results to return. Default returns up to 100 results."
                }
            }
        },
        "fields": {
            "endpoint": "resistors"
        },
        "type": "JLCSearchTool",
        "test_examples": [
            {"resistance": 10000, "package": "0603"},
            {"package": "0402", "limit": 5}
        ],
        "return_schema": {
            "oneOf": [
                {
                    "type": "object",
                    "properties": {
                        "data": {
                            "type": "array",
                            "items": {
                                "type": "object",
                                "properties": {
                                    "lcsc": {"type": "integer", "description": "LCSC part number"},
                                    "mfr": {"type": "string", "description": "Manufacturer part number"},
                                    "package": {"type": ["string", "null"], "description": "SMD package size (e.g., 0603)"},
                                    "is_basic": {"type": ["boolean", "null"], "description": "JLCPCB basic part flag"},
                                    "is_preferred": {"type": ["boolean", "null"], "description": "JLCPCB preferred part flag"},
                                    "resistance": {"type": ["number", "null"], "description": "Resistance value in ohms"},
                                    "tolerance_fraction": {"type": ["number", "null"], "description": "Tolerance as fraction (e.g., 0.01 = 1%)"},
                                    "power_watts": {"type": ["number", "null"], "description": "Power rating in milliwatts"},
                                    "stock": {"type": ["integer", "null"], "description": "Current stock quantity"},
                                    "price1": {"type": ["number", "null"], "description": "Unit price in USD"}
                                }
                            }
                        },
                        "metadata": {
                            "type": "object",
                            "properties": {
                                "source": {"type": "string"},
                                "endpoint": {"type": "string"},
                                "total_results": {"type": "integer"},
                                "params": {"type": "object"}
                            }
                        }
                    }
                },
                {
                    "type": "object",
                    "properties": {
                        "error": {"type": "string"}
                    }
                }
            ]
        }
    },
    {
        "name": "JLCSearch_search_capacitors",
        "description": "Parametric search for capacitors available from JLCPCB/LCSC. Filter by capacitance value, voltage rating, and package size. Returns detailed capacitor data including capacitance (farads), voltage rating, dielectric type, stock, and pricing. Components are sorted by stock quantity. Example: Search for 100nF 0603 capacitors for decoupling.",
        "parameter": {
            "type": "object",
            "properties": {
                "capacitance": {
                    "type": ["number", "null"],
                    "description": "Capacitance value in farads. Examples: 1e-12 (1pF), 1e-9 (1nF), 1e-7 (100nF), 1e-6 (1uF), 1e-4 (100uF). Note: use scientific notation."
                },
                "voltage": {
                    "type": ["number", "null"],
                    "description": "Voltage rating in volts. Examples: 6.3, 10, 16, 25, 50, 100."
                },
                "package": {
                    "type": ["string", "null"],
                    "description": "SMD package size. Examples: '0201', '0402', '0603', '0805', '1206'."
                },
                "limit": {
                    "type": ["integer", "null"],
                    "description": "Maximum number of results to return. Default returns up to 100 results."
                }
            }
        },
        "fields": {
            "endpoint": "capacitors"
        },
        "type": "JLCSearchTool",
        "test_examples": [
            {"package": "0603", "limit": 5},
            {"voltage": 50, "limit": 5}
        ],
        "return_schema": {
            "oneOf": [
                {
                    "type": "object",
                    "properties": {
                        "data": {
                            "type": "array",
                            "items": {
                                "type": "object",
                                "properties": {
                                    "lcsc": {"type": "integer", "description": "LCSC part number"},
                                    "mfr": {"type": "string", "description": "Manufacturer part number"},
                                    "package": {"type": ["string", "null"], "description": "SMD package size"},
                                    "is_basic": {"type": ["boolean", "null"], "description": "JLCPCB basic part flag"},
                                    "is_preferred": {"type": ["boolean", "null"], "description": "JLCPCB preferred part flag"},
                                    "capacitance": {"type": ["number", "null"], "description": "Capacitance value in farads"},
                                    "voltage": {"type": ["number", "null"], "description": "Voltage rating in volts"},
                                    "type": {"type": ["string", "null"], "description": "Capacitor type (e.g., ceramic, electrolytic)"},
                                    "stock": {"type": ["integer", "null"], "description": "Current stock quantity"},
                                    "price1": {"type": ["number", "null"], "description": "Unit price in USD"}
                                }
                            }
                        },
                        "metadata": {
                            "type": "object",
                            "properties": {
                                "source": {"type": "string"},
                                "endpoint": {"type": "string"},
                                "total_results": {"type": "integer"},
                                "params": {"type": "object"}
                            }
                        }
                    }
                },
                {
                    "type": "object",
                    "properties": {
                        "error": {"type": "string"}
                    }
                }
            ]
        }
    },
    {
        "name": "JLCSearch_search_microcontrollers",
        "description": "Parametric search for microcontrollers (MCUs) available from JLCPCB/LCSC. Filter by CPU core type, package, and specifications. Returns detailed MCU data including CPU core architecture, clock speed, flash/RAM size, GPIO count, available peripherals (UART, I2C, SPI, CAN, USB), stock levels, and pricing. Popular MCUs include STM32, ESP32, ATmega, and PIC series.",
        "parameter": {
            "type": "object",
            "properties": {
                "cpu_core": {
                    "type": ["string", "null"],
                    "description": "CPU core architecture filter. Examples: 'ARM-M3' (Cortex-M3), 'ARM-M4' (Cortex-M4), 'ARM-M0' (Cortex-M0), 'RISC-V', 'STM8', '51Series'."
                },
                "package": {
                    "type": ["string", "null"],
                    "description": "IC package type. Examples: 'LQFP-48(7x7)', 'TSSOP-20', 'QFN-32', 'SOP-8'."
                },
                "limit": {
                    "type": ["integer", "null"],
                    "description": "Maximum number of results to return. Default returns up to 100 results."
                }
            }
        },
        "fields": {
            "endpoint": "microcontrollers"
        },
        "type": "JLCSearchTool",
        "test_examples": [
            {"limit": 5},
            {"cpu_core": "ARM-M3", "limit": 5}
        ],
        "return_schema": {
            "oneOf": [
                {
                    "type": "object",
                    "properties": {
                        "data": {
                            "type": "array",
                            "items": {
                                "type": "object",
                                "properties": {
                                    "lcsc": {"type": "integer", "description": "LCSC part number"},
                                    "mfr": {"type": "string", "description": "Manufacturer part number"},
                                    "package": {"type": ["string", "null"], "description": "IC package type"},
                                    "cpu_core": {"type": ["string", "null"], "description": "CPU core architecture (e.g., ARM-M3, RISC-V)"},
                                    "cpu_speed_hz": {"type": ["number", "null"], "description": "Maximum CPU clock speed in Hz"},
                                    "flash_size_bytes": {"type": ["number", "null"], "description": "Flash memory size in KB"},
                                    "ram_size_bytes": {"type": ["number", "null"], "description": "RAM size in KB"},
                                    "eeprom_size_bytes": {"type": ["number", "null"], "description": "EEPROM size in bytes"},
                                    "gpio_count": {"type": ["integer", "null"], "description": "Number of GPIO pins"},
                                    "has_uart": {"type": ["boolean", "null"], "description": "UART peripheral available"},
                                    "has_i2c": {"type": ["boolean", "null"], "description": "I2C peripheral available"},
                                    "has_spi": {"type": ["boolean", "null"], "description": "SPI peripheral available"},
                                    "has_can": {"type": ["boolean", "null"], "description": "CAN bus peripheral available"},
                                    "has_usb": {"type": ["boolean", "null"], "description": "USB peripheral available"},
                                    "stock": {"type": ["integer", "null"], "description": "Current stock quantity"},
                                    "price1": {"type": ["number", "null"], "description": "Unit price in USD"}
                                }
                            }
                        },
                        "metadata": {
                            "type": "object",
                            "properties": {
                                "source": {"type": "string"},
                                "endpoint": {"type": "string"},
                                "total_results": {"type": "integer"},
                                "params": {"type": "object"}
                            }
                        }
                    }
                },
                {
                    "type": "object",
                    "properties": {
                        "error": {"type": "string"}
                    }
                }
            ]
        }
    },
    {
        "name": "JLCSearch_search_voltage_regulators",
        "description": "Parametric search for voltage regulators (LDOs and linear regulators) available from JLCPCB/LCSC. Filter by output voltage, output current, and package. Returns detailed regulator data including output type (fixed/adjustable), voltage range, current rating, dropout voltage, and whether it is an LDO (low dropout). Common parts include AMS1117, 78xx series, and XC6206.",
        "parameter": {
            "type": "object",
            "properties": {
                "output_voltage": {
                    "type": ["number", "null"],
                    "description": "Output voltage in volts. Examples: 1.8, 2.5, 3.3, 5.0, 12.0."
                },
                "output_current": {
                    "type": ["number", "null"],
                    "description": "Minimum output current capability in amps. Examples: 0.1, 0.5, 1.0, 3.0."
                },
                "package": {
                    "type": ["string", "null"],
                    "description": "Regulator package type. Examples: 'SOT-23', 'SOT-223', 'TO-252', 'TO-263', 'SOIC-8'."
                },
                "limit": {
                    "type": ["integer", "null"],
                    "description": "Maximum number of results to return. Default returns up to 100 results."
                }
            }
        },
        "fields": {
            "endpoint": "voltage_regulators"
        },
        "type": "JLCSearchTool",
        "test_examples": [
            {"limit": 5},
            {"package": "SOT-223", "limit": 5}
        ],
        "return_schema": {
            "oneOf": [
                {
                    "type": "object",
                    "properties": {
                        "data": {
                            "type": "array",
                            "items": {
                                "type": "object",
                                "properties": {
                                    "lcsc": {"type": "integer", "description": "LCSC part number"},
                                    "mfr": {"type": "string", "description": "Manufacturer part number"},
                                    "package": {"type": ["string", "null"], "description": "Package type"},
                                    "output_type": {"type": ["string", "null"], "description": "Output type: 'fixed' or 'adjustable'"},
                                    "is_low_dropout": {"type": ["boolean", "null"], "description": "Whether this is an LDO regulator"},
                                    "is_positive": {"type": ["boolean", "null"], "description": "Positive voltage regulator flag"},
                                    "output_voltage_min": {"type": ["number", "null"], "description": "Minimum output voltage in volts"},
                                    "output_voltage_max": {"type": ["number", "null"], "description": "Maximum output voltage in volts"},
                                    "output_current_max": {"type": ["number", "null"], "description": "Maximum output current in amps"},
                                    "dropout_voltage": {"type": ["number", "null"], "description": "Dropout voltage in volts"},
                                    "input_voltage_min": {"type": ["number", "null"], "description": "Minimum input voltage in volts"},
                                    "input_voltage_max": {"type": ["number", "null"], "description": "Maximum input voltage in volts"},
                                    "quiescent_current": {"type": ["number", "null"], "description": "Quiescent current in amps"},
                                    "stock": {"type": ["integer", "null"], "description": "Current stock quantity"},
                                    "price1": {"type": ["number", "null"], "description": "Unit price in USD"}
                                }
                            }
                        },
                        "metadata": {
                            "type": "object",
                            "properties": {
                                "source": {"type": "string"},
                                "endpoint": {"type": "string"},
                                "total_results": {"type": "integer"},
                                "params": {"type": "object"}
                            }
                        }
                    }
                },
                {
                    "type": "object",
                    "properties": {
                        "error": {"type": "string"}
                    }
                }
            ]
        }
    },
    {
        "name": "JLCSearch_search_leds",
        "description": "Parametric search for LEDs (Light Emitting Diodes) available from JLCPCB/LCSC. Filter by color, package size, and specifications. Returns detailed LED data including color, wavelength, forward voltage/current, luminous intensity, stock, and pricing. Useful for selecting indicator LEDs, display backlights, and illumination components for PCB designs.",
        "parameter": {
            "type": "object",
            "properties": {
                "color": {
                    "type": ["string", "null"],
                    "description": "LED color filter. Examples: 'red', 'green', 'blue', 'white', 'yellow', 'orange', 'emerald'."
                },
                "package": {
                    "type": ["string", "null"],
                    "description": "SMD LED package size. Examples: '0201', '0402', '0603', '0805', '1206', '3528', '5050'."
                },
                "limit": {
                    "type": ["integer", "null"],
                    "description": "Maximum number of results to return. Default returns up to 100 results."
                }
            }
        },
        "fields": {
            "endpoint": "leds"
        },
        "type": "JLCSearchTool",
        "test_examples": [
            {"color": "red", "limit": 5},
            {"package": "0603", "limit": 5}
        ],
        "return_schema": {
            "oneOf": [
                {
                    "type": "object",
                    "properties": {
                        "data": {
                            "type": "array",
                            "items": {
                                "type": "object",
                                "properties": {
                                    "lcsc": {"type": "integer", "description": "LCSC part number"},
                                    "mfr": {"type": "string", "description": "Manufacturer part number"},
                                    "package": {"type": ["string", "null"], "description": "LED package size"},
                                    "color": {"type": ["string", "null"], "description": "LED color (red, green, blue, etc.)"},
                                    "wavelength_nm": {"type": ["number", "null"], "description": "Peak wavelength in nanometers"},
                                    "forward_voltage": {"type": ["number", "null"], "description": "Forward voltage in volts"},
                                    "forward_current": {"type": ["number", "null"], "description": "Forward current in amps"},
                                    "luminous_intensity_mcd": {"type": ["number", "null"], "description": "Luminous intensity in millicandelas"},
                                    "stock": {"type": ["integer", "null"], "description": "Current stock quantity"},
                                    "price1": {"type": ["number", "null"], "description": "Unit price in USD"}
