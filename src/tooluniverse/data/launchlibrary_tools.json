[
  {
    "name": "LaunchLibrary_get_upcoming_launches",
    "description": "Get upcoming rocket launches worldwide from The Space Devs Launch Library 2 API. Returns launch details including rocket name, launch date/time, launch site, mission description, and current status. Covers all launch providers (SpaceX, NASA, ULA, Arianespace, Roscosmos, ISRO, etc.). No authentication required. Useful for space exploration tracking and event monitoring.",
    "parameter": {
      "type": "object",
      "properties": {
        "search": {
          "type": ["string", "null"],
          "description": "Search text to filter launches by name. Examples: 'Starlink', 'Crew Dragon', 'Ariane', 'ISRO'"
        },
        "launch_service_provider__name": {
          "type": ["string", "null"],
          "description": "Filter by launch provider name. Examples: 'SpaceX', 'NASA', 'Rocket Lab', 'United Launch Alliance'"
        },
        "net__gte": {
          "type": ["string", "null"],
          "description": "Filter launches after this datetime (ISO 8601). Example: '2024-01-01T00:00:00Z'"
        },
        "limit": {
          "type": ["integer", "null"],
          "description": "Number of results to return (default 10, max 100)"
        }
      },
      "required": []
    },
    "fields": {
      "endpoint": "https://ll.thespacedevs.com/2.3.0/launches/upcoming/",
      "params": {
        "format": "json",
        "limit": "10"
      }
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"limit": 5},
      {"search": "Starlink", "limit": 5},
      {"launch_service_provider__name": "SpaceX", "limit": 5}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Upcoming launches data",
              "properties": {
                "count": {"type": "integer", "description": "Total upcoming launches"},
                "next": {"type": ["string", "null"]},
                "previous": {"type": ["string", "null"]},
                "results": {
                  "type": "array",
                  "description": "List of upcoming launches",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {"type": "string", "description": "Launch UUID"},
                      "name": {"type": "string", "description": "Launch name (e.g., Falcon 9 | Starlink Group 10-36)"},
                      "net": {"type": "string", "description": "No Earlier Than launch datetime (ISO 8601)"},
                      "status": {
                        "type": "object",
                        "properties": {
                          "name": {"type": "string", "description": "Status (Go for Launch, TBD, etc.)"}
                        }
                      },
                      "launch_service_provider": {
                        "type": "object",
                        "properties": {
                          "name": {"type": "string", "description": "Provider name (SpaceX, NASA, etc.)"}
                        }
                      },
                      "rocket": {
                        "type": "object",
                        "properties": {
                          "configuration": {
                            "type": "object",
                            "properties": {
                              "name": {"type": "string", "description": "Rocket name"}
                            }
                          }
                        }
                      },
                      "mission": {
                        "type": ["object", "null"],
                        "properties": {
                          "name": {"type": "string"},
                          "description": {"type": "string"},
                          "type": {"type": "string"}
                        }
                      },
                      "pad": {
                        "type": "object",
                        "properties": {
                          "name": {"type": "string", "description": "Launch pad name"},
                          "location": {"type": "object", "description": "Launch location"}
                        }
                      }
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
