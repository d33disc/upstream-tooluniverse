[
  {
    "name": "Lemmy_search_posts",
    "description": "Search for posts across Lemmy (lemmy.world), an open-source Reddit alternative with thousands of communities covering technology, science, gaming, politics, and more. Returns posts matching a query with scores, comment counts, community info, and URLs. No authentication required. Useful for discovering discussions, tracking topics across federated communities, and monitoring community sentiment.",
    "parameter": {
      "type": "object",
      "properties": {
        "q": {
          "type": "string",
          "description": "Search query string. Examples: 'rust programming', 'machine learning', 'self-hosted apps', 'linux gaming'"
        },
        "type_": {
          "type": ["string", "null"],
          "description": "Type of search results. Values: 'Posts' (default), 'Comments', 'Communities', 'Users', 'Url'. Default: 'Posts'"
        },
        "sort": {
          "type": ["string", "null"],
          "description": "Sort order. Values: 'TopAll', 'TopDay', 'TopWeek', 'TopMonth', 'TopYear', 'Hot', 'New', 'Active', 'Old', 'MostComments', 'NewComments'. Default: 'TopAll'"
        },
        "limit": {
          "type": ["integer", "null"],
          "description": "Number of results (1-50). Default: 10"
        },
        "page": {
          "type": ["integer", "null"],
          "description": "Page number for pagination. Default: 1"
        },
        "community_name": {
          "type": ["string", "null"],
          "description": "Filter to a specific community name. Examples: 'technology', 'programming', 'linux', 'science'"
        }
      },
      "required": ["q"]
    },
    "fields": {
      "endpoint": "https://lemmy.world/api/v3/search",
      "params": {
        "type_": "Posts"
      }
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"q": "rust programming", "sort": "TopAll", "limit": 5},
      {"q": "machine learning", "type_": "Posts", "limit": 3},
      {"q": "self-hosted", "community_name": "selfhosted", "limit": 5}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Lemmy search results",
              "properties": {
                "posts": {
                  "type": "array",
                  "description": "List of matching posts",
                  "items": {
                    "type": "object",
                    "properties": {
                      "post": {
                        "type": "object",
                        "description": "Post details",
                        "properties": {
                          "id": {"type": "integer", "description": "Post ID"},
                          "name": {"type": "string", "description": "Post title"},
                          "url": {"type": ["string", "null"], "description": "Link URL if link post"},
                          "body": {"type": ["string", "null"], "description": "Post text body"},
                          "published": {"type": "string", "description": "ISO 8601 publish date"},
                          "nsfw": {"type": "boolean"},
                          "thumbnail_url": {"type": ["string", "null"]}
                        }
                      },
                      "counts": {
                        "type": "object",
                        "description": "Post engagement metrics",
                        "properties": {
                          "score": {"type": "integer", "description": "Net score (upvotes - downvotes)"},
                          "upvotes": {"type": "integer"},
                          "downvotes": {"type": "integer"},
                          "comments": {"type": "integer", "description": "Number of comments"}
                        }
                      },
                      "community": {
                        "type": "object",
                        "description": "Community the post belongs to",
                        "properties": {
                          "name": {"type": "string", "description": "Community name"},
                          "title": {"type": "string", "description": "Community display title"}
                        }
                      }
                    }
                  }
                },
                "comments": {"type": "array", "description": "List of matching comments (when type_=Comments)"},
                "communities": {"type": "array", "description": "List of matching communities (when type_=Communities)"}
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "Lemmy_list_communities",
    "description": "List communities on Lemmy (lemmy.world), an open-source federated social platform. Returns communities sorted by subscribers, activity, or creation date. Each community has subscriber count, post count, and description. No authentication required. Useful for discovering active communities, finding niche discussion groups, and analyzing community growth.",
    "parameter": {
      "type": "object",
      "properties": {
        "sort": {
          "type": ["string", "null"],
          "description": "Sort order. Values: 'TopAll' (most subscribers), 'Hot', 'New', 'Active', 'TopDay', 'TopWeek', 'TopMonth'. Default: 'TopAll'"
        },
        "limit": {
          "type": ["integer", "null"],
          "description": "Number of communities (1-50). Default: 10"
        },
        "page": {
          "type": ["integer", "null"],
          "description": "Page number for pagination. Default: 1"
        },
        "type_": {
          "type": ["string", "null"],
          "description": "Filter type. Values: 'All', 'Local', 'Subscribed'. Default: 'All'"
        }
      },
      "required": []
    },
    "fields": {
      "endpoint": "https://lemmy.world/api/v3/community/list",
      "params": {
        "type_": "All"
      }
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"sort": "TopAll", "limit": 10},
      {"sort": "Hot", "limit": 5},
      {"sort": "New", "limit": 5}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Community listing results",
              "properties": {
                "communities": {
                  "type": "array",
                  "description": "List of communities",
                  "items": {
                    "type": "object",
                    "properties": {
                      "community": {
                        "type": "object",
                        "properties": {
                          "id": {"type": "integer"},
                          "name": {"type": "string", "description": "Community name (slug)"},
                          "title": {"type": "string", "description": "Display title"},
                          "description": {"type": ["string", "null"], "description": "Community description"},
                          "nsfw": {"type": "boolean"},
                          "published": {"type": "string"},
                          "icon": {"type": ["string", "null"]}
                        }
                      },
                      "counts": {
                        "type": "object",
                        "properties": {
                          "subscribers": {"type": "integer", "description": "Number of subscribers"},
                          "posts": {"type": "integer", "description": "Total posts"},
                          "comments": {"type": "integer", "description": "Total comments"},
                          "users_active_month": {"type": "integer", "description": "Monthly active users"}
                        }
                      }
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "Lemmy_get_community_posts",
    "description": "Get posts from a specific Lemmy community (subreddit equivalent). Returns posts with titles, URLs, scores, and comment counts sorted by hot, new, or top. No authentication required. Useful for monitoring specific communities, building news aggregators from curated communities, and tracking trending discussions.",
    "parameter": {
      "type": "object",
      "properties": {
        "community_name": {
          "type": "string",
          "description": "Community name to get posts from. Examples: 'technology', 'programming', 'linux', 'science', 'selfhosted', 'privacy', 'games'"
        },
        "sort": {
          "type": ["string", "null"],
          "description": "Sort order. Values: 'Hot', 'New', 'Active', 'TopDay', 'TopWeek', 'TopMonth', 'TopAll', 'MostComments', 'NewComments'. Default: 'Hot'"
        },
        "limit": {
          "type": ["integer", "null"],
          "description": "Number of posts (1-50). Default: 10"
        },
        "page": {
          "type": ["integer", "null"],
          "description": "Page number for pagination. Default: 1"
        }
      },
      "required": ["community_name"]
    },
    "fields": {
      "endpoint": "https://lemmy.world/api/v3/post/list"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"community_name": "technology", "sort": "Hot", "limit": 5},
      {"community_name": "programming", "sort": "TopWeek", "limit": 5},
      {"community_name": "linux", "sort": "New", "limit": 3}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Community post listing",
              "properties": {
                "posts": {
                  "type": "array",
                  "description": "List of posts in the community",
                  "items": {
                    "type": "object",
                    "properties": {
                      "post": {
                        "type": "object",
                        "properties": {
                          "id": {"type": "integer"},
                          "name": {"type": "string", "description": "Post title"},
                          "url": {"type": ["string", "null"], "description": "Link URL"},
                          "body": {"type": ["string", "null"], "description": "Text body"},
                          "published": {"type": "string"},
                          "nsfw": {"type": "boolean"}
                        }
                      },
                      "counts": {
                        "type": "object",
                        "properties": {
                          "score": {"type": "integer"},
                          "upvotes": {"type": "integer"},
                          "downvotes": {"type": "integer"},
                          "comments": {"type": "integer"}
                        }
                      },
                      "community": {
                        "type": "object",
                        "properties": {
                          "name": {"type": "string"},
                          "title": {"type": "string"}
                        }
                      }
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
