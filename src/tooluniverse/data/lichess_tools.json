[
  {
    "name": "Lichess_get_player_profile",
    "description": "Get a Lichess.org chess player's public profile including ratings for all time controls (bullet, blitz, rapid, classical), game count, titles, and account info using the Lichess public API. No authentication required. Useful for chess analytics, comparing players, and tracking performance.",
    "parameter": {
      "type": "object",
      "properties": {
        "username": {
          "type": "string",
          "description": "Lichess username (case-insensitive). Examples: 'DrNykterstein' (Magnus Carlsen), 'hikaru', 'alireza2003', 'wonderfultime'"
        }
      },
      "required": ["username"]
    },
    "fields": {
      "endpoint": "https://lichess.org/api/user/{username}",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"username": "DrNykterstein"},
      {"username": "hikaru"},
      {"username": "alireza2003"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Lichess player profile",
              "properties": {
                "id": {"type": "string"},
                "username": {"type": "string"},
                "title": {"type": ["string", "null"], "description": "FIDE title (GM, IM, FM, etc.)"},
                "perfs": {
                  "type": "object",
                  "description": "Performance ratings by time control",
                  "properties": {
                    "bullet": {"type": "object", "properties": {"rating": {"type": "integer"}, "games": {"type": "integer"}, "prog": {"type": "integer"}}},
                    "blitz": {"type": "object", "properties": {"rating": {"type": "integer"}, "games": {"type": "integer"}}},
                    "rapid": {"type": "object", "properties": {"rating": {"type": "integer"}, "games": {"type": "integer"}}},
                    "classical": {"type": "object", "properties": {"rating": {"type": "integer"}, "games": {"type": "integer"}}}
                  }
                },
                "createdAt": {"type": "integer", "description": "Unix timestamp of account creation"},
                "seenAt": {"type": "integer", "description": "Unix timestamp of last activity"},
                "playTime": {"type": "object", "properties": {"total": {"type": "integer"}, "tv": {"type": "integer"}}},
                "count": {
                  "type": "object",
                  "properties": {
                    "all": {"type": "integer", "description": "Total games"},
                    "rated": {"type": "integer"},
                    "win": {"type": "integer"},
                    "loss": {"type": "integer"},
                    "draw": {"type": "integer"}
                  }
                },
                "url": {"type": "string", "description": "Lichess profile URL"}
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "Lichess_get_top_players",
    "description": "Get the top 50 Lichess.org players for a specific time control using the Lichess public API. Returns player usernames, ratings, and titles. No authentication required. Useful for finding elite players, tracking leaderboard changes, and chess research.",
    "parameter": {
      "type": "object",
      "properties": {
        "nb": {
          "type": "integer",
          "description": "Number of top players to return (1-200). Default: 10"
        },
        "perfType": {
          "type": "string",
          "description": "Time control / performance type. Values: 'bullet', 'blitz', 'rapid', 'classical', 'ultraBullet', 'chess960', 'crazyhouse', 'antichess', 'atomic', 'horde', 'kingOfTheHill', 'racingKings', 'threeCheck'"
        }
      },
      "required": ["nb", "perfType"]
    },
    "fields": {
      "endpoint": "https://lichess.org/api/player/top/{nb}/{perfType}",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"nb": 10, "perfType": "bullet"},
      {"nb": 10, "perfType": "blitz"},
      {"nb": 5, "perfType": "rapid"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Top Lichess players for the time control",
              "properties": {
                "users": {
                  "type": "array",
                  "description": "List of top players",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {"type": "string"},
                      "username": {"type": "string"},
                      "title": {"type": ["string", "null"]},
                      "perfs": {"type": "object"},
                      "patron": {"type": ["boolean", "null"]}
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
