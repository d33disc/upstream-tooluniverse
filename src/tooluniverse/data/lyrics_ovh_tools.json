[
  {
    "name": "LyricsOVH_get_lyrics",
    "description": "Get lyrics for any song using the Lyrics.ovh API. Returns the full song lyrics as text. Covers a vast catalog of artists and songs across all genres. No authentication required. Useful for music analysis, natural language processing of song lyrics, and music information retrieval.",
    "parameter": {
      "type": "object",
      "properties": {
        "artist": {
          "type": "string",
          "description": "Artist or band name. Examples: 'Michael Jackson', 'The Beatles', 'Taylor Swift', 'Queen', 'Bob Dylan', 'Radiohead'"
        },
        "title": {
          "type": "string",
          "description": "Song title. Examples: 'Thriller', 'Bohemian Rhapsody', 'Hey Jude', 'Shake It Off', 'Creep'"
        }
      },
      "required": ["artist", "title"]
    },
    "fields": {
      "endpoint": "https://api.lyrics.ovh/v1/{artist}/{title}",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"artist": "Michael Jackson", "title": "Thriller"},
      {"artist": "The Beatles", "title": "Hey Jude"},
      {"artist": "Queen", "title": "Bohemian Rhapsody"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Song lyrics",
              "properties": {
                "lyrics": {"type": "string", "description": "Full song lyrics text"}
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "LyricsOVH_suggest_songs",
    "description": "Search for songs and artists using the Lyrics.ovh suggestion API. Returns a list of songs matching the search term with artist name and song title. Useful for music discovery and finding the exact song/artist names before fetching lyrics.",
    "parameter": {
      "type": "object",
      "properties": {
        "query": {
          "type": "string",
          "description": "Search query for artist or song name. Examples: 'Michael Jackson', 'Beatles', 'Taylor Swift', 'love song'"
        }
      },
      "required": ["query"]
    },
    "fields": {
      "endpoint": "https://api.lyrics.ovh/suggest/{query}",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"query": "Michael Jackson"},
      {"query": "Beatles"},
      {"query": "Taylor Swift"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Song suggestions matching the query",
              "properties": {
                "total": {"type": "integer", "description": "Total matching results"},
                "next": {"type": ["string", "null"], "description": "URL for next page"},
                "data": {
                  "type": "array",
                  "description": "List of matching songs",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {"type": "integer"},
                      "title": {"type": "string", "description": "Song title"},
                      "artist": {
                        "type": "object",
                        "properties": {
                          "id": {"type": "integer"},
                          "name": {"type": "string", "description": "Artist name"}
                        }
                      }
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
