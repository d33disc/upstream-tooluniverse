[
  {
    "name": "MakeupAPI_search_products",
    "description": "Search for cosmetics and makeup products by brand, type, category, tags, and price range using the Makeup API. Returns product name, brand, price, description, image, rating, colors, and purchase links. Covers major brands including Maybelline, L'Oreal, Revlon, NYX, CoverGirl, and more. No authentication required. Useful for beauty product research, price comparison, and cosmetics data.",
    "parameter": {
      "type": "object",
      "properties": {
        "brand": {
          "type": ["string", "null"],
          "description": "Filter by brand name (lowercase). Options include: 'maybelline', 'covergirl', 'nyx', 'revlon', 'loreal', 'almay', 'physicians formula', 'milani', 'colourpop', 'elf', 'wet n wild'"
        },
        "product_type": {
          "type": ["string", "null"],
          "description": "Filter by product type. Options: 'blush', 'bronzer', 'eyebrow', 'eyeliner', 'eyeshadow', 'foundation', 'lip_liner', 'lipstick', 'mascara', 'nail_polish'"
        },
        "product_category": {
          "type": ["string", "null"],
          "description": "Filter by sub-category. Options include: 'powder', 'cream', 'liquid', 'pencil', 'gel', 'palette', 'lipgloss', 'lip_stain'"
        },
        "product_tags": {
          "type": ["string", "null"],
          "description": "Filter by tag (comma-separated). Options: 'vegan', 'organic', 'natural', 'canadian', 'gluten_free', 'cruelty free', 'chemical free', 'purpicks', 'ewg verified'"
        },
        "price_greater_than": {
          "type": ["number", "null"],
          "description": "Minimum price filter in USD"
        },
        "price_less_than": {
          "type": ["number", "null"],
          "description": "Maximum price filter in USD"
        }
      },
      "required": []
    },
    "fields": {
      "endpoint": "http://makeup-api.herokuapp.com/api/v1/products.json"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"brand": "maybelline", "product_type": "lipstick"},
      {"brand": "covergirl", "product_type": "foundation"},
      {"product_type": "mascara", "product_tags": "vegan"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "array",
              "description": "List of matching makeup products",
              "items": {
                "type": "object",
                "properties": {
                  "id": {"type": "integer", "description": "Product ID"},
                  "brand": {"type": ["string", "null"]},
                  "name": {"type": "string", "description": "Product name"},
                  "price": {"type": ["string", "null"], "description": "Price in USD"},
                  "image_link": {"type": ["string", "null"], "description": "Product image URL"},
                  "product_link": {"type": ["string", "null"], "description": "Purchase URL"},
                  "description": {"type": ["string", "null"], "description": "Product description"},
                  "rating": {"type": ["number", "null"], "description": "User rating (0-5)"},
                  "category": {"type": ["string", "null"], "description": "Product sub-category"},
                  "product_type": {"type": "string"},
                  "tag_list": {"type": "array", "items": {"type": "string"}, "description": "Product tags (vegan, organic, etc.)"},
                  "product_colors": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "hex_value": {"type": "string"},
                        "colour_name": {"type": "string"}
                      }
                    },
                    "description": "Available color options"
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
