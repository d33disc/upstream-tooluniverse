[
  {
    "name": "MangaDex_search_manga",
    "description": "Search for manga series in the MangaDex public API. Returns manga titles, descriptions, publication status, year, tags, content ratings, and author information. No authentication required. Covers thousands of manga series with community translations. Useful for manga recommendations, metadata research, and comics analysis.",
    "parameter": {
      "type": "object",
      "properties": {
        "title": {
          "type": ["string", "null"],
          "description": "Manga title to search for. Examples: 'one piece', 'naruto', 'attack on titan', 'fullmetal alchemist'"
        },
        "limit": {
          "type": ["integer", "null"],
          "description": "Number of results (1-100). Default: 10"
        },
        "status": {
          "type": ["string", "null"],
          "description": "Publication status filter. Values: 'ongoing', 'completed', 'hiatus', 'cancelled'"
        },
        "contentRating": {
          "type": ["string", "null"],
          "description": "Content rating filter. Values: 'safe', 'suggestive', 'erotica'. Default returns all except explicit."
        }
      },
      "required": []
    },
    "fields": {
      "endpoint": "https://api.mangadex.org/manga",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"title": "one piece", "limit": 3},
      {"title": "fullmetal alchemist", "status": "completed", "limit": 3},
      {"title": "attack on titan", "limit": 3}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Manga search results",
              "properties": {
                "result": {"type": "string"},
                "total": {"type": "integer", "description": "Total matching manga"},
                "data": {
                  "type": "array",
                  "description": "List of manga records",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {"type": "string", "description": "MangaDex manga UUID"},
                      "type": {"type": "string"},
                      "attributes": {
                        "type": "object",
                        "properties": {
                          "title": {"type": "object", "description": "Title in various languages (key=lang code, value=title)"},
                          "description": {"type": "object", "description": "Description in various languages"},
                          "status": {"type": "string", "description": "ongoing, completed, hiatus, cancelled"},
                          "year": {"type": ["integer", "null"], "description": "Publication start year"},
                          "contentRating": {"type": "string"},
                          "tags": {"type": "array", "items": {"type": "object"}}
                        }
                      }
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
