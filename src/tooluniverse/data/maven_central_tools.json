[
  {
    "name": "MavenCentral_search_packages",
    "description": "Search Maven Central for Java/JVM packages (artifacts). Returns matching artifacts with groupId, artifactId, latest version, packaging type, version count, and timestamps. Supports free-text search and advanced Solr syntax: 'g:groupId' for group, 'a:artifactId' for artifact, combinable with AND (e.g., 'g:org.springframework AND a:spring-core'). Maven Central hosts 500K+ artifacts for Java, Kotlin, Scala, and other JVM languages.",
    "parameter": {
      "type": "object",
      "properties": {
        "q": {
          "type": "string",
          "description": "Search query. Free text (e.g., 'spring boot') or Solr syntax: 'g:org.springframework' (group), 'a:junit' (artifact), 'g:com.google AND a:guava' (specific artifact)"
        },
        "rows": {
          "type": ["integer", "null"],
          "description": "Number of results to return (default 10, max 200)"
        },
        "start": {
          "type": ["integer", "null"],
          "description": "Offset for pagination (default 0)"
        }
      },
      "required": ["q"]
    },
    "fields": {
      "endpoint": "https://search.maven.org/solrsearch/select",
      "params": {
        "wt": "json"
      }
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"q": "spring-boot", "rows": 5},
      {"q": "g:org.apache.commons", "rows": 5},
      {"q": "a:junit", "rows": 3}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Solr search response from Maven Central",
              "properties": {
                "responseHeader": {
                  "type": "object",
                  "properties": {
                    "status": {"type": "integer"},
                    "QTime": {"type": "integer"}
                  }
                },
                "response": {
                  "type": "object",
                  "properties": {
                    "numFound": {"type": "integer", "description": "Total number of matching artifacts"},
                    "start": {"type": "integer"},
                    "docs": {
                      "type": "array",
                      "description": "List of matching Maven artifacts",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {"type": "string", "description": "Full artifact ID (groupId:artifactId)"},
                          "g": {"type": "string", "description": "Maven groupId (e.g., 'org.springframework.boot')"},
                          "a": {"type": "string", "description": "Maven artifactId (e.g., 'spring-boot-starter')"},
                          "latestVersion": {"type": "string", "description": "Latest available version"},
                          "p": {"type": "string", "description": "Packaging type (jar, pom, war, etc.)"},
                          "repositoryId": {"type": "string", "description": "Repository identifier"},
                          "timestamp": {"type": "integer", "description": "Last update timestamp (ms since epoch)"},
                          "versionCount": {"type": "integer", "description": "Number of published versions"}
                        }
                      }
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "MavenCentral_get_package_versions",
    "description": "Get the version history of a specific Maven artifact from Maven Central. Pass the groupId and artifactId combined as a Solr query (e.g., 'g:com.google.guava AND a:guava'). Returns all published versions with timestamps, packaging types, and available file extensions. Uses the 'gav' (Group-Artifact-Version) core for version-level data.",
    "parameter": {
      "type": "object",
      "properties": {
        "q": {
          "type": "string",
          "description": "Solr query for specific artifact: 'g:{groupId} AND a:{artifactId}' (e.g., 'g:org.springframework.boot AND a:spring-boot-starter', 'g:com.google.guava AND a:guava')"
        },
        "rows": {
          "type": ["integer", "null"],
          "description": "Number of versions to return (default 10, max 200)"
        }
      },
      "required": ["q"]
    },
    "fields": {
      "endpoint": "https://search.maven.org/solrsearch/select",
      "params": {
        "wt": "json",
        "core": "gav"
      }
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"q": "g:org.springframework.boot AND a:spring-boot-starter", "rows": 5},
      {"q": "g:com.google.guava AND a:guava", "rows": 5},
      {"q": "g:org.apache.commons AND a:commons-lang3", "rows": 3}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Version history from Maven Central GAV core",
              "properties": {
                "responseHeader": {
                  "type": "object",
                  "properties": {
                    "status": {"type": "integer"},
                    "QTime": {"type": "integer"}
                  }
                },
                "response": {
                  "type": "object",
                  "properties": {
                    "numFound": {"type": "integer", "description": "Total number of versions"},
                    "start": {"type": "integer"},
                    "docs": {
                      "type": "array",
                      "description": "List of version records sorted by timestamp descending",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {"type": "string", "description": "Full ID (groupId:artifactId:version)"},
                          "g": {"type": "string", "description": "Maven groupId"},
                          "a": {"type": "string", "description": "Maven artifactId"},
                          "v": {"type": "string", "description": "Version string"},
                          "p": {"type": "string", "description": "Packaging type"},
                          "timestamp": {"type": "integer", "description": "Publication timestamp (ms since epoch)"},
                          "ec": {
                            "type": "array",
                            "description": "Available file extensions (e.g., '.jar', '.pom', '-sources.jar')",
                            "items": {"type": "string"}
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
