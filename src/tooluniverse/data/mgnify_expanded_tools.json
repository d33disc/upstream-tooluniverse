        },
        "page_size": {
          "type": "integer",
          "description": "Number of InterPro entries to return per page (default 25, max 100).",
          "default": 25
        }
      },
      "required": [
        "analysis_id"
      ]
    },
    "fields": {
      "endpoint_type": "analysis",
