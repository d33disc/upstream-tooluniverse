[
  {
    "name": "Mouser_search_by_keyword",
    "description": "Search Mouser Electronics for electronic components by keyword. Returns matching parts with pricing, availability, specifications, and datasheets. Supports broad searches like 'STM32 microcontroller' or specific terms like 'LM7805 voltage regulator'. Results include manufacturer part number, stock level, price breaks, lifecycle status, and technical specifications. Requires a free Mouser API key (register at https://www.mouser.com/api-search/ and set MOUSER_API_KEY environment variable). Rate limits: 30 requests/minute, 1000 requests/day.",
    "parameter": {
      "type": "object",
      "properties": {
        "keyword": {
          "type": "string",
          "description": "Search keyword - component type, part number, or description. Examples: 'STM32F103', 'op amp rail to rail', '100nF capacitor 0603', 'USB Type-C connector'."
        },
        "records": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Maximum number of results to return (1-50). Default is 10."
        },
        "starting_record": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Starting index for pagination. Default is 0. Use with records to page through results."
        },
        "search_options": {
          "type": [
            "string",
            "null"
          ],
          "description": "Search filter options. Valid values: '' (none), 'InStock' (only in-stock), 'RoHS' (RoHS compliant only), 'RoHSAndInStock' (both filters). Default is '' (no filter)."
        }
      },
      "required": [
        "keyword"
      ]
    },
    "fields": {
      "operation": "keyword_search",
      "api_version": "v1"
    },
    "type": "MouserTool",
    "test_examples": [
      {
        "keyword": "STM32F103C8T6",
        "records": 5
      },
      {
        "keyword": "LM7805",
        "records": 3
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "mouser_part_number": {
                    "type": "string",
                    "description": "Mouser's internal part number"
                  },
                  "manufacturer_part_number": {
                    "type": "string",
                    "description": "Manufacturer's part number (MPN)"
                  },
                  "manufacturer": {
                    "type": "string",
                    "description": "Component manufacturer name"
                  },
                  "description": {
                    "type": "string",
                    "description": "Part description"
                  },
                  "availability": {
                    "type": "string",
                    "description": "Stock availability status"
                  },
                  "lifecycle": {
                    "type": "string",
                    "description": "Product lifecycle status"
                  },
                  "datasheet_url": {
                    "type": "string",
                    "description": "URL to component datasheet"
                  },
                  "product_detail_url": {
                    "type": "string",
                    "description": "URL to Mouser product page"
                  },
                  "category": {
                    "type": "string",
                    "description": "Component category"
                  },
                  "lead_time": {
                    "type": "string",
                    "description": "Lead time for ordering"
                  },
                  "price_breaks": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "quantity": {
                          "type": "integer"
                        },
                        "price": {
                          "type": "string"
                        },
                        "currency": {
                          "type": "string"
                        }
                      }
                    }
                  },
                  "attributes": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "name": {
                          "type": "string"
                        },
                        "value": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              }
            },
            "metadata": {
              "type": "object",
              "properties": {
                "source": {
                  "type": "string"
                },
                "total_results": {
                  "type": "integer"
                },
                "query": {
                  "type": "string"
                },
                "endpoint": {
                  "type": "string"
                }
              }
            }
          },
          "required": [
            "data"
          ]
        },
        {
          "type": "object",
          "properties": {
            "error": {
              "type": "string"
            }
          },
          "required": [
            "error"
          ]
        }
      ]
    }
  },
  {
    "name": "Mouser_search_by_part_number",
    "description": "Search Mouser Electronics by exact or partial manufacturer part number (MPN). More precise than keyword search - use when you know the specific part number. Returns detailed part data including pricing, stock, specs, and datasheet links. Supports exact matching or begins-with matching. Requires a free Mouser API key (set MOUSER_API_KEY env var). Rate limits: 30 req/min, 1000 req/day.",
    "parameter": {
      "type": "object",
      "properties": {
        "part_number": {
          "type": "string",
          "description": "Manufacturer part number (MPN) or Mouser part number to search. Examples: 'STM32F103C8T6', 'LM358DR', 'CC0603KRX7R9BB104', 'ESP32-WROOM-32E'."
        },
        "search_option": {
          "type": [
            "string",
            "null"
          ],
          "description": "Part number matching mode. Valid values: '' (default - any match), 'Exact' (exact match only), 'BeginsWith' (part number starts with). Default is '' (any)."
        }
      },
      "required": [
        "part_number"
      ]
    },
    "fields": {
      "operation": "partnumber_search",
      "api_version": "v1"
    },
    "type": "MouserTool",
    "test_examples": [
