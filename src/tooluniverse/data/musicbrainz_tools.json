[
  {
    "name": "MusicBrainz_search_recordings",
    "description": "Search for music recordings (songs) in the MusicBrainz open music encyclopedia. Returns title, artist, duration, release information, and unique MBIDs. Uses Lucene syntax: 'artist:beatles AND title:yesterday'. No authentication required. Useful for music metadata lookup, discography research, and audio fingerprinting.",
    "parameter": {
      "type": "object",
      "properties": {
        "query": {
          "type": "string",
          "description": "Lucene search query. Use field:value syntax. Fields: artist (artist name), title (song title), release (album), year. Examples: 'artist:beatles AND title:yesterday', 'artist:\"pink floyd\" AND release:\"dark side\"', 'title:bohemian rhapsody'"
        },
        "limit": {
          "type": ["integer", "null"],
          "description": "Number of results (1-100). Default: 10"
        }
      },
      "required": ["query"]
    },
    "fields": {
      "endpoint": "https://musicbrainz.org/ws/2/recording",
      "params": {"fmt": "json"}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"query": "artist:beatles AND title:yesterday", "limit": 3},
      {"query": "artist:\"pink floyd\" AND release:\"dark side of the moon\"", "limit": 3},
      {"query": "title:bohemian rhapsody AND artist:queen", "limit": 3}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "MusicBrainz recording search results",
              "properties": {
                "count": {"type": "integer", "description": "Total matching recordings"},
                "recordings": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {"type": "string", "description": "MusicBrainz Recording ID (MBID)"},
                      "title": {"type": "string"},
                      "length": {"type": ["integer", "null"], "description": "Duration in milliseconds"},
                      "score": {"type": "integer", "description": "Search relevance score"},
                      "artist-credit": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "name": {"type": ["string", "null"]},
                            "artist": {"type": "object", "properties": {"name": {"type": "string"}, "id": {"type": "string"}}}
                          }
                        }
                      },
                      "releases": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "title": {"type": "string", "description": "Album/release title"},
                            "date": {"type": ["string", "null"]},
                            "id": {"type": "string", "description": "Release MBID"}
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "MusicBrainz_search_artists",
    "description": "Search for music artists in the MusicBrainz open music encyclopedia. Returns artist name, disambiguation, type (person/group), country, begin/end dates, and MBID. No authentication required. Useful for discography research, music metadata, and finding canonical artist identifiers.",
    "parameter": {
      "type": "object",
      "properties": {
        "query": {
          "type": "string",
          "description": "Artist search query. Examples: 'beatles', 'david bowie', 'radiohead', 'mozart'. Use 'artist:\"exact name\"' for exact matching."
        },
        "limit": {
          "type": ["integer", "null"],
          "description": "Number of results (1-100). Default: 10"
        }
      },
      "required": ["query"]
    },
    "fields": {
      "endpoint": "https://musicbrainz.org/ws/2/artist",
      "params": {"fmt": "json"}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"query": "beatles", "limit": 3},
      {"query": "david bowie", "limit": 3},
      {"query": "radiohead", "limit": 3}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "MusicBrainz artist search results",
              "properties": {
                "count": {"type": "integer", "description": "Total matching artists"},
                "artists": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {"type": "string", "description": "MusicBrainz Artist ID (MBID)"},
                      "name": {"type": "string"},
                      "sort-name": {"type": "string"},
                      "type": {"type": ["string", "null"], "description": "Person, Group, Orchestra, etc."},
                      "country": {"type": ["string", "null"], "description": "2-letter country code"},
                      "disambiguation": {"type": ["string", "null"], "description": "Disambiguation info"},
                      "life-span": {
                        "type": "object",
                        "properties": {
                          "begin": {"type": ["string", "null"]},
                          "end": {"type": ["string", "null"]},
                          "ended": {"type": "boolean"}
                        }
                      },
                      "score": {"type": "integer"}
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
