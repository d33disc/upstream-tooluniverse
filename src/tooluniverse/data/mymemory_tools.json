[
  {
    "name": "MyMemory_translate",
    "description": "Translate text between languages using MyMemory, the world's largest collaborative translation memory. Supports 200+ language pairs. Returns translated text with match quality score and alternative translations from the community. No API key required (1000 words/day free limit). Useful for multilingual applications, content localization, translation verification, and cross-language information retrieval.",
    "parameter": {
      "type": "object",
      "properties": {
        "q": {
          "type": "string",
          "description": "Text to translate (max 500 characters per request). Examples: 'Hello, how are you?', 'The quick brown fox jumps over the lazy dog'"
        },
        "langpair": {
          "type": "string",
          "description": "Language pair in format 'source|target' using ISO 639-1 codes. Examples: 'en|fr' (English to French), 'en|de' (to German), 'en|es' (to Spanish), 'en|ja' (to Japanese), 'en|zh' (to Chinese), 'fr|en' (French to English), 'de|en' (German to English)"
        }
      },
      "required": ["q", "langpair"]
    },
    "fields": {
      "endpoint": "https://api.mymemory.translated.net/get"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"q": "Hello, how are you?", "langpair": "en|fr"},
      {"q": "The quick brown fox jumps over the lazy dog", "langpair": "en|de"},
      {"q": "Bonjour le monde", "langpair": "fr|en"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Translation response",
              "properties": {
                "responseData": {
                  "type": "object",
                  "description": "Primary translation result",
                  "properties": {
                    "translatedText": {"type": "string", "description": "The translated text"},
                    "match": {"type": "number", "description": "Translation match quality (0-1, where 1 is perfect match from translation memory)"}
                  }
                },
                "responseStatus": {"type": "integer", "description": "HTTP-like status code (200=success)"},
                "responderId": {"type": ["string", "null"]},
                "matches": {
                  "type": "array",
                  "description": "Alternative translations from translation memory",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {"type": ["string", "null"]},
                      "segment": {"type": "string", "description": "Source text segment"},
                      "translation": {"type": "string", "description": "Alternative translation"},
                      "source": {"type": "string", "description": "Source language code"},
                      "target": {"type": "string", "description": "Target language code"},
                      "quality": {"type": ["string", "number"], "description": "Translation quality score"},
                      "usage-count": {"type": "integer", "description": "How many times this translation has been used"},
                      "subject": {"type": ["string", "null"], "description": "Subject area of translation"},
                      "created-by": {"type": ["string", "null"], "description": "Translation contributor"}
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
