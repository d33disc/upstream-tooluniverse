[
  {
    "name": "PublicHolidays_get_by_country",
    "description": "Get public holidays for a specific country and year using the Nager.Date API. Returns holiday dates, names, types (Public/Bank/Optional), and whether they are national or regional. No authentication required. Covers 100+ countries. Useful for business calendar planning, date calculations, and international scheduling.",
    "parameter": {
      "type": "object",
      "properties": {
        "year": {
          "type": "integer",
          "description": "Year to get holidays for. Examples: 2024, 2025, 2026"
        },
        "countryCode": {
          "type": "string",
          "description": "ISO 3166-1 alpha-2 country code. Examples: 'US' (USA), 'GB' (UK), 'DE' (Germany), 'FR' (France), 'JP' (Japan), 'AU' (Australia), 'CA' (Canada)"
        }
      },
      "required": ["year", "countryCode"]
    },
    "fields": {
      "endpoint": "https://date.nager.at/api/v3/PublicHolidays/{year}/{countryCode}",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"year": 2024, "countryCode": "US"},
      {"year": 2024, "countryCode": "DE"},
      {"year": 2025, "countryCode": "JP"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "array",
              "description": "List of public holidays for the country and year",
              "items": {
                "type": "object",
                "properties": {
                  "date": {"type": "string", "description": "Holiday date in ISO format (YYYY-MM-DD)"},
                  "localName": {"type": "string", "description": "Holiday name in local language"},
                  "name": {"type": "string", "description": "Holiday name in English"},
                  "countryCode": {"type": "string"},
                  "fixed": {"type": "boolean", "description": "Whether it is on the same date each year"},
                  "global": {"type": "boolean", "description": "Whether it applies nationwide"},
                  "counties": {"type": ["array", "null"], "items": {"type": "string"}, "description": "State/region codes if not nationwide"},
                  "launchYear": {"type": ["integer", "null"]},
                  "types": {"type": "array", "items": {"type": "string"}, "description": "Types: Public, Bank, School, Optional, Authorities, Observance"}
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "PublicHolidays_check_is_holiday",
    "description": "Check if a specific date is a public holiday in a given country using the Nager.Date API. Returns whether today or a specific date is a public holiday. No authentication required. Useful for business logic, date validation, and scheduling applications.",
    "parameter": {
      "type": "object",
      "properties": {
        "date": {
          "type": "string",
          "description": "Date to check in ISO format (YYYY-MM-DD). Examples: '2024-12-25', '2024-07-04', '2025-01-01'"
        },
        "countryCode": {
          "type": "string",
          "description": "ISO 3166-1 alpha-2 country code. Examples: 'US', 'GB', 'DE', 'FR', 'JP'"
        }
      },
      "required": ["date", "countryCode"]
    },
    "fields": {
      "endpoint": "https://date.nager.at/api/v3/IsTodayPublicHoliday/{countryCode}",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"date": "2024-12-25", "countryCode": "US"},
      {"date": "2024-07-04", "countryCode": "US"},
      {"date": "2024-12-25", "countryCode": "DE"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Holiday check result",
              "properties": {
                "is_holiday": {"type": "boolean", "description": "Whether the date is a public holiday (HTTP 200 = yes, 204 = no)"}
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
