[
  {
    "name": "NOAASpaceWeather_get_solar_cycle",
    "description": "Get predicted solar cycle data from NOAA Space Weather Prediction Center (SWPC). Returns monthly sunspot number (SSN) and radio flux (F10.7) predictions for the current solar cycle with high/low uncertainty bounds. Solar cycles last ~11 years and affect space weather, satellite drag, radio propagation, and aurora activity. Currently in Solar Cycle 25 which started in December 2019.",
    "parameter": {
      "type": "object",
      "properties": {},
      "required": []
    },
    "fields": {
      "endpoint": "https://services.swpc.noaa.gov/json/solar-cycle/predicted-solar-cycle.json"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {},
      {},
      {}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "array",
              "description": "Monthly solar cycle predictions",
              "items": {
                "type": "object",
                "properties": {
                  "time-tag": {"type": "string", "description": "Year-month (e.g., '2024-06')"},
                  "predicted_ssn": {"type": "number", "description": "Predicted smoothed sunspot number"},
                  "high25_ssn": {"type": ["number", "null"]},
                  "high_ssn": {"type": ["number", "null"], "description": "High scenario sunspot number"},
                  "low_ssn": {"type": ["number", "null"], "description": "Low scenario sunspot number"},
                  "predicted_f10.7": {"type": "number", "description": "Predicted F10.7 solar radio flux (10.7 cm, sfu)"},
                  "high_f10.7": {"type": ["number", "null"]},
                  "low_f10.7": {"type": ["number", "null"]}
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "NOAASpaceWeather_get_kp_index",
    "description": "Get real-time planetary geomagnetic Kp index data from NOAA SWPC. The Kp index (0-9 scale) measures global geomagnetic activity caused by solar wind. Kp>=5 = geomagnetic storm, Kp>=7 = strong storm (aurora visible at mid-latitudes), Kp>=9 = extreme storm. Updated every minute. Essential for aurora forecasting, satellite operations, radio communications, and space weather research.",
    "parameter": {
      "type": "object",
      "properties": {},
      "required": []
    },
    "fields": {
      "endpoint": "https://services.swpc.noaa.gov/json/planetary_k_index_1m.json"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {},
      {},
      {}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "array",
              "description": "Kp index records (1-minute cadence, last few days)",
              "items": {
                "type": "object",
                "properties": {
                  "time_tag": {"type": "string", "description": "UTC timestamp (YYYY-MM-DDTHH:mm:00.000Z)"},
                  "kp_index": {"type": ["number", "null"], "description": "Official NOAA Kp index (0-9 scale, 3-hour estimate)"},
                  "estimated_kp": {"type": "number", "description": "Real-time estimated Kp (1-minute resolution)"},
                  "kp": {"type": ["string", "null"]}
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "NOAASpaceWeather_get_solar_xrays",
    "description": "Get recent solar X-ray flux measurements from NOAA GOES satellite (last 7 days). X-ray flux is used to classify solar flares: A<10^-8, B 10^-7, C 10^-6, M 10^-5, X>10^-4 W/m^2. X-class flares are the most intense and can cause radio blackouts. Updated every minute. Essential for space weather monitoring, radio propagation studies, and solar physics research.",
    "parameter": {
      "type": "object",
      "properties": {},
      "required": []
    },
    "fields": {
      "endpoint": "https://services.swpc.noaa.gov/json/goes/secondary/xrays-7-day.json"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {},
      {},
      {}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "array",
              "description": "Solar X-ray flux records (1-minute cadence, 7-day history)",
              "items": {
                "type": "object",
                "properties": {
                  "time_tag": {"type": "string", "description": "UTC timestamp"},
                  "satellite": {"type": "integer", "description": "GOES satellite number"},
                  "flux": {"type": ["number", "null"], "description": "X-ray flux W/m^2 (short wavelength 0.1-0.8 nm)"},
                  "observed_flux": {"type": ["number", "null"]},
                  "energy": {"type": "string", "description": "Energy band: '0.05-0.4nm' (hard) or '0.1-0.8nm' (soft)"}
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
