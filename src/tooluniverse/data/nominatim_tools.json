[
  {
    "name": "Nominatim_geocode",
    "description": "Geocode a location name or address into geographic coordinates using OpenStreetMap Nominatim. Returns latitude, longitude, bounding box, place type, and display name for matching locations. Supports free-text search for cities, addresses, landmarks, and regions worldwide. Results include OSM type, place ID, and importance score.",
    "parameter": {
      "type": "object",
      "properties": {
        "q": {
          "type": "string",
          "description": "Free-form location query. Examples: 'London', 'Eiffel Tower, Paris', '10 Downing Street, London', 'Central Park, New York'"
        },
        "limit": {
          "type": ["integer", "null"],
          "description": "Maximum number of results to return (default 5, max 50)"
        },
        "countrycodes": {
          "type": ["string", "null"],
          "description": "Limit results to specific countries using ISO 3166-1alpha2 codes (comma-separated, e.g., 'us,gb,de')"
        },
        "language": {
          "type": ["string", "null"],
          "description": "Preferred language for result display names (e.g., 'en', 'fr', 'de')"
        }
      },
      "required": ["q"]
    },
    "fields": {
      "endpoint": "https://nominatim.openstreetmap.org/search",
      "params": {
        "format": "json",
        "addressdetails": "1"
      },
      "headers": {
        "User-Agent": "ToolUniverse/1.0 (scientific research tool)"
      }
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"q": "London"},
      {"q": "Eiffel Tower, Paris", "limit": 3},
      {"q": "Tokyo, Japan", "limit": 2, "language": "en"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "array",
              "description": "List of geocoding results matching the query",
              "items": {
                "type": "object",
                "properties": {
                  "place_id": {"type": "integer", "description": "Unique OSM place identifier"},
                  "osm_type": {"type": "string", "description": "OSM object type: 'node', 'way', or 'relation'"},
                  "osm_id": {"type": "integer"},
                  "lat": {"type": "string", "description": "Latitude as string (e.g., '51.5074')"},
                  "lon": {"type": "string", "description": "Longitude as string (e.g., '-0.1278')"},
                  "display_name": {"type": "string", "description": "Full human-readable address"},
                  "class": {"type": "string", "description": "OSM object class (e.g., 'place', 'boundary')"},
                  "type": {"type": "string", "description": "OSM object type (e.g., 'city', 'administrative')"},
                  "importance": {"type": "number", "description": "Result relevance score (0-1)"},
                  "boundingbox": {
                    "type": "array",
                    "description": "Bounding box [min_lat, max_lat, min_lon, max_lon]",
                    "items": {"type": "string"}
                  },
                  "address": {
                    "type": "object",
                    "description": "Structured address components",
                    "properties": {
                      "city": {"type": ["string", "null"]},
                      "country": {"type": ["string", "null"]},
                      "country_code": {"type": ["string", "null"]},
                      "state": {"type": ["string", "null"]},
                      "postcode": {"type": ["string", "null"]}
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "Nominatim_reverse_geocode",
    "description": "Reverse geocode geographic coordinates (latitude/longitude) into a human-readable address using OpenStreetMap Nominatim. Returns the full address, place name, OSM type, and structured address components for a given point on the map. Useful for converting GPS coordinates to location names.",
    "parameter": {
      "type": "object",
      "properties": {
        "lat": {
          "type": "number",
          "description": "Latitude in decimal degrees (e.g., 51.5074 for London, 48.8584 for Paris)"
        },
        "lon": {
          "type": "number",
          "description": "Longitude in decimal degrees (e.g., -0.1278 for London, 2.2945 for Paris)"
        },
        "zoom": {
          "type": ["integer", "null"],
          "description": "Level of detail for result: 3=country, 8=state, 10=city, 14=suburb, 16=street, 18=building (default 18)"
        }
      },
      "required": ["lat", "lon"]
    },
    "fields": {
      "endpoint": "https://nominatim.openstreetmap.org/reverse",
      "params": {
        "format": "json",
        "addressdetails": "1"
      },
      "headers": {
        "User-Agent": "ToolUniverse/1.0 (scientific research tool)"
      }
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"lat": 51.5074, "lon": -0.1278},
      {"lat": 48.8584, "lon": 2.2945, "zoom": 14},
      {"lat": 40.7484, "lon": -73.9967, "zoom": 16}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Reverse geocoding result for the given coordinates",
              "properties": {
                "place_id": {"type": "integer"},
                "osm_type": {"type": "string"},
                "osm_id": {"type": "integer"},
                "lat": {"type": "string"},
                "lon": {"type": "string"},
                "display_name": {"type": "string", "description": "Full human-readable address string"},
                "address": {
                  "type": "object",
                  "description": "Structured address components",
                  "properties": {
                    "road": {"type": ["string", "null"]},
                    "suburb": {"type": ["string", "null"]},
                    "city": {"type": ["string", "null"]},
                    "state": {"type": ["string", "null"]},
                    "country": {"type": ["string", "null"]},
                    "country_code": {"type": ["string", "null"]},
                    "postcode": {"type": ["string", "null"]}
                  }
                },
                "boundingbox": {"type": "array", "items": {"type": "string"}}
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "Nominatim_get_details",
    "description": "Get detailed information about a specific OpenStreetMap place by its OSM type and ID. Returns comprehensive data including local and international name translations, address hierarchy, linked places, and administrative details. The OSM type (N=node, W=way, R=relation) and OSM ID can be obtained from geocoding results or directly from OpenStreetMap. Provides much richer data than geocoding, including all name translations, parent administrative units, and Wikipedia/Wikidata links.",
    "parameter": {
      "type": "object",
      "properties": {
        "osmtype": {
          "type": "string",
          "description": "OSM object type: 'N' (node), 'W' (way), or 'R' (relation)"
        },
        "osmid": {
          "type": "integer",
          "description": "OSM object ID (e.g., 240109189 for Berlin, 65606 for London relation)"
        },
        "addressdetails": {
          "type": ["integer", "null"],
          "description": "Include address hierarchy: 1=yes, 0=no (default 0)"
        },
        "linkedplaces": {
          "type": ["integer", "null"],
          "description": "Include linked places: 1=yes, 0=no (default 1)"
        },
        "accept-language": {
          "type": ["string", "null"],
          "description": "Preferred language for response names (e.g., 'en', 'de', 'fr')"
        }
      },
      "required": ["osmtype", "osmid"]
    },
    "fields": {
      "endpoint": "https://nominatim.openstreetmap.org/details",
      "params": {
        "format": "json"
      },
      "headers": {
        "User-Agent": "ToolUniverse/1.0 (scientific research tool)"
      }
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"osmtype": "N", "osmid": 240109189},
      {"osmtype": "R", "osmid": 65606, "addressdetails": 1},
      {"osmtype": "R", "osmid": 62422, "addressdetails": 1}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Detailed information about the OSM place",
              "properties": {
                "place_id": {"type": "integer", "description": "Nominatim internal place ID"},
                "osm_type": {"type": "string", "description": "OSM type (N/W/R)"},
                "osm_id": {"type": "integer", "description": "OSM object ID"},
                "category": {"type": "string", "description": "OSM feature category (place, boundary, amenity)"},
                "type": {"type": "string", "description": "OSM feature type (city, administrative, restaurant)"},
                "admin_level": {"type": ["integer", "null"], "description": "Administrative level (2=country, 4=state, 6=county, 8=city)"},
                "localname": {"type": ["string", "null"], "description": "Primary local name of the place"},
                "names": {
                  "type": "object",
                  "description": "All name translations (name:en, name:de, name:fr, etc.)"
                },
                "addresstags": {
                  "type": "object",
                  "description": "Address-related tags (city, postcode, street, etc.)"
                },
                "extratags": {
                  "type": "object",
                  "description": "Extra tags including wikipedia, wikidata, population, website"
                },
                "calculated_importance": {"type": ["number", "null"], "description": "Calculated importance score"},
                "geometry": {
                  "type": "object",
                  "description": "GeoJSON geometry of the place"
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
