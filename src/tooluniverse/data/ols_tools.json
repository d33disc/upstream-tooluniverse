[
  {
    "type": "OLSTool",
    "name": "ols_search_terms",
    "description": "Search biomedical ontology terms in EBI's Ontology Lookup Service (OLS). Covers GO, HP, MONDO, EFO, and 200+ ontologies. Returns term labels, IRIs, synonyms, and definitions.",
    "parameter": {
      "type": "object",
      "properties": {
        "operation": {
          "type": "string",
          "const": "search_terms",
          "description": "The operation to perform (search_terms)"
        },
        "query": {
          "type": "string",
          "description": "The search query for terms"
        },
        "rows": {
          "type": "integer",
          "description": "Number of results to return (default: 10). Alias: size.",
          "default": 10
        },
        "size": {
          "type": "integer",
          "description": "Alias for rows. Number of results to return (default: 10).",
          "default": 10
        },
        "ontology": {
          "type": "string",
          "description": "Filter by specific ontology (optional)"
        },
        "exact_match": {
          "type": "boolean",
          "description": "Search for exact matches only (default: false)",
          "default": false
        },
        "include_obsolete": {
          "type": "boolean",
          "description": "Include obsolete terms (default: false)",
          "default": false
        },
        "limit": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Alias for rows. Maximum number of results to return (default: 10, max: 100)."
        }
      },
      "required": [
        "query"
      ]
    },
    "examples": [
      {
        "description": "Search for disease terms",
        "arguments": {
          "operation": "search_terms",
          "query": "diabetes",
          "rows": 10
        }
      },
      {
        "description": "Search for exact term in specific ontology",
        "arguments": {
          "operation": "search_terms",
          "query": "cancer",
          "ontology": "efo",
          "exact_match": true
        }
      }
    ],
    "tags": [
      "ontology",
      "search",
      "ebi",
      "ols"
    ],
    "author": "EBI OLS",
    "version": "1.0.0",
    "test_examples": [
      {
        "query": "apoptosis",
        "rows": 5,
        "ontology": "go",
        "exact_match": false,
        "include_obsolete": false
      },
      {
        "query": "breast cancer",
        "rows": 5,
        "ontology": "mondo",
        "exact_match": false
      }
    ],
    "return_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "description": "Response status (success or error)"
        },
        "terms": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "iri": {
                "type": "string",
                "description": "Internationalized Resource Identifier for the term"
              },
              "ontologyName": {
                "type": "string",
                "description": "Name of the ontology containing this term"
              },
              "shortForm": {
                "type": "string",
                "description": "Short form identifier (e.g. GO_0006915)"
              },
              "label": {
                "type": "string",
                "description": "Human-readable term label"
              },
              "oboId": {
                "type": "string",
                "description": "OBO-format identifier (e.g. GO:0006915)"
              },
              "isObsolete": {
                "type": "boolean",
                "description": "Whether the term is obsolete"
              }
            }
          },
          "description": "Array of matching ontology terms"
        },
        "total_items": {
          "type": "integer",
          "description": "Total number of matching terms"
        },
        "showing": {
          "type": "integer",
          "description": "Number of terms returned in this response"
        },
        "query": {
          "type": "string",
          "description": "The search query used"
        },
        "filters": {
          "type": "object",
          "properties": {
            "ontology": {
              "type": "string",
              "description": "Ontology filter applied"
            },
            "exact_match": {
              "type": "boolean",
              "description": "Whether exact matching was used"
            },
            "include_obsolete": {
              "type": "boolean",
              "description": "Whether obsolete terms were included"
            }
          },
          "description": "Filters applied to the search"
        }
      }
    }
  },
  {
    "type": "OLSTool",
    "name": "ols_get_ontology_info",
    "description": "Get metadata for a biomedical ontology in EBI OLS by ontology ID (e.g., 'hp', 'go', 'mondo'). Returns title, description, number of terms, homepage, and preferred prefix.",
    "parameter": {
      "type": "object",
      "properties": {
        "operation": {
          "type": "string",
          "const": "get_ontology_info",
          "description": "The operation to perform (get_ontology_info)"
        },
        "ontology_id": {
          "type": "string",
          "description": "The ID of the ontology to retrieve"
        },
        "ontology": {
          "type": "string",
          "description": "Alias for ontology_id. The ontology abbreviation (e.g. mondo, hp, go, ordo)."
        }
      },
      "required": []
    },
    "examples": [
      {
        "description": "Get information about the EFO ontology",
        "arguments": {
          "operation": "get_ontology_info",
          "ontology_id": "efo"
        }
      }
    ],
    "tags": [
      "ontology",
      "metadata",
      "ebi",
      "ols"
    ],
    "author": "EBI OLS",
    "version": "1.0.0",
    "test_examples": [
      {
        "ontology_id": "efo"
      },
      {
        "ontology_id": "hp"
      }
    ],
    "return_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "description": "Response status (success or error)"
        },
        "ontologyId": {
          "type": "string",
          "description": "Ontology identifier"
        },
        "title": {
          "type": "string",
          "description": "Full title of the ontology"
        },
        "version": {
          "type": [
            "string",
            "null"
          ],
          "description": "Ontology version"
        },
        "description": {
          "type": "string",
          "description": "Description of the ontology"
        },
        "domain": {
          "type": [
            "string",
            "null"
          ],
          "description": "Domain of the ontology"
        },
        "homepage": {
          "type": "string",
          "description": "Homepage URL"
        },
        "preferredPrefix": {
          "type": "string",
          "description": "Preferred namespace prefix"
        },
        "number_of_terms": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Number of terms in the ontology"
        },
        "numberOfClasses": {
          "type": "integer",
          "description": "Number of classes in the ontology"
        },
        "repository": {
          "type": [
            "string",
            "null"
          ],
          "description": "Source repository URL"
        }
      }
    }
  },
  {
    "type": "OLSTool",
    "name": "ols_search_ontologies",
    "description": "Browse and search available ontologies in EBI OLS. Returns ontology metadata including IDs, titles, and descriptions. Supports keyword filtering and pagination.",
    "parameter": {
      "type": "object",
      "properties": {
        "operation": {
          "type": "string",
          "const": "search_ontologies",
          "description": "The operation to perform (search_ontologies)"
        },
        "search": {
          "type": "string",
          "description": "Search query for ontologies (optional)"
        },
        "page": {
          "type": "integer",
          "description": "Page number (default: 0)",
          "default": 0
        },
        "size": {
          "type": "integer",
          "description": "Number of results per page (default: 20)",
          "default": 20
        }
      },
      "required": []
    },
    "examples": [
      {
        "description": "Search all ontologies",
        "arguments": {
          "operation": "search_ontologies"
        }
      },
      {
        "description": "Search for disease-related ontologies",
        "arguments": {
          "operation": "search_ontologies",
          "search": "disease",
          "size": 10
        }
      }
    ],
    "tags": [
      "ontology",
      "search",
      "ebi",
      "ols"
    ],
    "author": "EBI OLS",
    "version": "1.0.0",
    "test_examples": [
      {
        "search": "cancer",
        "page": 0,
        "size": 5
      },
      {
        "search": "phenotype",
        "page": 0,
        "size": 5
      }
    ],
    "return_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "description": "Response status (success or error)"
        },
        "results": {
          "type": "array",
          "items": {
            "type": "object"
          },
          "description": "Array of matching ontologies"
        },
        "pagination": {
          "type": "object",
          "properties": {
            "page": {
              "type": "integer",
              "description": "Current page number"
            },
            "size": {
              "type": "integer",
              "description": "Page size"
            },
            "total_pages": {
              "type": "integer",
              "description": "Total number of pages"
            },
            "total_items": {
              "type": "integer",
              "description": "Total matching ontologies"
            }
          },
          "description": "Pagination metadata"
        },
        "search": {
          "type": "string",
          "description": "The search query used"
        }
      }
    }
  },
  {
    "type": "OLSTool",
    "name": "ols_get_term_info",
    "description": "Get detailed information about a specific ontology term in EBI OLS by term ID or IRI. Returns label, definition, synonyms, and ontology membership. Supports HP, GO, EFO, MONDO IDs.",
    "parameter": {
      "type": "object",
      "properties": {
        "operation": {
          "type": "string",
          "const": "get_term_info",
          "description": "The operation to perform (get_term_info)"
        },
        "id": {
          "type": "string",
          "description": "Ontology term ID or IRI (e.g. HP:0001903, http://purl.obolibrary.org/obo/HP_0001903)"
        },
        "term_id": {
          "type": "string",
          "description": "Alias for id \u2014 ontology term ID (e.g. HP:0001903)"
        },
        "term_iri": {
          "type": "string",
          "description": "Alias for id. Full IRI or short-form ID (e.g., GO:0008150, EFO:0003971). Same as id."
        }
      },
      "required": []
    },
    "examples": [
      {
        "description": "Get term information by ID",
        "arguments": {
          "operation": "get_term_info",
          "id": "EFO:0000408"
        }
      }
    ],
    "tags": [
      "ontology",
      "term",
      "metadata",
      "ebi",
      "ols"
    ],
    "author": "EBI OLS",
    "version": "1.0.0",
    "test_examples": [
      {
        "id": "HP:0001903"
      },
      {
        "id": "GO:0006915"
      }
    ],
    "return_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "description": "Response status (success or error)"
        },
        "iri": {
          "type": "string",
          "description": "Internationalized Resource Identifier for the term"
        },
        "ontologyName": {
          "type": "string",
          "description": "Name of the ontology containing this term"
        },
        "shortForm": {
          "type": "string",
          "description": "Short form identifier"
        },
        "label": {
          "type": "string",
          "description": "Human-readable term label"
        },
        "oboId": {
          "type": "string",
          "description": "OBO-format identifier"
        },
        "isObsolete": {
          "type": "boolean",
          "description": "Whether the term is obsolete"
        },
        "description": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Term descriptions"
        },
        "synonyms": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Alternative names for the term"
        }
      }
    }
  },
  {
    "type": "OLSTool",
    "name": "ols_get_term_children",
    "description": "Get child terms of a specific term in an ontology. Use `term_id` with CURIE format (e.g., 'HP:0001928') \u2014 the ontology is auto-inferred from the prefix. Or supply `term_iri` + `ontology` explicitly.",
    "parameter": {
      "type": "object",
      "properties": {
        "operation": {
          "type": "string",
          "const": "get_term_children",
          "description": "The operation to perform (get_term_children)"
        },
        "term_iri": {
          "type": "string",
          "description": "The full IRI of the term (e.g., http://www.ebi.ac.uk/efo/EFO_0000408)"
        },
        "term_id": {
          "type": "string",
          "description": "Short-form CURIE (e.g., 'HP:0001928', 'GO:0008150'). Ontology is auto-inferred from prefix."
        },
        "ontology": {
          "type": "string",
          "description": "Ontology ID (e.g., 'hp', 'go', 'efo'). Auto-inferred from term_id prefix when not supplied."
        },
        "include_obsolete": {
          "type": "boolean",
          "description": "Include obsolete terms (default: false)",
          "default": false
        },
        "size": {
          "type": "integer",
          "description": "Number of results to return (default: 20)",
          "default": 20
        }
      },
      "required": []
    },
    "examples": [
      {
        "description": "Get child terms",
        "arguments": {
          "operation": "get_term_children",
          "term_iri": "http://www.ebi.ac.uk/efo/EFO_0000408",
          "ontology": "efo",
          "size": 10
        }
      }
    ],
    "tags": [
      "ontology",
      "hierarchy",
      "term",
      "ebi",
      "ols"
    ],
    "author": "EBI OLS",
    "version": "1.0.0",
    "test_examples": [
      {
        "term_iri": "http://www.ebi.ac.uk/efo/EFO_0000384",
        "ontology": "efo",
        "include_obsolete": false,
        "size": 10
      },
      {
        "term_id": "HP:0000118",
        "size": 10
      }
    ],
    "return_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "description": "Response status (success or error)"
        },
        "page": {
          "type": "integer",
          "description": "Current page number"
        },
        "numElements": {
          "type": "integer",
          "description": "Number of elements on this page"
        },
        "totalPages": {
          "type": "integer",
          "description": "Total number of pages"
        },
        "totalElements": {
          "type": "integer",
          "description": "Total number of child terms"
        },
        "elements": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "iri": {
                "type": "string",
                "description": "Term IRI"
              },
              "label": {
                "type": "string",
                "description": "Term label"
              },
              "shortForm": {
                "type": "string",
                "description": "Short form identifier"
              },
              "oboId": {
                "type": "string",
                "description": "OBO-format identifier"
              },
              "isObsolete": {
                "type": "boolean",
                "description": "Whether the term is obsolete"
              }
            }
          },
          "description": "Array of child terms"
        },
        "term_iri": {
          "type": "string",
          "description": "IRI of the parent term"
        },
        "ontology": {
          "type": "string",
          "description": "Ontology queried"
        },
        "filters": {
          "type": "object",
          "properties": {
            "include_obsolete": {
              "type": "boolean",
              "description": "Whether obsolete terms were included"
            }
          },
          "description": "Filters applied"
        }
      }
    }
  },
