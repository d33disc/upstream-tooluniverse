  {
    "type": "OLSTool",
    "name": "ols_find_similar_terms",
    "description": "Find semantically similar ontology terms in EBI OLS using LLM-based embedding similarity. Returns related terms from the same ontology. Useful for ontology mapping and term disambiguation.",
    "parameter": {
      "type": "object",
      "properties": {
        "operation": {
          "type": "string",
          "const": "find_similar_terms",
          "description": "The operation to perform (find_similar_terms)"
        },
        "term_iri": {
          "type": "string",
          "description": "The IRI of the term to find similar terms for"
        },
        "ontology": {
          "type": "string",
          "description": "The ontology ID"
        },
        "size": {
          "type": "integer",
          "description": "Number of similar terms to return (default: 10)",
          "default": 10
        },
        "term_id": {
          "type": "string",
          "description": "Alias for term_iri. Short-form ontology ID (e.g., GO:0008150) or full IRI."
        }
      },
      "required": [
        "ontology"
      ]
    },
    "examples": [
      {
        "description": "Find similar terms using LLM",
        "arguments": {
          "operation": "find_similar_terms",
          "term_iri": "http://www.ebi.ac.uk/efo/EFO_0000408",
          "ontology": "efo",
          "size": 5
        }
      }
    ],
    "tags": [
      "ontology",
      "similarity",
      "llm",
      "ebi",
      "ols"
    ],
    "author": "EBI OLS",
    "version": "1.0.0",
    "test_examples": [
      {
        "term_iri": "http://www.ebi.ac.uk/efo/EFO_0000384",
        "ontology": "efo",
        "size": 5
      },
      {
        "term_id": "MONDO:0005015",
        "ontology": "mondo",
        "size": 5
      }
    ],
    "return_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "description": "Success or error status"
        },
        "term_iri": {
          "type": "string",
          "description": "IRI of the query term"
        },
        "source_label": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Labels of the source term"
        },
        "ontology": {
          "type": "string",
          "description": "Ontology searched"
        },
        "similar_terms": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "iri": {
                "type": "string",
                "description": "IRI of the similar term"
              },
              "ontology_name": {
                "type": "string",
                "description": "Ontology name"
              },
              "ontology_prefix": {
                "type": "string",
                "description": "Ontology prefix"
              },
              "short_form": {
                "type": "string",
                "description": "Short form identifier"
              },
              "description": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Term descriptions"
              },
              "label": {
                "type": "string",
                "description": "Human-readable label"
              },
              "obo_id": {
                "type": "string",
                "description": "OBO identifier"
              },
              "type": {
                "type": "string",
                "description": "Term type (e.g. class)"
              },
              "exact_synonyms": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Exact synonym list"
              }
            }
          },
          "description": "List of similar terms found"
        },
        "total": {
          "type": "integer",
          "description": "Total number of similar terms found"
        },
        "note": {
          "type": "string",
          "description": "Additional information about the search method"
        }
      }
    }
  }
