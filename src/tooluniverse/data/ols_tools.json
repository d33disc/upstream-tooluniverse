[
  {
    "type": "OLSTool",
    "name": "ols_search_terms",
    "description": "Search biomedical ontology terms in EBI's Ontology Lookup Service (OLS). Covers GO, HP, MONDO, EFO, and 200+ ontologies. Returns term labels, IRIs, synonyms, and definitions.",
    "parameter": {
      "type": "object",
      "properties": {
        "operation": {
          "type": "string",
          "const": "search_terms",
          "description": "The operation to perform (search_terms)"
        },
        "query": {
          "type": "string",
          "description": "The search query for terms"
        },
        "rows": {
          "type": "integer",
          "description": "Number of results to return (default: 10). Alias: size.",
          "default": 10
        },
        "size": {
          "type": "integer",
          "description": "Alias for rows. Number of results to return (default: 10).",
          "default": 10
        },
        "ontology": {
          "type": "string",
          "description": "Filter by specific ontology (optional)"
        },
        "exact_match": {
          "type": "boolean",
          "description": "Search for exact matches only (default: false)",
          "default": false
        },
        "include_obsolete": {
          "type": "boolean",
          "description": "Include obsolete terms (default: false)",
          "default": false
        },
        "limit": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Alias for rows. Maximum number of results to return (default: 10, max: 100)."
        }
      },
      "required": [
        "query"
      ]
    },
    "examples": [
      {
        "description": "Search for disease terms",
        "arguments": {
          "operation": "search_terms",
          "query": "diabetes",
          "rows": 10
        }
      },
      {
        "description": "Search for exact term in specific ontology",
        "arguments": {
          "operation": "search_terms",
          "query": "cancer",
          "ontology": "efo",
          "exact_match": true
        }
      }
    ],
    "tags": [
      "ontology",
      "search",
      "ebi",
      "ols"
    ],
    "author": "EBI OLS",
    "version": "1.0.0",
    "test_examples": [
      {
        "query": "apoptosis",
        "rows": 5,
        "ontology": "go",
        "exact_match": false,
        "include_obsolete": false
      },
      {
        "query": "breast cancer",
        "rows": 5,
        "ontology": "mondo",
        "exact_match": false
      }
    ]
  },
  {
    "type": "OLSTool",
    "name": "ols_get_ontology_info",
    "description": "Get metadata for a biomedical ontology in EBI OLS by ontology ID (e.g., 'hp', 'go', 'mondo'). Returns title, description, number of terms, homepage, and preferred prefix.",
    "parameter": {
      "type": "object",
      "properties": {
        "operation": {
          "type": "string",
          "const": "get_ontology_info",
          "description": "The operation to perform (get_ontology_info)"
        },
        "ontology_id": {
          "type": "string",
          "description": "The ID of the ontology to retrieve"
        },
        "ontology": {
          "type": "string",
          "description": "Alias for ontology_id. The ontology abbreviation (e.g. mondo, hp, go, ordo)."
        }
      },
      "required": []
    },
    "examples": [
      {
        "description": "Get information about the EFO ontology",
        "arguments": {
          "operation": "get_ontology_info",
          "ontology_id": "efo"
        }
      }
    ],
    "tags": [
      "ontology",
      "metadata",
      "ebi",
      "ols"
    ],
    "author": "EBI OLS",
    "version": "1.0.0",
    "test_examples": [
      {
        "ontology_id": "efo"
      },
      {
        "ontology_id": "hp"
      }
    ]
  },
  {
    "type": "OLSTool",
    "name": "ols_search_ontologies",
    "description": "Browse and search available ontologies in EBI OLS. Returns ontology metadata including IDs, titles, and descriptions. Supports keyword filtering and pagination.",
    "parameter": {
      "type": "object",
      "properties": {
        "operation": {
          "type": "string",
          "const": "search_ontologies",
          "description": "The operation to perform (search_ontologies)"
        },
        "search": {
          "type": "string",
          "description": "Search query for ontologies (optional)"
        },
        "page": {
          "type": "integer",
          "description": "Page number (default: 0)",
          "default": 0
        },
        "size": {
          "type": "integer",
          "description": "Number of results per page (default: 20)",
          "default": 20
        }
      },
      "required": []
    },
    "examples": [
      {
        "description": "Search all ontologies",
        "arguments": {
          "operation": "search_ontologies"
        }
      },
      {
        "description": "Search for disease-related ontologies",
        "arguments": {
          "operation": "search_ontologies",
          "search": "disease",
          "size": 10
        }
      }
    ],
    "tags": [
      "ontology",
      "search",
      "ebi",
      "ols"
    ],
    "author": "EBI OLS",
    "version": "1.0.0",
    "test_examples": [
      {
        "search": "cancer",
        "page": 0,
        "size": 5
      },
      {
        "search": "phenotype",
        "page": 0,
        "size": 5
      }
    ]
  },
  {
    "type": "OLSTool",
    "name": "ols_get_term_info",
    "description": "Get detailed information about a specific ontology term in EBI OLS by term ID or IRI. Returns label, definition, synonyms, and ontology membership. Supports HP, GO, EFO, MONDO IDs.",
    "parameter": {
      "type": "object",
      "properties": {
        "operation": {
          "type": "string",
          "const": "get_term_info",
          "description": "The operation to perform (get_term_info)"
        },
        "id": {
          "type": "string",
          "description": "Ontology term ID or IRI (e.g. HP:0001903, http://purl.obolibrary.org/obo/HP_0001903)"
        },
        "term_id": {
          "type": "string",
          "description": "Alias for id \u2014 ontology term ID (e.g. HP:0001903)"
        },
        "term_iri": {
          "type": "string",
          "description": "Alias for id. Full IRI or short-form ID (e.g., GO:0008150, EFO:0003971). Same as id."
        }
      },
      "required": []
    },
    "examples": [
      {
        "description": "Get term information by ID",
        "arguments": {
          "operation": "get_term_info",
          "id": "EFO:0000408"
        }
      }
    ],
    "tags": [
      "ontology",
      "term",
      "metadata",
      "ebi",
      "ols"
    ],
    "author": "EBI OLS",
    "version": "1.0.0",
    "test_examples": [
      {
        "id": "HP:0001903"
      },
      {
        "id": "GO:0006915"
      }
    ]
  },
  {
    "type": "OLSTool",
    "name": "ols_get_term_children",
    "description": "Get child terms of a specific term in an ontology. Use `term_id` with CURIE format (e.g., 'HP:0001928') \u2014 the ontology is auto-inferred from the prefix. Or supply `term_iri` + `ontology` explicitly.",
    "parameter": {
      "type": "object",
      "properties": {
        "operation": {
          "type": "string",
          "const": "get_term_children",
          "description": "The operation to perform (get_term_children)"
        },
        "term_iri": {
          "type": "string",
          "description": "The full IRI of the term (e.g., http://www.ebi.ac.uk/efo/EFO_0000408)"
        },
        "term_id": {
          "type": "string",
          "description": "Short-form CURIE (e.g., 'HP:0001928', 'GO:0008150'). Ontology is auto-inferred from prefix."
        },
        "ontology": {
          "type": "string",
          "description": "Ontology ID (e.g., 'hp', 'go', 'efo'). Auto-inferred from term_id prefix when not supplied."
        },
        "include_obsolete": {
          "type": "boolean",
          "description": "Include obsolete terms (default: false)",
          "default": false
        },
        "size": {
          "type": "integer",
          "description": "Number of results to return (default: 20)",
          "default": 20
        }
      },
      "required": []
    },
    "examples": [
      {
        "description": "Get child terms",
        "arguments": {
          "operation": "get_term_children",
          "term_iri": "http://www.ebi.ac.uk/efo/EFO_0000408",
          "ontology": "efo",
          "size": 10
        }
      }
    ],
    "tags": [
      "ontology",
      "hierarchy",
      "term",
      "ebi",
      "ols"
    ],
    "author": "EBI OLS",
    "version": "1.0.0",
    "test_examples": [
      {
        "term_iri": "http://www.ebi.ac.uk/efo/EFO_0000384",
        "ontology": "efo",
        "include_obsolete": false,
        "size": 10
      },
      {
        "term_id": "HP:0000118",
        "size": 10
      }
    ]
  },
  {
    "type": "OLSTool",
    "name": "ols_get_term_ancestors",
    "description": "Get ancestor terms of a specific term in an ontology. Use `term_id` with CURIE format (e.g., 'HP:0001928') \u2014 the ontology is auto-inferred from the prefix. Or supply `term_iri` + `ontology` explicitly.",
    "parameter": {
      "type": "object",
      "properties": {
        "operation": {
          "type": "string",
          "const": "get_term_ancestors",
          "description": "The operation to perform (get_term_ancestors)"
        },
        "term_iri": {
          "type": "string",
          "description": "The full IRI of the term (e.g., http://www.ebi.ac.uk/efo/EFO_0000408)"
        },
        "term_id": {
          "type": "string",
          "description": "Short-form CURIE (e.g., 'HP:0001928', 'GO:0008150'). Ontology is auto-inferred from prefix."
        },
        "ontology": {
          "type": "string",
          "description": "Ontology ID (e.g., 'hp', 'go', 'efo'). Auto-inferred from term_id prefix when not supplied."
        },
        "include_obsolete": {
          "type": "boolean",
          "description": "Include obsolete terms (default: false)",
          "default": false
        },
        "size": {
          "type": "integer",
          "description": "Number of results to return (default: 20)",
          "default": 20
        }
      },
      "required": []
    },
    "examples": [
      {
        "description": "Get ancestor terms",
        "arguments": {
          "operation": "get_term_ancestors",
          "term_iri": "http://www.ebi.ac.uk/efo/EFO_0000408",
          "ontology": "efo"
        }
      }
    ],
    "tags": [
      "ontology",
      "hierarchy",
      "term",
      "ebi",
      "ols"
    ],
    "author": "EBI OLS",
    "version": "1.0.0",
    "test_examples": [
      {
        "term_iri": "http://www.ebi.ac.uk/efo/EFO_0000384",
        "ontology": "efo",
        "include_obsolete": false,
        "size": 10
      },
      {
        "term_id": "HP:0000118",
        "size": 10
      }
    ]
  },
  {
    "type": "OLSTool",
    "name": "ols_find_similar_terms",
    "description": "Find semantically similar ontology terms in EBI OLS using LLM-based embedding similarity. Returns related terms from the same ontology. Useful for ontology mapping and term disambiguation.",
    "parameter": {
      "type": "object",
      "properties": {
        "operation": {
          "type": "string",
          "const": "find_similar_terms",
          "description": "The operation to perform (find_similar_terms)"
        },
        "term_iri": {
          "type": "string",
          "description": "The IRI of the term to find similar terms for"
        },
        "ontology": {
          "type": "string",
          "description": "The ontology ID"
        },
        "size": {
          "type": "integer",
          "description": "Number of similar terms to return (default: 10)",
          "default": 10
        },
        "term_id": {
          "type": "string",
          "description": "Alias for term_iri. Short-form ontology ID (e.g., GO:0008150) or full IRI."
        }
      },
      "required": [
        "ontology"
      ]
    },
    "examples": [
      {
        "description": "Find similar terms using LLM",
        "arguments": {
          "operation": "find_similar_terms",
          "term_iri": "http://www.ebi.ac.uk/efo/EFO_0000408",
          "ontology": "efo",
          "size": 5
        }
      }
    ],
    "tags": [
      "ontology",
      "similarity",
      "llm",
      "ebi",
      "ols"
    ],
    "author": "EBI OLS",
    "version": "1.0.0",
    "test_examples": [
      {
        "term_iri": "http://www.ebi.ac.uk/efo/EFO_0000384",
        "ontology": "efo",
        "size": 5
      },
      {
        "term_id": "MONDO:0005015",
        "ontology": "mondo",
        "size": 5
      }
    ]
  }
]
