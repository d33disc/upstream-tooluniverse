[
  {
    "name": "OnThisDay_get_events",
    "description": "Get historical events, births, and deaths that occurred on a specific day in history using the byabbe.se On This Day API (via Wikipedia). Returns events with year, description, and Wikipedia links. No authentication required. Useful for historical research, trivia, timeline generation, and educational applications.",
    "parameter": {
      "type": "object",
      "properties": {
        "month": {
          "type": "integer",
          "description": "Month number (1-12). Examples: 1 (January), 7 (July), 12 (December)"
        },
        "day": {
          "type": "integer",
          "description": "Day of month (1-31). Examples: 1, 15, 25"
        },
        "type": {
          "type": ["string", "null"],
          "description": "Type of historical data. Values: 'events' (historical events), 'births' (notable births), 'deaths' (notable deaths). Default: events"
        }
      },
      "required": ["month", "day"]
    },
    "fields": {
      "endpoint": "https://byabbe.se/on-this-day/{month}/{day}/{type}.json",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"month": 7, "day": 20, "type": "events"},
      {"month": 1, "day": 15, "type": "births"},
      {"month": 11, "day": 11, "type": "events"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Historical events/births/deaths for the specified date",
              "properties": {
                "date": {"type": "string", "description": "Date in 'Month Day' format"},
                "wikipedia": {"type": "string", "description": "URL to Wikipedia page for this date"},
                "events": {
                  "type": "array",
                  "description": "List of events (if type=events)",
                  "items": {
                    "type": "object",
                    "properties": {
                      "year": {"type": "string", "description": "Year the event occurred"},
                      "description": {"type": "string", "description": "Brief description of the event"},
                      "wikipedia": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "title": {"type": "string"},
                            "wikipedia": {"type": "string", "description": "Wikipedia URL"}
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
