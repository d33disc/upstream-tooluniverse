[
  {
    "name": "OncoTree_search",
    "type": "OncoTreeSearchTool",
    "description": "Search the OncoTree cancer type ontology by name, code, main type, or tissue. OncoTree is a hierarchical cancer classification system developed at Memorial Sloan Kettering with 897+ cancer types. Returns standardized cancer type codes with UMLS and NCI Thesaurus cross-references. Use to identify the correct OncoTree code for a cancer type, find all cancer subtypes under a tissue, or map free-text cancer names to structured identifiers.",
    "parameter": {
      "type": "object",
      "properties": {
        "query": {
          "type": "string",
          "description": "Search term. Interpreted according to the 'field' parameter. Examples: 'breast cancer', 'BRCA', 'Lung', 'Non-Small Cell Lung Cancer'."
        },
        "field": {
          "type": "string",
          "description": "Field to search in. One of: 'name' (cancer type name), 'code' (OncoTree code), 'main_type' (main cancer category), 'tissue' (tissue of origin). Default: 'name'.",
          "enum": [
            "name",
            "code",
            "main_type",
            "tissue"
          ],
          "default": "name"
        },
        "exact_match": {
          "type": "boolean",
          "description": "If true, requires exact match. If false (default), performs substring/prefix matching.",
          "default": false
        },
        "version": {
          "type": "string",
          "description": "OncoTree version identifier. Use 'oncotree_latest_stable' (default) for the current production version.",
          "default": "oncotree_latest_stable"
        }
      },
      "required": [
        "query"
      ]
    },
    "test_examples": [
      {
        "query": "breast cancer",
        "field": "name"
      },
      {
        "query": "LUAD",
        "field": "code",
        "exact_match": true
      },
      {
        "query": "Lung",
        "field": "tissue"
      }
    ],
    "return_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "description": "Response status (e.g., 'success')"
        },
        "data": {
          "type": "array",
          "description": "Matching cancer types",
          "items": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string",
                "description": "OncoTree code (e.g., 'IBC', 'MBC')"
              },
              "name": {
                "type": "string",
                "description": "Cancer type name"
              },
              "main_type": {
                "type": "string",
                "description": "Main cancer category (e.g., 'Breast Cancer')"
              },
              "tissue": {
                "type": "string",
                "description": "Tissue of origin (e.g., 'Breast')"
              },
              "parent": {
                "type": "string",
                "description": "Parent node code in hierarchy"
              },
              "level": {
                "type": "integer",
                "description": "Hierarchy level (1=tissue, 2=main type, 3+=subtypes)"
              },
              "external_references": {
                "type": "object",
                "description": "Cross-references to UMLS and NCI Thesaurus",
                "properties": {
                  "UMLS": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "NCI": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "metadata": {
          "type": "object",
          "properties": {
            "query": { "type": "string", "description": "Original search query" },
            "field": { "type": "string", "description": "Field that was searched" },
            "exact_match": { "type": "boolean", "description": "Whether exact matching was used" },
            "count": { "type": "integer", "description": "Number of results" },
            "version": { "type": "string", "description": "OncoTree version used" }
          }
        }
      }
    },
    "label": [
      "OncoTree",
      "Cancer",
      "Oncology",
      "Classification"
    ],
    "metadata": {
      "tags": [
        "cancer",
        "oncology",
        "tumor type",
        "classification",
        "MSK",
        "UMLS",
        "NCI"
      ],
      "estimated_execution_time": "1-2 seconds"
    }
  },
  {
    "name": "OncoTree_get_type",
    "type": "OncoTreeGetTypeTool",
    "description": "Get detailed information about a specific OncoTree cancer type by its exact code (e.g. 'BRCA', 'LUAD', 'GBM'). Returns the cancer name, main type, tissue, parent node in the hierarchy, hierarchy level, color used in MSK visualizations, revision history, and cross-references to UMLS and NCI Thesaurus. Use after OncoTree_search to get complete details for a known code.",
    "parameter": {
      "type": "object",
      "properties": {
        "code": {
          "type": "string",
          "description": "OncoTree cancer type code (case-insensitive). Examples: 'BRCA' (Invasive Breast Carcinoma), 'LUAD' (Lung Adenocarcinoma), 'GBM' (Glioblastoma Multiforme), 'PAAD' (Pancreatic Adenocarcinoma)."
        },
        "version": {
          "type": "string",
          "description": "OncoTree version. Default: 'oncotree_latest_stable'.",
          "default": "oncotree_latest_stable"
        }
      },
      "required": [
        "code"
      ]
    },
    "test_examples": [
      {
        "code": "BRCA"
      },
      {
        "code": "LUAD"
      },
      {
        "code": "GBM"
      }
    ],
    "return_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "description": "Response status (e.g., 'success')"
        },
        "data": {
          "type": "object",
          "description": "Cancer type details",
          "properties": {
            "code": { "type": "string", "description": "OncoTree code" },
            "name": { "type": "string", "description": "Cancer type name" },
            "main_type": { "type": "string", "description": "Main cancer category" },
            "tissue": { "type": "string", "description": "Tissue of origin" },
            "color": { "type": "string", "description": "Color used in MSK visualizations" },
            "parent": { "type": "string", "description": "Parent node code" },
            "level": { "type": "integer", "description": "Hierarchy level" },
            "history": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Revision history entries"
            },
            "external_references": {
              "type": "object",
              "description": "Cross-references to UMLS and NCI Thesaurus",
              "properties": {
                "UMLS": { "type": "array", "items": { "type": "string" } },
                "NCI": { "type": "array", "items": { "type": "string" } }
              }
            }
          }
        },
        "metadata": {
          "type": "object",
          "properties": {
            "source": { "type": "string", "description": "Data source (e.g., 'OncoTree MSK')" },
            "version": { "type": "string", "description": "OncoTree version used" }
          }
        }
      }
    },
    "label": [
      "OncoTree",
      "Cancer",
      "Oncology",
      "Classification"
    ],
    "metadata": {
      "tags": [
        "cancer",
        "oncology",
        "tumor type",
        "code lookup",
        "MSK",
        "UMLS",
        "NCI"
      ],
      "estimated_execution_time": "1-2 seconds"
    }
  },
  {
    "name": "OncoTree_list_tissues",
    "type": "OncoTreeListTissuesTool",
    "description": "List all tissue categories in the OncoTree hierarchy. Returns the unique set of tissue/organ names used as top-level groupings (e.g. 'Breast', 'Lung', 'Brain/CNS', 'Bladder/Urinary Tract'). Use to discover what tissues are represented in OncoTree before searching by tissue, or to enumerate all supported cancer tissue origins.",
    "parameter": {
      "type": "object",
      "properties": {
        "version": {
          "type": "string",
          "description": "OncoTree version. Default: 'oncotree_latest_stable'.",
          "default": "oncotree_latest_stable"
        }
      }
    },
    "test_examples": [
      {},
      {}
    ],
    "label": [
      "OncoTree",
      "Cancer",
