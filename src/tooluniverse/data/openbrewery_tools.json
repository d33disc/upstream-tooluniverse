[
  {
    "name": "OpenBreweryDB_search_breweries",
    "description": "Search for breweries by city, state, country, type, or name using the Open Brewery DB API. Returns brewery details including address, coordinates, phone, website, and type (micro, brewpub, regional, etc.). Covers US and international breweries. No authentication required.",
    "parameter": {
      "type": "object",
      "properties": {
        "by_city": {
          "type": ["string", "null"],
          "description": "Filter by city name. Examples: 'seattle', 'portland', 'denver', 'london'"
        },
        "by_state": {
          "type": ["string", "null"],
          "description": "Filter by US state (full name or abbreviation). Examples: 'california', 'new york', 'texas'"
        },
        "by_country": {
          "type": ["string", "null"],
          "description": "Filter by country. Examples: 'united_states', 'england', 'south_korea'"
        },
        "by_name": {
          "type": ["string", "null"],
          "description": "Filter by brewery name. Examples: 'dog', 'sierra', 'stone'"
        },
        "by_type": {
          "type": ["string", "null"],
          "description": "Filter by brewery type. Values: 'micro', 'nano', 'regional', 'brewpub', 'large', 'planning', 'bar', 'contract', 'proprietor', 'closed'"
        },
        "per_page": {
          "type": ["integer", "null"],
          "description": "Number of results per page (max 200). Default: 50"
        }
      },
      "required": []
    },
    "fields": {
      "endpoint": "https://api.openbrewerydb.org/v1/breweries",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"by_city": "seattle", "per_page": 5},
      {"by_state": "colorado", "by_type": "micro", "per_page": 5},
      {"by_name": "dog", "per_page": 5}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "array",
              "description": "List of breweries matching the search criteria",
              "items": {
                "type": "object",
                "properties": {
                  "id": {"type": "string"},
                  "name": {"type": "string", "description": "Brewery name"},
                  "brewery_type": {"type": ["string", "null"], "description": "Type: micro, nano, brewpub, regional, large, etc."},
                  "address_1": {"type": ["string", "null"]},
                  "city": {"type": ["string", "null"]},
                  "state_province": {"type": ["string", "null"]},
                  "postal_code": {"type": ["string", "null"]},
                  "country": {"type": ["string", "null"]},
                  "latitude": {"type": ["number", "null"]},
                  "longitude": {"type": ["number", "null"]},
                  "phone": {"type": ["string", "null"]},
                  "website_url": {"type": ["string", "null"]}
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "OpenBreweryDB_get_random_brewery",
    "description": "Get one or more random breweries from the Open Brewery DB. Returns brewery details including name, address, type, coordinates, and website. No authentication required. Useful for discovery or sampling the brewery database.",
    "parameter": {
      "type": "object",
      "properties": {
        "size": {
          "type": ["integer", "null"],
          "description": "Number of random breweries to return (1-50). Default: 1"
        }
      },
      "required": []
    },
    "fields": {
      "endpoint": "https://api.openbrewerydb.org/v1/breweries/random",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"size": 1},
      {"size": 3},
      {}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "array",
              "description": "Random brewery entries",
              "items": {
                "type": "object",
                "properties": {
                  "id": {"type": "string"},
                  "name": {"type": "string"},
                  "brewery_type": {"type": ["string", "null"]},
                  "city": {"type": ["string", "null"]},
                  "state_province": {"type": ["string", "null"]},
                  "country": {"type": ["string", "null"]},
                  "website_url": {"type": ["string", "null"]}
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
