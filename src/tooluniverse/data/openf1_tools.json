[
  {
    "name": "OpenF1_get_sessions",
    "description": "Get Formula 1 race sessions (Race, Qualifying, Practice) data using the OpenF1 API. Returns session details including circuit name, location, country, start/end dates, and session type. Covers complete F1 data from 2023 onwards. No authentication required. Useful for motorsport analytics, F1 data science, and race scheduling.",
    "parameter": {
      "type": "object",
      "properties": {
        "year": {
          "type": ["integer", "null"],
          "description": "Season year. Examples: 2023, 2024"
        },
        "session_name": {
          "type": ["string", "null"],
          "description": "Filter by session type. Values: 'Race', 'Qualifying', 'Sprint', 'Practice 1', 'Practice 2', 'Practice 3', 'Sprint Qualifying'"
        },
        "circuit_short_name": {
          "type": ["string", "null"],
          "description": "Short circuit name. Examples: 'monza', 'spa', 'silverstone', 'monaco', 'suzuka', 'bahrain'"
        }
      },
      "required": []
    },
    "fields": {
      "endpoint": "https://api.openf1.org/v1/sessions",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"year": 2024, "session_name": "Race"},
      {"year": 2024, "circuit_short_name": "monza"},
      {"year": 2023, "session_name": "Qualifying"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "array",
              "description": "List of F1 sessions",
              "items": {
                "type": "object",
                "properties": {
                  "session_key": {"type": "integer", "description": "Unique session identifier"},
                  "session_name": {"type": "string", "description": "Session name (Race, Qualifying, Practice 1-3)"},
                  "session_type": {"type": "string", "description": "Session type (Race, Qualifying, Practice)"},
                  "date_start": {"type": "string", "description": "Session start datetime"},
                  "date_end": {"type": "string", "description": "Session end datetime"},
                  "meeting_key": {"type": "integer"},
                  "circuit_short_name": {"type": "string"},
                  "circuit_key": {"type": "integer"},
                  "country_name": {"type": "string"},
                  "country_code": {"type": "string"},
                  "location": {"type": "string"},
                  "year": {"type": "integer"}
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "OpenF1_get_drivers",
    "description": "Get Formula 1 driver information for a specific session using the OpenF1 API. Returns driver details including full name, team, country, car number, name acronym, headshot URL, and team color (hex). Use session_key from OpenF1_get_sessions. No authentication required. Useful for F1 analytics, driver databases, and motorsport research.",
    "parameter": {
      "type": "object",
      "properties": {
        "session_key": {
          "type": "integer",
          "description": "Session identifier from OpenF1 API. Examples: 9158 (Monza 2023 Race), 9468 (Monaco 2024 Race)"
        },
        "driver_number": {
          "type": ["integer", "null"],
          "description": "Optional filter by driver number. Examples: 1 (Verstappen), 44 (Hamilton), 16 (Leclerc), 63 (Russell), 4 (Norris)"
        }
      },
      "required": ["session_key"]
    },
    "fields": {
      "endpoint": "https://api.openf1.org/v1/drivers",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"session_key": 9158},
      {"session_key": 9158, "driver_number": 44},
      {"session_key": 9468}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "array",
              "description": "F1 driver details for the session",
              "items": {
                "type": "object",
                "properties": {
                  "driver_number": {"type": "integer", "description": "Car number"},
                  "full_name": {"type": "string", "description": "Full driver name"},
                  "name_acronym": {"type": "string", "description": "3-letter abbreviation (e.g., HAM, VER)"},
                  "broadcast_name": {"type": "string"},
                  "first_name": {"type": "string"},
                  "last_name": {"type": "string"},
                  "team_name": {"type": "string"},
                  "team_colour": {"type": "string", "description": "Team color hex code"},
                  "country_code": {"type": "string"},
                  "headshot_url": {"type": ["string", "null"], "description": "URL to driver headshot image"}
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "OpenF1_get_meeting_info",
    "description": "Get Formula 1 Grand Prix meeting information using the OpenF1 API. Returns meeting details including official name, location, country, and dates. A 'meeting' is a race weekend (e.g., Italian Grand Prix 2024). No authentication required.",
    "parameter": {
      "type": "object",
      "properties": {
        "year": {
          "type": ["integer", "null"],
          "description": "Season year. Examples: 2023, 2024"
        },
        "country_name": {
          "type": ["string", "null"],
          "description": "Filter by country name. Examples: 'Italy', 'Monaco', 'United Kingdom', 'Japan', 'Bahrain'"
        },
        "circuit_short_name": {
          "type": ["string", "null"],
          "description": "Short circuit name. Examples: 'monza', 'spa', 'silverstone', 'monaco'"
        }
      },
      "required": []
    },
    "fields": {
      "endpoint": "https://api.openf1.org/v1/meetings",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"year": 2024},
      {"year": 2024, "country_name": "Italy"},
      {"year": 2023, "circuit_short_name": "monza"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "array",
              "description": "F1 Grand Prix meeting data",
              "items": {
                "type": "object",
                "properties": {
                  "meeting_key": {"type": "integer"},
                  "meeting_name": {"type": "string"},
                  "meeting_official_name": {"type": "string"},
                  "location": {"type": "string"},
                  "country_name": {"type": "string"},
                  "country_code": {"type": "string"},
                  "circuit_short_name": {"type": "string"},
                  "year": {"type": "integer"},
                  "date_start": {"type": "string"}
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
