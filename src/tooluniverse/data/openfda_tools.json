[
  {
    "name": "OpenFDA_search_drug_labels",
    "description": "Search the FDA drug label (SPL - Structured Product Labeling) database via openFDA. Contains approved prescription and OTC drug labels including indications, warnings, dosage, adverse reactions, contraindications, and pharmacology sections. Use Lucene query syntax: 'openfda.brand_name:aspirin', 'openfda.generic_name:ibuprofen', 'openfda.manufacturer_name:pfizer'. Returns label text sections and openFDA cross-references (brand name, generic name, substance name, product type).",
    "parameter": {
      "type": "object",
      "properties": {
        "search": {
          "type": "string",
          "description": "Lucene query to search drug labels (e.g., 'openfda.brand_name:aspirin', 'openfda.generic_name:metformin', 'indications_and_usage:diabetes', 'openfda.pharm_class_epc:\"beta blocker\"')"
        },
        "limit": {
          "type": ["integer", "null"],
          "description": "Maximum number of results (default 1, max 100)"
        }
      },
      "required": ["search"]
    },
    "fields": {
      "endpoint": "https://api.fda.gov/drug/label.json"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"search": "openfda.brand_name:aspirin", "limit": 2},
      {"search": "openfda.generic_name:metformin", "limit": 2},
      {"search": "openfda.brand_name:lipitor", "limit": 1}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "FDA drug label search results",
              "properties": {
                "meta": {
                  "type": "object",
                  "description": "Query metadata",
                  "properties": {
                    "results": {
                      "type": "object",
                      "properties": {
                        "total": {"type": "integer", "description": "Total matching labels"},
                        "skip": {"type": "integer"},
                        "limit": {"type": "integer"}
                      }
                    }
                  }
                },
                "results": {
                  "type": "array",
                  "description": "Matching drug labels",
                  "items": {
                    "type": "object",
                    "properties": {
                      "openfda": {
                        "type": "object",
                        "description": "FDA cross-references",
                        "properties": {
                          "brand_name": {"type": "array", "items": {"type": "string"}},
                          "generic_name": {"type": "array", "items": {"type": "string"}},
                          "manufacturer_name": {"type": "array", "items": {"type": "string"}},
                          "substance_name": {"type": "array", "items": {"type": "string"}},
                          "product_type": {"type": "array", "items": {"type": "string"}},
                          "route": {"type": "array", "items": {"type": "string"}},
                          "pharm_class_epc": {"type": "array", "description": "Established pharmacologic class"}
                        }
                      },
                      "indications_and_usage": {"type": ["array", "null"], "items": {"type": "string"}},
                      "warnings": {"type": ["array", "null"], "items": {"type": "string"}},
                      "dosage_and_administration": {"type": ["array", "null"], "items": {"type": "string"}},
                      "contraindications": {"type": ["array", "null"], "items": {"type": "string"}},
                      "adverse_reactions": {"type": ["array", "null"], "items": {"type": "string"}},
                      "drug_interactions": {"type": ["array", "null"], "items": {"type": "string"}},
                      "mechanism_of_action": {"type": ["array", "null"], "items": {"type": "string"}}
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {
            "error": {"type": "string"}
          },
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "OpenFDA_search_drug_events",
    "description": "Search the FDA Adverse Event Reporting System (FAERS) database via openFDA for drug safety reports. Contains 20+ million adverse event reports submitted to the FDA. Use Lucene syntax: 'patient.drug.medicinalproduct:aspirin', 'patient.reaction.reactionmeddrapt:headache'. Returns serious adverse events with outcomes (hospitalization, death), suspect drugs, and reported reactions using MedDRA terminology.",
    "parameter": {
      "type": "object",
      "properties": {
        "search": {
          "type": "string",
          "description": "Lucene query for adverse event reports (e.g., 'patient.drug.medicinalproduct:aspirin', 'patient.reaction.reactionmeddrapt:\"myocardial infarction\"', 'serious:1 AND patient.drug.medicinalproduct:warfarin')"
        },
        "limit": {
          "type": ["integer", "null"],
          "description": "Maximum number of reports to return (default 1, max 100)"
        },
        "count": {
          "type": ["string", "null"],
          "description": "Field to count by for frequency analysis (e.g., 'patient.reaction.reactionmeddrapt.exact' to get most common reactions)"
        }
      },
      "required": ["search"]
    },
    "fields": {
      "endpoint": "https://api.fda.gov/drug/event.json"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"search": "patient.drug.medicinalproduct:aspirin", "limit": 2},
      {"search": "patient.drug.medicinalproduct:warfarin", "count": "patient.reaction.reactionmeddrapt.exact"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "FDA adverse event reports",
              "properties": {
                "meta": {
                  "type": "object",
                  "properties": {
                    "results": {
                      "type": "object",
                      "properties": {
                        "total": {"type": "integer", "description": "Total matching reports"}
                      }
                    }
                  }
                },
                "results": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "safetyreportid": {"type": "string", "description": "Unique report ID"},
                      "serious": {"type": ["string", "null"], "description": "1 = serious, 2 = not serious"},
                      "seriousnessoutcomes": {"type": ["string", "null"]},
                      "patient": {
                        "type": "object",
                        "properties": {
                          "drug": {
                            "type": "array",
                            "items": {
                              "type": "object",
                              "properties": {
                                "medicinalproduct": {"type": "string", "description": "Drug name"},
                                "drugcharacterization": {"type": "string", "description": "1=suspect, 2=concomitant, 3=interacting"}
                              }
                            }
                          },
                          "reaction": {
                            "type": "array",
                            "items": {
                              "type": "object",
                              "properties": {
                                "reactionmeddrapt": {"type": "string", "description": "MedDRA preferred term for the adverse reaction"},
                                "reactionoutcome": {"type": "string", "description": "1=recovered, 2=recovering, 3=not recovered, 4=fatal, 5=unknown, 6=unknown"}
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {
            "error": {"type": "string"}
          },
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "OpenFDA_search_drug_ndc",
    "description": "Search the FDA National Drug Code (NDC) Directory via openFDA. The NDC directory identifies drugs listed under Section 510 of the FDA Act, covering finished dosage forms, unfinished APIs, and non-prescription drugs. Returns product/package codes, brand/generic names, dosage forms, routes of administration, active ingredients, and marketing information.",
    "parameter": {
      "type": "object",
      "properties": {
        "search": {
          "type": "string",
          "description": "Lucene query for NDC products (e.g., 'brand_name:lipitor', 'generic_name:atorvastatin', 'active_ingredients.name:metformin', 'finished:true AND marketing_status:\"Prescription\"')"
        },
        "limit": {
          "type": ["integer", "null"],
          "description": "Maximum number of results (default 5, max 100)"
        }
      },
      "required": ["search"]
    },
    "fields": {
      "endpoint": "https://api.fda.gov/drug/ndc.json"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"search": "brand_name:lipitor", "limit": 3},
      {"search": "generic_name:atorvastatin", "limit": 3},
      {"search": "active_ingredients.name:metformin", "limit": 2}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "FDA NDC directory search results",
              "properties": {
                "meta": {
                  "type": "object",
                  "properties": {
                    "results": {
                      "type": "object",
                      "properties": {
                        "total": {"type": "integer", "description": "Total matching NDC products"}
                      }
                    }
                  }
                },
                "results": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "product_ndc": {"type": "string", "description": "NDC product code (e.g., '0069-0155')"},
                      "brand_name": {"type": "string", "description": "Brand name"},
                      "generic_name": {"type": "string", "description": "Generic/non-proprietary name"},
                      "dosage_form": {"type": "string", "description": "Dosage form (TABLET, CAPSULE, INJECTION, etc.)"},
                      "route": {"type": "array", "items": {"type": "string"}, "description": "Administration routes (ORAL, INTRAVENOUS, etc.)"},
                      "marketing_status": {"type": "string", "description": "Prescription, OTC, etc."},
                      "active_ingredients": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "name": {"type": "string"},
                            "strength": {"type": "string"}
                          }
                        }
                      },
                      "labeler_name": {"type": "string", "description": "Manufacturer/labeler name"},
                      "finished": {"type": "boolean"}
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {
            "error": {"type": "string"}
          },
          "required": ["error"]
        }
      ]
    }
  }
]
