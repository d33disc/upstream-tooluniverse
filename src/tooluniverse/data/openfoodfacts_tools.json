[
  {
    "name": "OpenFoodFacts_search_products",
    "description": "Search the Open Food Facts database containing 3M+ food products worldwide. Returns product names, brands, ingredients, nutritional values (per 100g), allergens, labels (organic, vegan, fair trade), and environmental scores (Nutri-Score A-E, NOVA group 1-4, Eco-Score). No authentication required. Useful for nutrition research, dietary analysis, food science, and consumer product research.",
    "parameter": {
      "type": "object",
      "properties": {
        "search_terms": {
          "type": "string",
          "description": "Search terms for the product. Examples: 'chocolate', 'organic milk', 'gluten-free bread', 'vitamin C supplement', 'coca-cola'"
        },
        "page_size": {
          "type": ["integer", "null"],
          "description": "Number of results per page (default 10, max 100)"
        },
        "page": {
          "type": ["integer", "null"],
          "description": "Page number for pagination (default 1)"
        },
        "tagtype_0": {
          "type": ["string", "null"],
          "description": "Filter by tag type. Examples: 'brands', 'categories', 'countries', 'labels'"
        },
        "tag_contains_0": {
          "type": ["string", "null"],
          "description": "Filter value for tagtype_0. Examples: 'nestle', 'beverages', 'en:united-states'"
        }
      },
      "required": ["search_terms"]
    },
    "fields": {
      "endpoint": "https://world.openfoodfacts.org/cgi/search.pl",
      "params": {
        "action": "process",
        "json": "true",
        "page_size": "10"
      }
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"search_terms": "chocolate"},
      {"search_terms": "olive oil", "page_size": 5},
      {"search_terms": "yogurt", "tagtype_0": "brands", "tag_contains_0": "danone"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Food product search results",
              "properties": {
                "count": {"type": "integer", "description": "Total matching products"},
                "page": {"type": "integer"},
                "page_size": {"type": "integer"},
                "products": {
                  "type": "array",
                  "description": "List of food products",
                  "items": {
                    "type": "object",
                    "properties": {
                      "code": {"type": "string", "description": "Barcode/EAN"},
                      "product_name": {"type": ["string", "null"], "description": "Product name"},
                      "brands": {"type": ["string", "null"], "description": "Brand name(s)"},
                      "categories": {"type": ["string", "null"], "description": "Product categories"},
                      "ingredients_text": {"type": ["string", "null"], "description": "Ingredients list"},
                      "allergens": {"type": ["string", "null"], "description": "Allergen information"},
                      "labels": {"type": ["string", "null"], "description": "Labels (organic, vegan, etc.)"},
                      "countries": {"type": ["string", "null"], "description": "Countries where sold"},
                      "nutriscore_grade": {"type": ["string", "null"], "description": "Nutri-Score grade (a-e, a=healthiest)"},
                      "nova_group": {"type": ["integer", "null"], "description": "NOVA food processing group (1=unprocessed, 4=ultra-processed)"},
                      "nutriments": {
                        "type": "object",
                        "description": "Nutritional values per 100g",
                        "properties": {
                          "energy-kcal_100g": {"type": ["number", "null"], "description": "Calories per 100g"},
                          "proteins_100g": {"type": ["number", "null"]},
                          "carbohydrates_100g": {"type": ["number", "null"]},
                          "fat_100g": {"type": ["number", "null"]},
                          "fiber_100g": {"type": ["number", "null"]},
                          "sugars_100g": {"type": ["number", "null"]},
                          "salt_100g": {"type": ["number", "null"]}
                        }
                      }
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
