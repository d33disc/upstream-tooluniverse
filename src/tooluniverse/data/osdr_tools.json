[
  {
    "name": "OSDR_search_studies",
    "description": "Search NASA's Open Science Data Repository (OSDR, formerly GeneLab) for space biology and life science studies. OSDR contains datasets from spaceflight, ground-based analog experiments (simulated microgravity, radiation), and related studies. Covers transcriptomics, proteomics, metabolomics, and other omics from organisms exposed to spaceflight conditions. Returns study identifiers, descriptions, assay types, missions, organisms, and experimental factors.",
    "parameter": {
      "type": "object",
      "properties": {
        "query": {
          "type": "string",
          "description": "Search query (e.g., 'microgravity', 'radiation', 'bone loss', 'muscle atrophy', 'ISS', 'rodent', 'arabidopsis')"
        },
        "type": {
          "type": "string",
          "default": "cgene",
          "description": "Data source type. Options: 'cgene' (all GeneLab), 'nih_geo_gse' (GEO), 'ebi_pride' (proteomics)"
        },
        "size": {
          "type": "integer",
          "default": 10,
          "description": "Number of results to return (default 10)"
        },
        "from": {
          "type": "integer",
          "default": 0,
          "description": "Offset for pagination (default 0)"
        }
      },
      "required": ["query"]
    },
    "fields": {
      "endpoint": "https://osdr.nasa.gov/osdr/data/search",
      "params": {
        "qs": "{query}",
        "type": "{type}",
        "size": "{size}",
        "from": "{from}"
      }
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"query": "microgravity", "size": 5},
      {"query": "bone loss spaceflight", "size": 3},
      {"query": "radiation mouse", "size": 3, "type": "cgene"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "OSDR search response with study hits",
              "properties": {
                "took": {"type": "integer", "description": "Query time in ms"},
                "timed_out": {"type": "boolean"},
                "hits": {
                  "type": "object",
                  "properties": {
                    "total": {"type": "integer", "description": "Total matching studies"},
                    "max_score": {"type": "number"},
                    "hits": {
                      "type": "array",
                      "description": "Array of matching study objects",
                      "items": {
                        "type": "object",
                        "properties": {
                          "_id": {"type": "string"},
                          "_score": {"type": "number"},
                          "_source": {
                            "type": "object",
                            "description": "Study metadata",
                            "properties": {
                              "Study Identifier": {"type": "string"},
                              "Study Assay Measurement Type": {"type": "string"},
                              "Space Program": {"type": "string"},
                              "Flight Program": {"type": "string"},
                              "Study Factor Name": {"type": "string"},
                              "Mission": {"type": "object"},
                              "Data Source Type": {"type": "string"},
                              "Experiment Platform": {"type": "string"}
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {
            "error": {"type": "string"}
          },
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "OSDR_get_study",
    "description": "Get detailed metadata for a specific study from NASA's Open Science Data Repository (OSDR). Returns comprehensive ISA (Investigation-Study-Assay) metadata including experimental design, protocols, sample information, data files, organisms, and mission details. Study IDs use numeric format (e.g., 379 for OSD-379). Use OSDR_search_studies first to discover available study IDs.",
    "parameter": {
      "type": "object",
      "properties": {
        "study_id": {
          "type": "string",
          "description": "Numeric study ID (e.g., '379', '137', '47', '120'). This is the number from OSD-XXX identifiers."
        }
      },
      "required": ["study_id"]
    },
    "fields": {
      "endpoint": "https://osdr.nasa.gov/osdr/data/osd/meta/{study_id}"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"study_id": "379"},
      {"study_id": "137"},
      {"study_id": "47"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Study metadata in ISA (Investigation-Study-Assay) format",
              "properties": {
                "hits": {
                  "type": "integer",
                  "description": "Number of matching studies (1 for valid IDs)"
                },
                "input": {
                  "type": "string",
                  "description": "Input study ID"
                },
                "study": {
                  "type": "object",
                  "description": "Study data keyed by OSD-XXX identifier. Contains ontologySourceReferences, people, publications, studies (with assays, protocols, samples)"
                },
                "success": {
                  "type": "boolean"
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {
            "error": {"type": "string"}
          },
          "required": ["error"]
        }
      ]
    }
  }
]
