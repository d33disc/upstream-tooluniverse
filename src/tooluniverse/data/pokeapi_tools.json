[
  {
    "name": "PokeAPI_get_pokemon",
    "description": "Get detailed information about a Pokemon by name or ID using the PokeAPI. Returns stats, types, abilities, moves, height, weight, and sprites. No authentication required. Useful for game data analysis, educational tools about species, and biodiversity-like analyses of fictional creatures.",
    "parameter": {
      "type": "object",
      "properties": {
        "pokemon": {
          "type": "string",
          "description": "Pokemon name (lowercase) or national Pokedex ID. Examples: 'pikachu', 'charizard', 'mewtwo', '25' (Pikachu), '150' (Mewtwo)"
        }
      },
      "required": ["pokemon"]
    },
    "fields": {
      "endpoint": "https://pokeapi.co/api/v2/pokemon/{pokemon}",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"pokemon": "pikachu"},
      {"pokemon": "charizard"},
      {"pokemon": "150"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Pokemon data",
              "properties": {
                "id": {"type": "integer", "description": "National Pokedex ID"},
                "name": {"type": "string"},
                "height": {"type": "integer", "description": "Height in decimetres"},
                "weight": {"type": "integer", "description": "Weight in hectograms"},
                "base_experience": {"type": ["integer", "null"]},
                "types": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "slot": {"type": "integer"},
                      "type": {"type": "object", "properties": {"name": {"type": "string"}}}
                    }
                  }
                },
                "stats": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "base_stat": {"type": "integer"},
                      "stat": {"type": "object", "properties": {"name": {"type": "string"}}}
                    }
                  }
                },
                "abilities": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "is_hidden": {"type": "boolean"},
                      "ability": {"type": "object", "properties": {"name": {"type": "string"}}}
                    }
                  }
                },
                "sprites": {
                  "type": "object",
                  "properties": {
                    "front_default": {"type": ["string", "null"], "description": "URL to front sprite image"}
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "PokeAPI_get_pokemon_species",
    "description": "Get species-level information about a Pokemon from the PokeAPI, including flavor text (Pokedex entries), evolution chain ID, capture rate, base happiness, and whether it is legendary or mythical. No authentication required.",
    "parameter": {
      "type": "object",
      "properties": {
        "species": {
          "type": "string",
          "description": "Pokemon species name (lowercase) or ID. Examples: 'pikachu', 'eevee', 'mew', '133' (Eevee)"
        }
      },
      "required": ["species"]
    },
    "fields": {
      "endpoint": "https://pokeapi.co/api/v2/pokemon-species/{species}",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"species": "pikachu"},
      {"species": "eevee"},
      {"species": "mewtwo"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Pokemon species data",
              "properties": {
                "id": {"type": "integer"},
                "name": {"type": "string"},
                "is_legendary": {"type": "boolean"},
                "is_mythical": {"type": "boolean"},
                "capture_rate": {"type": "integer", "description": "Capture rate (0-255, higher = easier)"},
                "base_happiness": {"type": ["integer", "null"]},
                "flavor_text_entries": {
                  "type": "array",
                  "description": "Pokedex entries in multiple languages",
                  "items": {
                    "type": "object",
                    "properties": {
                      "flavor_text": {"type": "string"},
                      "language": {"type": "object", "properties": {"name": {"type": "string"}}},
                      "version": {"type": "object", "properties": {"name": {"type": "string"}}}
                    }
                  }
                },
                "evolution_chain": {
                  "type": "object",
                  "properties": {"url": {"type": "string", "description": "URL to evolution chain data"}}
                },
                "genera": {
                  "type": "array",
                  "description": "Species classification (e.g., 'Mouse Pokemon')"
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
