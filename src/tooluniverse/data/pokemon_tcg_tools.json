[
  {
    "name": "PokemonTCG_search_cards",
    "description": "Search for Pokemon Trading Card Game cards using the Pokemon TCG API. Supports querying by name, type, set, rarity, HP, and more using the Lucene-like query syntax. Returns card details including stats, attacks, images, and market prices. No authentication required.",
    "parameter": {
      "type": "object",
      "properties": {
        "q": {
          "type": "string",
          "description": "Search query using Lucene syntax. Examples: 'name:charizard', 'name:pikachu types:lightning', 'set.name:base rarity:rare', 'hp:[100 TO *]', 'attacks.name:thunderbolt'. Multiple conditions can be combined with spaces (AND) or 'OR'."
        },
        "page": {
          "type": ["integer", "null"],
          "description": "Page number for pagination. Default: 1"
        },
        "pageSize": {
          "type": ["integer", "null"],
          "description": "Number of results per page (max 250). Default: 10"
        },
        "orderBy": {
          "type": ["string", "null"],
          "description": "Field to order by. Examples: 'name', '-name' (descending), 'set.releaseDate', 'nationalPokedexNumbers'"
        }
      },
      "required": ["q"]
    },
    "fields": {
      "endpoint": "https://api.pokemontcg.io/v2/cards",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"q": "name:charizard", "pageSize": 3},
      {"q": "name:pikachu types:lightning", "pageSize": 5},
      {"q": "set.name:base rarity:\"Rare Holo\"", "pageSize": 3}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Pokemon TCG card search results with pagination",
              "properties": {
                "data": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {"type": "string", "description": "Unique card ID like 'base1-4'"},
                      "name": {"type": "string"},
                      "supertype": {"type": "string", "description": "Pokemon, Trainer, or Energy"},
                      "subtypes": {"type": "array", "items": {"type": "string"}},
                      "hp": {"type": "string"},
                      "types": {"type": "array", "items": {"type": "string"}},
                      "attacks": {"type": "array"},
                      "weaknesses": {"type": "array"},
                      "retreatCost": {"type": "array"},
                      "set": {"type": "object", "properties": {"id": {"type": "string"}, "name": {"type": "string"}, "series": {"type": "string"}}},
                      "rarity": {"type": ["string", "null"]},
                      "images": {"type": "object", "properties": {"small": {"type": "string"}, "large": {"type": "string"}}},
                      "tcgplayer": {"type": "object", "description": "Market prices from TCGplayer"},
                      "cardmarket": {"type": "object", "description": "Market prices from Cardmarket"}
                    }
                  }
                },
                "page": {"type": "integer"},
                "pageSize": {"type": "integer"},
                "count": {"type": "integer"},
                "totalCount": {"type": "integer"}
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "PokemonTCG_get_card",
    "description": "Get detailed information about a specific Pokemon TCG card by its unique ID. Returns comprehensive card data including stats, attacks, abilities, set info, images, and current market prices from TCGplayer and Cardmarket. No authentication required.",
    "parameter": {
      "type": "object",
      "properties": {
        "card_id": {
          "type": "string",
          "description": "Unique card ID in format 'setId-number'. Examples: 'base1-4' (Charizard Base Set), 'swsh1-1' (Celebi V), 'xy1-1' (Venusaur-EX)"
        }
      },
      "required": ["card_id"]
    },
    "fields": {
      "endpoint": "https://api.pokemontcg.io/v2/cards/{card_id}",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"card_id": "base1-4"},
      {"card_id": "gym2-2"},
      {"card_id": "dp3-3"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Detailed Pokemon TCG card data",
              "properties": {
                "data": {
                  "type": "object",
                  "properties": {
                    "id": {"type": "string"},
                    "name": {"type": "string"},
                    "supertype": {"type": "string"},
                    "subtypes": {"type": "array", "items": {"type": "string"}},
                    "hp": {"type": "string"},
                    "types": {"type": "array", "items": {"type": "string"}},
                    "evolvesFrom": {"type": ["string", "null"]},
                    "attacks": {"type": "array"},
                    "weaknesses": {"type": "array"},
                    "resistances": {"type": "array"},
                    "retreatCost": {"type": "array"},
                    "set": {"type": "object"},
                    "number": {"type": "string"},
                    "artist": {"type": "string"},
                    "rarity": {"type": ["string", "null"]},
                    "nationalPokedexNumbers": {"type": "array", "items": {"type": "integer"}},
                    "images": {"type": "object"},
                    "tcgplayer": {"type": "object"},
                    "cardmarket": {"type": "object"}
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "PokemonTCG_list_sets",
    "description": "List all Pokemon TCG card sets or search for specific sets. Returns set details including name, series, release date, total cards, set images, and legality info. The Pokemon TCG has 170+ sets spanning from Base Set (1999) to modern expansions. No authentication required.",
    "parameter": {
      "type": "object",
      "properties": {
        "q": {
          "type": ["string", "null"],
          "description": "Optional search query for filtering sets. Examples: 'name:base', 'series:sword', 'legalities.standard:legal'. Leave empty to list all sets."
        },
        "page": {
          "type": ["integer", "null"],
          "description": "Page number. Default: 1"
        },
        "pageSize": {
          "type": ["integer", "null"],
          "description": "Results per page (max 250). Default: 10"
        },
        "orderBy": {
          "type": ["string", "null"],
          "description": "Sort by field. Examples: 'releaseDate', '-releaseDate' (newest first), 'name'"
        }
      },
      "required": []
    },
    "fields": {
      "endpoint": "https://api.pokemontcg.io/v2/sets",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"q": "name:base", "pageSize": 5},
      {"orderBy": "-releaseDate", "pageSize": 3},
      {"q": "series:sun", "pageSize": 5}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Paginated list of Pokemon TCG sets",
              "properties": {
                "data": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {"type": "string"},
                      "name": {"type": "string"},
                      "series": {"type": "string"},
                      "printedTotal": {"type": "integer"},
                      "total": {"type": "integer"},
                      "legalities": {"type": "object"},
                      "releaseDate": {"type": "string"},
                      "images": {"type": "object", "properties": {"symbol": {"type": "string"}, "logo": {"type": "string"}}}
                    }
                  }
                },
                "page": {"type": "integer"},
                "pageSize": {"type": "integer"},
                "count": {"type": "integer"},
                "totalCount": {"type": "integer"}
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
