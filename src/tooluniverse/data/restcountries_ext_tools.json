[
  {
    "name": "RESTCountries_get_by_code",
    "description": "Get detailed country information by ISO 3166-1 alpha-2 or alpha-3 code using the REST Countries API. Returns capital, population, area, currencies, languages, flag, borders, and geographic data. Useful when you have a country code (e.g., from another API) and need full country details. No authentication required.",
    "parameter": {
      "type": "object",
      "properties": {
        "code": {
          "type": "string",
          "description": "ISO 3166-1 alpha-2 (e.g., 'US', 'DE', 'JP') or alpha-3 (e.g., 'USA', 'DEU', 'JPN') country code"
        },
        "fields": {
          "type": ["string", "null"],
          "description": "Comma-separated list of fields to return. Examples: 'name,capital,population', 'name,currencies,languages,area'. Default: all fields"
        }
      },
      "required": ["code"]
    },
    "fields": {
      "endpoint": "https://restcountries.com/v3.1/alpha/{code}",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"code": "US", "fields": "name,capital,population,currencies"},
      {"code": "DEU", "fields": "name,capital,region,languages"},
      {"code": "JP", "fields": "name,population,area,borders"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "array",
              "description": "Country data array (single item for exact code match)",
              "items": {
                "type": "object",
                "properties": {
                  "name": {"type": "object", "properties": {"common": {"type": "string"}, "official": {"type": "string"}}},
                  "capital": {"type": "array", "items": {"type": "string"}},
                  "region": {"type": "string"},
                  "subregion": {"type": ["string", "null"]},
                  "population": {"type": "integer"},
                  "area": {"type": "number"},
                  "languages": {"type": "object"},
                  "currencies": {"type": "object"},
                  "borders": {"type": "array", "items": {"type": "string"}},
                  "cca2": {"type": "string"},
                  "cca3": {"type": "string"},
                  "flag": {"type": "string"},
                  "flags": {"type": "object"}
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
