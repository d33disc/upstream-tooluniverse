[
  {
    "name": "RESTCountries_get_by_name",
    "description": "Get detailed information about a country by name using the REST Countries API. Returns capital, population, area, currencies, languages, flag, borders, calling codes, and geographic data for 250 countries and territories. No authentication required. Useful for geographic research, international studies, and data analysis.",
    "parameter": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Country name to search. Examples: 'France', 'Brazil', 'Japan', 'South Africa', 'New Zealand'"
        },
        "fields": {
          "type": ["string", "null"],
          "description": "Comma-separated list of fields to return. Examples: 'name,capital,population', 'name,currencies,languages,area'. Default: all fields"
        }
      },
      "required": ["name"]
    },
    "fields": {
      "endpoint": "https://restcountries.com/v3.1/name/{name}",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"name": "France", "fields": "name,capital,population,area,currencies,languages"},
      {"name": "Japan", "fields": "name,capital,population,languages,flag"},
      {"name": "Brazil", "fields": "name,region,subregion,borders,population"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "array",
              "description": "List of country data (usually 1 item, may include partial matches)",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "object",
                    "properties": {
                      "common": {"type": "string", "description": "Common country name"},
                      "official": {"type": "string", "description": "Official country name"}
                    }
                  },
                  "capital": {"type": "array", "items": {"type": "string"}, "description": "Capital city/cities"},
                  "region": {"type": "string", "description": "Geographic region (e.g., Europe, Asia)"},
                  "subregion": {"type": ["string", "null"], "description": "Geographic subregion"},
                  "population": {"type": "integer", "description": "Population"},
                  "area": {"type": "number", "description": "Area in km²"},
                  "languages": {"type": "object", "description": "Official languages (code: name)"},
                  "currencies": {"type": "object", "description": "Currencies (code: {name, symbol})"},
                  "borders": {"type": "array", "items": {"type": "string"}, "description": "Bordering countries (ISO 3166-1 alpha-3)"},
                  "flag": {"type": "string", "description": "Flag emoji"},
                  "flags": {"type": "object", "description": "Flag image URLs"},
                  "latlng": {"type": "array", "items": {"type": "number"}, "description": "Lat/lng coordinates"},
                  "cca2": {"type": "string", "description": "ISO 3166-1 alpha-2 code"},
                  "cca3": {"type": "string", "description": "ISO 3166-1 alpha-3 code"},
                  "independent": {"type": ["boolean", "null"]},
                  "unMember": {"type": "boolean", "description": "UN member state"}
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "RESTCountries_get_by_region",
    "description": "Get all countries in a geographic region using the REST Countries API. Returns country data for all nations in a continent or subregion including capitals, populations, languages, and currencies. No authentication required.",
    "parameter": {
      "type": "object",
      "properties": {
        "region": {
          "type": "string",
          "description": "Geographic region. Values: 'Africa', 'Americas', 'Asia', 'Europe', 'Oceania', 'Antarctic'"
        },
        "fields": {
          "type": ["string", "null"],
          "description": "Comma-separated fields to return. Examples: 'name,capital,population', 'name,cca2,languages'"
        }
      },
      "required": ["region"]
    },
    "fields": {
      "endpoint": "https://restcountries.com/v3.1/region/{region}",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"region": "Europe", "fields": "name,capital,population,cca2"},
      {"region": "Africa", "fields": "name,capital,languages"},
      {"region": "Asia", "fields": "name,population,area"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "array",
              "description": "List of all countries in the region",
              "items": {
                "type": "object",
                "properties": {
                  "name": {"type": "object", "properties": {"common": {"type": "string"}, "official": {"type": "string"}}},
                  "capital": {"type": "array", "items": {"type": "string"}},
                  "population": {"type": "integer"},
                  "area": {"type": "number"},
                  "cca2": {"type": "string", "description": "ISO 2-letter code"},
                  "languages": {"type": "object"},
                  "currencies": {"type": "object"}
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
