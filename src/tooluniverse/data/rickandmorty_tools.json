[
  {
    "name": "RickAndMorty_get_characters",
    "description": "Get Rick and Morty characters with optional filtering by name, status, species, type, or gender using the Rick and Morty public API. Returns character details including name, species, origin, location, and episode appearances. No authentication required.",
    "parameter": {
      "type": "object",
      "properties": {
        "name": {
          "type": ["string", "null"],
          "description": "Filter by character name. Examples: 'rick', 'morty', 'beth', 'jerry', 'summer'"
        },
        "status": {
          "type": ["string", "null"],
          "description": "Filter by status. Values: 'alive', 'dead', 'unknown'"
        },
        "species": {
          "type": ["string", "null"],
          "description": "Filter by species. Examples: 'human', 'alien', 'robot', 'humanoid'"
        },
        "gender": {
          "type": ["string", "null"],
          "description": "Filter by gender. Values: 'female', 'male', 'genderless', 'unknown'"
        },
        "page": {
          "type": ["integer", "null"],
          "description": "Page number for pagination (20 results per page). Default: 1"
        }
      },
      "required": []
    },
    "fields": {
      "endpoint": "https://rickandmortyapi.com/api/character",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"name": "rick", "status": "alive"},
      {"species": "alien", "page": 1},
      {"name": "morty", "gender": "male"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Paginated list of Rick and Morty characters",
              "properties": {
                "info": {
                  "type": "object",
                  "properties": {
                    "count": {"type": "integer", "description": "Total number of matching characters"},
                    "pages": {"type": "integer", "description": "Total number of pages"},
                    "next": {"type": ["string", "null"]},
                    "prev": {"type": ["string", "null"]}
                  }
                },
                "results": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {"type": "integer"},
                      "name": {"type": "string"},
                      "status": {"type": "string", "description": "alive, dead, or unknown"},
                      "species": {"type": "string"},
                      "type": {"type": "string"},
                      "gender": {"type": "string"},
                      "origin": {"type": "object", "properties": {"name": {"type": "string"}}},
                      "location": {"type": "object", "properties": {"name": {"type": "string"}}},
                      "image": {"type": "string", "description": "Character image URL"},
                      "episode": {"type": "array", "items": {"type": "string"}}
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "RickAndMorty_get_episodes",
    "description": "Get Rick and Morty episodes with optional filtering by name or episode code (e.g. S01E01) using the Rick and Morty public API. Returns episode name, air date, episode code, and list of character URLs. No authentication required.",
    "parameter": {
      "type": "object",
      "properties": {
        "name": {
          "type": ["string", "null"],
          "description": "Filter by episode name. Examples: 'pilot', 'rick potion', 'pickle'"
        },
        "episode": {
          "type": ["string", "null"],
          "description": "Filter by episode code. Examples: 'S01E01', 'S02E05', 'S03E03'"
        },
        "page": {
          "type": ["integer", "null"],
          "description": "Page number (20 results per page). Default: 1"
        }
      },
      "required": []
    },
    "fields": {
      "endpoint": "https://rickandmortyapi.com/api/episode",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"name": "pilot"},
      {"episode": "S01E01"},
      {"name": "pickle"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Paginated list of episodes",
              "properties": {
                "info": {"type": "object", "properties": {"count": {"type": "integer"}, "pages": {"type": "integer"}}},
                "results": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {"type": "integer"},
                      "name": {"type": "string"},
                      "air_date": {"type": "string"},
                      "episode": {"type": "string", "description": "Episode code like S01E01"},
                      "characters": {"type": "array", "items": {"type": "string"}, "description": "Character URLs"},
                      "url": {"type": "string"}
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
