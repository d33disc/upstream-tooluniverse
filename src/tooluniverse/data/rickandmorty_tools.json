[
  {
    "name": "RickAndMorty_search_characters",
    "description": "Search for characters from the Rick and Morty TV show. Filter by name, status (alive/dead), species, type, or gender. Returns character details including origin, location, and episode appearances.",
    "parameter": {
      "type": "object",
      "properties": {
        "name": {
          "type": ["string", "null"],
          "description": "Filter by character name (e.g., 'rick', 'morty', 'jerry')"
        },
        "status": {
          "type": ["string", "null"],
          "description": "Filter by status: 'alive', 'dead', 'unknown'"
        },
        "species": {
          "type": ["string", "null"],
          "description": "Filter by species (e.g., 'Human', 'Alien', 'Robot')"
        },
        "gender": {
          "type": ["string", "null"],
          "description": "Filter by gender: 'female', 'male', 'genderless', 'unknown'"
        },
        "page": {
          "type": ["integer", "null"],
          "description": "Page number for pagination (20 results per page)"
        }
      },
      "required": []
    },
    "fields": {
      "endpoint": "https://rickandmortyapi.com/api/character"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"name": "rick"},
      {"species": "Alien", "status": "alive"},
      {"name": "morty", "gender": "male"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Character search results",
              "properties": {
                "info": {
                  "type": "object",
                  "properties": {
                    "count": {"type": "integer"},
                    "pages": {"type": "integer"},
                    "next": {"type": ["string", "null"]},
                    "prev": {"type": ["string", "null"]}
                  }
                },
                "results": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {"type": "integer"},
                      "name": {"type": "string"},
                      "status": {"type": "string"},
                      "species": {"type": "string"},
                      "type": {"type": "string"},
                      "gender": {"type": "string"},
                      "origin": {"type": "object"},
                      "location": {"type": "object"},
                      "image": {"type": "string"},
                      "episode": {"type": "array", "items": {"type": "string"}},
                      "url": {"type": "string"}
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {
            "error": {"type": "string"}
          },
          "required": ["error"]
        }
      ]
    }
  },
