[
  {
    "name": "Smithsonian_search_collection",
    "description": "Search the Smithsonian Institution's open access collection of 5M+ digitized artifacts, specimens, artworks, and archival materials from 19 Smithsonian museums and research centers. Uses DEMO_KEY for basic access. Returns items from the National Museum of Natural History, National Air and Space Museum, American Art Museum, National Zoo, and more. Useful for museum research, natural history studies, and cultural heritage analysis.",
    "parameter": {
      "type": "object",
      "properties": {
        "q": {
          "type": "string",
          "description": "Search query. Examples: 'dinosaur fossil', 'lunar module', 'butterflies', 'Wright brothers', 'Native American artifacts'"
        },
        "unit_code": {
          "type": ["string", "null"],
          "description": "Filter by museum/unit. Examples: 'NMNH' (Natural History), 'NASM' (Air & Space), 'SAAM' (American Art), 'NMAAHC' (African American History), 'NMAH' (American History)"
        },
        "type": {
          "type": ["string", "null"],
          "description": "Object type filter. Examples: 'edanmdm:nasm_A19610048000' (specific item), or by category"
        },
        "rows": {
          "type": ["integer", "null"],
          "description": "Number of results to return (default 10, max 100)"
        },
        "start": {
          "type": ["integer", "null"],
          "description": "Start offset for pagination"
        }
      },
      "required": ["q"]
    },
    "fields": {
      "endpoint": "https://api.si.edu/openaccess/api/v1.0/search",
      "params": {
        "api_key": "DEMO_KEY",
        "rows": "10"
      }
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"q": "dinosaur fossil", "unit_code": "NMNH", "rows": 5},
      {"q": "Apollo 11 lunar module", "unit_code": "NASM", "rows": 5},
      {"q": "butterfly specimen", "rows": 5}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Smithsonian collection search results",
              "properties": {
                "status": {"type": "integer"},
                "responseCode": {"type": "integer"},
                "response": {
                  "type": "object",
                  "properties": {
                    "rowCount": {"type": "integer", "description": "Total matching items"},
                    "rows": {
                      "type": "array",
                      "description": "List of collection items",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {"type": "string", "description": "Item ID"},
                          "title": {"type": "string", "description": "Item title"},
                          "unitCode": {"type": "string", "description": "Museum/unit code"},
                          "type": {"type": "string", "description": "Object type"},
                          "url": {"type": "string", "description": "Smithsonian URL"},
                          "content": {
                            "type": "object",
                            "description": "Item content",
                            "properties": {
                              "descriptiveNonRepeating": {
                                "type": "object",
                                "properties": {
                                  "title": {"type": "object"},
                                  "online_media": {"type": "object", "description": "Images and media"},
                                  "record_link": {"type": "string"}
                                }
                              },
                              "freetext": {"type": "object", "description": "Descriptive text fields"},
                              "indexedStructured": {"type": "object", "description": "Structured metadata"}
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
