[
  {
    "name": "ISS_get_position",
    "description": "Get the current real-time position (latitude and longitude) of the International Space Station (ISS) from the Open Notify API. The ISS orbits Earth at ~400 km altitude, completing an orbit every 90 minutes. Use this to track where the ISS is now, correlate with ground observations, or build ISS tracking applications. Position updates every few seconds.",
    "parameter": {
      "type": "object",
      "properties": {},
      "required": []
    },
    "fields": {
      "endpoint": "http://api.open-notify.org/iss-now.json"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {},
      {},
      {}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Current ISS position",
              "properties": {
                "message": {
                  "type": "string",
                  "description": "Status: 'success'"
                },
                "timestamp": {
                  "type": "integer",
                  "description": "Unix timestamp of position measurement"
                },
                "iss_position": {
                  "type": "object",
                  "properties": {
                    "latitude": {
                      "type": "string",
                      "description": "Current ISS latitude (-90 to 90)"
                    },
                    "longitude": {
                      "type": "string",
                      "description": "Current ISS longitude (-180 to 180)"
                    }
                  }
                }
              }
            },
            "metadata": {
              "type": "object"
            }
          },
          "required": [
            "data"
          ]
        },
        {
          "type": "object",
          "properties": {
            "error": {
              "type": "string"
            }
          },
          "required": [
            "error"
          ]
        }
      ]
    }
  },
  {
    "name": "ISS_get_astronauts",
    "description": "Get the current list of astronauts aboard the International Space Station (ISS) and other spacecraft in orbit from the Open Notify API. Returns names and spacecraft for all humans currently in space. The ISS typically hosts 3-7 crew members from NASA, Roscosmos, ESA, JAXA, and CSA.",
    "parameter": {
      "type": "object",
      "properties": {},
      "required": []
    },
    "fields": {
      "endpoint": "http://api.open-notify.org/astros.json"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {},
      {},
      {}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Current humans in space",
              "properties": {
                "message": {
                  "type": "string"
                },
                "number": {
                  "type": "integer",
                  "description": "Total number of humans currently in space"
                },
                "people": {
                  "type": "array",
                  "description": "List of people currently in space",
                  "items": {
                    "type": "object",
                    "properties": {
                      "name": {
                        "type": "string",
                        "description": "Astronaut name"
                      },
                      "craft": {
                        "type": "string",
                        "description": "Spacecraft name (e.g., 'ISS', 'Shenzhou')"
                      }
                    }
                  }
                }
              }
            },
            "metadata": {
              "type": "object"
            }
          },
          "required": [
            "data"
          ]
        },
        {
          "type": "object",
          "properties": {
            "error": {
              "type": "string"
            }
          },
          "required": [
            "error"
          ]
        }
      ]
    }
  }
]
