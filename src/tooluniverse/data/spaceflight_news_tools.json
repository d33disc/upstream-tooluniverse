[
  {
    "name": "SpaceflightNews_search_articles",
    "description": "Search spaceflight news articles from 30,000+ stories across major space news sites (SpaceNews, NASASpaceflight, The Verge, etc.) using the Spaceflight News API. Returns articles with titles, summaries, publication dates, source sites, and associated launches/events. No authentication required. Useful for tracking space exploration developments, rocket launches, and aerospace industry news.",
    "parameter": {
      "type": "object",
      "properties": {
        "title_contains": {
          "type": ["string", "null"],
          "description": "Filter articles containing this text in the title. Examples: 'Starship', 'Artemis', 'SpaceX', 'NASA', 'Mars'"
        },
        "summary_contains": {
          "type": ["string", "null"],
          "description": "Filter articles containing this text in the summary"
        },
        "news_site": {
          "type": ["string", "null"],
          "description": "Filter by news site name. Examples: 'NASA', 'SpaceNews', 'NASASpaceflight', 'The Verge'"
        },
        "published_at_gte": {
          "type": ["string", "null"],
          "description": "Filter articles published on or after this date (ISO 8601). Example: '2024-01-01'"
        },
        "published_at_lte": {
          "type": ["string", "null"],
          "description": "Filter articles published on or before this date (ISO 8601). Example: '2024-12-31'"
        },
        "limit": {
          "type": ["integer", "null"],
          "description": "Number of articles to return (default 10, max 100)"
        },
        "offset": {
          "type": ["integer", "null"],
          "description": "Pagination offset"
        }
      },
      "required": []
    },
    "fields": {
      "endpoint": "https://api.spaceflightnewsapi.net/v4/articles/",
      "params": {
        "limit": "10"
      }
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"title_contains": "Starship", "limit": 5},
      {"title_contains": "Artemis", "published_at_gte": "2024-01-01", "limit": 5},
      {"news_site": "NASA", "limit": 5}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Spaceflight news search results",
              "properties": {
                "count": {"type": "integer", "description": "Total matching articles"},
                "next": {"type": ["string", "null"], "description": "URL for next page"},
                "previous": {"type": ["string", "null"]},
                "results": {
                  "type": "array",
                  "description": "List of news articles",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {"type": "integer"},
                      "title": {"type": "string", "description": "Article title"},
                      "url": {"type": "string", "description": "Article URL"},
                      "image_url": {"type": "string", "description": "Article image URL"},
                      "news_site": {"type": "string", "description": "Source news site"},
                      "summary": {"type": "string", "description": "Article summary"},
                      "published_at": {"type": "string", "description": "Publication date (ISO 8601)"},
                      "updated_at": {"type": "string"},
                      "featured": {"type": "boolean"},
                      "launches": {"type": "array", "items": {"type": "object"}, "description": "Related launches"},
                      "events": {"type": "array", "items": {"type": "object"}, "description": "Related events"}
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
