[
  {
    "name": "SpaceX_get_latest_launch",
    "description": "Get data about the latest SpaceX rocket launch, including mission name, date, success status, rocket used, crew members, and related links (webcast, article, Wikipedia).",
    "parameter": {
      "type": "object",
      "properties": {},
      "required": []
    },
    "fields": {
      "endpoint": "https://api.spacexdata.com/v4/launches/latest"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Latest SpaceX launch data",
              "properties": {
                "id": {"type": "string"},
                "name": {"type": "string", "description": "Mission name"},
                "flight_number": {"type": "integer"},
                "date_utc": {"type": "string"},
                "date_local": {"type": "string"},
                "success": {"type": ["boolean", "null"]},
                "details": {"type": ["string", "null"]},
                "rocket": {"type": "string", "description": "Rocket ID"},
                "crew": {"type": "array", "items": {"type": "string"}},
                "launchpad": {"type": "string"},
                "links": {"type": "object"}
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {
            "error": {"type": "string"}
          },
          "required": ["error"]
        }
      ]
    }
  },
  {
