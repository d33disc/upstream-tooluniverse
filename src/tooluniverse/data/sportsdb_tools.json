[
  {
    "name": "TheSportsDB_search_teams",
    "description": "Search for sports teams by name in TheSportsDB - a free community sports database. Returns team details including formation year, stadium, location, social media links, and badge/logo URLs. Covers teams from soccer/football, American football, basketball, baseball, hockey, rugby, and more.",
    "parameter": {
      "type": "object",
      "properties": {
        "t": {
          "type": "string",
          "description": "Team name to search for (partial match). Examples: 'Arsenal', 'Manchester United', 'Lakers', 'New York Yankees', 'All Blacks'"
        }
      },
      "required": ["t"]
    },
    "fields": {
      "endpoint": "https://www.thesportsdb.com/api/v1/json/3/searchteams.php"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"t": "Arsenal"},
      {"t": "Los Angeles Lakers"},
      {"t": "New Zealand All Blacks"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Sports team search results",
              "properties": {
                "teams": {
                  "type": "array",
                  "description": "List of matching sports teams",
                  "items": {
                    "type": "object",
                    "properties": {
                      "idTeam": {"type": "string", "description": "Team ID (use for event lookups)"},
                      "strTeam": {"type": "string", "description": "Team name"},
                      "strTeamAlternate": {"type": ["string", "null"], "description": "Alternative team name"},
                      "intFormedYear": {"type": ["string", "null"], "description": "Year team was founded"},
                      "strSport": {"type": "string", "description": "Sport type (Soccer, Basketball, etc.)"},
                      "strLeague": {"type": ["string", "null"], "description": "Primary league"},
                      "strLeague2": {"type": ["string", "null"]},
                      "idLeague": {"type": ["string", "null"], "description": "League ID"},
                      "strStadium": {"type": ["string", "null"], "description": "Home stadium/venue name"},
                      "strStadiumLocation": {"type": ["string", "null"]},
                      "intStadiumCapacity": {"type": ["string", "null"]},
                      "strWebsite": {"type": ["string", "null"]},
                      "strFacebook": {"type": ["string", "null"]},
                      "strTwitter": {"type": ["string", "null"]},
                      "strInstagram": {"type": ["string", "null"]},
                      "strDescriptionEN": {"type": ["string", "null"], "description": "Team description"},
                      "strCountry": {"type": ["string", "null"], "description": "Country"},
                      "strBadge": {"type": ["string", "null"], "description": "URL to team badge/logo image"},
                      "strJersey": {"type": ["string", "null"], "description": "URL to jersey image"},
                      "strLogo": {"type": ["string", "null"]}
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "TheSportsDB_search_players",
    "description": "Search for sports players by name in TheSportsDB. Returns player details including nationality, position, team, birth date, and profile images. Covers players from soccer, basketball, American football, baseball, hockey, tennis, golf, rugby, and more.",
    "parameter": {
      "type": "object",
      "properties": {
        "p": {
          "type": "string",
          "description": "Player name to search for (partial match). Examples: 'Ronaldo', 'LeBron James', 'Serena Williams', 'Mike Trout'"
        }
      },
      "required": ["p"]
    },
    "fields": {
      "endpoint": "https://www.thesportsdb.com/api/v1/json/3/searchplayers.php"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"p": "Messi"},
      {"p": "LeBron James"},
      {"p": "Serena Williams"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Sports player search results",
              "properties": {
                "player": {
                  "type": "array",
                  "description": "List of matching players",
                  "items": {
                    "type": "object",
                    "properties": {
                      "idPlayer": {"type": "string", "description": "Player ID"},
                      "idTeam": {"type": ["string", "null"], "description": "Current team ID"},
                      "strPlayer": {"type": "string", "description": "Player full name"},
                      "strTeam": {"type": ["string", "null"], "description": "Current team name"},
                      "strSport": {"type": "string", "description": "Sport type"},
                      "strNationality": {"type": ["string", "null"], "description": "Player nationality"},
                      "strPosition": {"type": ["string", "null"], "description": "Playing position"},
                      "dateBorn": {"type": ["string", "null"], "description": "Birth date (YYYY-MM-DD)"},
                      "strBirthLocation": {"type": ["string", "null"]},
                      "strHeight": {"type": ["string", "null"]},
                      "strWeight": {"type": ["string", "null"]},
                      "strDescriptionEN": {"type": ["string", "null"], "description": "Player biography"},
                      "strThumb": {"type": ["string", "null"], "description": "Player photo thumbnail URL"},
                      "strCutout": {"type": ["string", "null"], "description": "Player cutout image URL"},
                      "strStatus": {"type": ["string", "null"], "description": "Career status (Active/Retired)"}
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "TheSportsDB_get_league_events",
    "description": "Get sports events/matches for a specific season from TheSportsDB. Returns match details including teams, date, time, venue, and results. Useful for analyzing sports schedules, results, and historical match data. Use TheSportsDB_search_teams to find the league ID first.",
    "parameter": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "League ID from TheSportsDB. Common IDs: '4328' (English Premier League), '4335' (German Bundesliga), '4346' (La Liga), '4480' (NBA), '4424' (NFL), '4424' (MLB). Use TheSportsDB_search_teams to find."
        },
        "s": {
          "type": "string",
          "description": "Season (format varies by sport). Soccer: '2023-2024'. Basketball/American sports: '2023-2024' or '2024'. Examples: '2023-2024', '2024'"
        }
      },
      "required": ["id", "s"]
    },
    "fields": {
      "endpoint": "https://www.thesportsdb.com/api/v1/json/3/eventsseason.php"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"id": "4328", "s": "2023-2024"},
      {"id": "4335", "s": "2023-2024"},
      {"id": "4480", "s": "2023-2024"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "League season event/match data",
              "properties": {
                "events": {
                  "type": "array",
                  "description": "List of matches/events in the season",
                  "items": {
                    "type": "object",
                    "properties": {
                      "idEvent": {"type": "string", "description": "Event/match ID"},
                      "strEvent": {"type": "string", "description": "Match name (e.g. 'Arsenal vs Chelsea')"},
                      "strSport": {"type": "string"},
                      "idLeague": {"type": "string"},
                      "strLeague": {"type": "string", "description": "League name"},
                      "strSeason": {"type": "string", "description": "Season"},
                      "strHomeTeam": {"type": ["string", "null"], "description": "Home team name"},
                      "strAwayTeam": {"type": ["string", "null"], "description": "Away team name"},
                      "intHomeScore": {"type": ["string", "null"], "description": "Home team final score"},
                      "intAwayScore": {"type": ["string", "null"], "description": "Away team final score"},
                      "dateEvent": {"type": ["string", "null"], "description": "Match date (YYYY-MM-DD)"},
                      "strTime": {"type": ["string", "null"], "description": "Match time"},
                      "strVenue": {"type": ["string", "null"], "description": "Stadium/venue name"},
                      "strCity": {"type": ["string", "null"]}
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
