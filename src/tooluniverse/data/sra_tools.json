[
  {
    "name": "SRA_search_experiments",
    "description": "Search the NCBI Sequence Read Archive (SRA) for sequencing experiments by keyword, organism, library strategy, or sequencing platform. SRA is the largest repository of raw sequencing data, containing data from Illumina, PacBio, Oxford Nanopore, and other platforms. Library strategies include: RNA-Seq, WGS (whole genome), WXS (whole exome), ChIP-Seq, ATAC-seq, Bisulfite-Seq, AMPLICON, scRNA-Seq, and more.",
    "parameter": {
      "type": "object",
      "properties": {
        "query": {
          "type": "string",
          "description": "Search keywords (e.g., 'human gut metagenome', 'BRCA1 RNA-Seq', 'single cell lung cancer')"
        },
        "organism": {
          "type": "string",
          "description": "Organism name to filter by (e.g., 'Homo sapiens', 'Mus musculus', 'human gut metagenome')"
        },
        "library_strategy": {
          "type": "string",
          "description": "Sequencing strategy filter (e.g., 'RNA-Seq', 'WGS', 'WXS', 'ChIP-Seq', 'ATAC-seq', 'Bisulfite-Seq', 'AMPLICON')"
        },
        "platform": {
          "type": "string",
          "description": "Sequencing platform filter (e.g., 'ILLUMINA', 'PACBIO_SMRT', 'OXFORD_NANOPORE', 'ION_TORRENT')"
        },
        "limit": {
          "type": "integer",
          "description": "Maximum results to return (1-50, default 10)",
          "default": 10
        }
      },
      "required": []
    },
    "fields": {
      "operation": "search"
    },
    "type": "SRATool",
    "test_examples": [
      {
        "query": "BRCA1",
        "organism": "Homo sapiens",
        "library_strategy": "RNA-Seq",
        "limit": 3
      },
      {
        "organism": "human gut metagenome",
        "limit": 3
      },
      {
        "query": "single cell kidney",
        "platform": "ILLUMINA",
        "limit": 3
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "total": {
              "type": "integer"
            },
            "returned": {
              "type": "integer"
            },
            "query_used": {
              "type": "string"
            },
            "experiments": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "uid": {
                    "type": "string"
                  },
                  "title": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "organism": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "taxid": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "platform": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "library_strategy": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "library_source": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "library_layout": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "total_runs": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "total_spots": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "total_bases": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "experiment_accession": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "study_accession": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "bioproject": {
                    "type": [
                      "string",
