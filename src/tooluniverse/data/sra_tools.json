        },
        {
          "type": "object",
          "properties": {
            "error": {
              "type": "string"
            }
          },
          "required": [
            "error"
          ]
        }
      ]
    }
  },
  {
    "name": "SRA_get_experiment",
    "description": "Get detailed metadata for a specific SRA experiment by accession number. Returns experiment title, organism, sequencing platform, library information, study details, and run statistics. Accepts SRA experiment accessions (SRX/ERX/DRX), study accessions (SRP/ERP/DRP), or sample accessions (SRS/ERS/DRS).",
    "parameter": {
      "type": "object",
      "properties": {
        "accession": {
          "type": "string",
          "description": "SRA accession number (e.g., 'SRX26927637', 'SRP000001', 'SRS000001')"
        }
      },
      "required": [
        "accession"
      ]
    },
    "fields": {
      "operation": "get_experiment"
    },
    "type": "SRATool",
    "test_examples": [
      {
        "accession": "SRX515811"
      },
      {
        "accession": "SRP000001"
      },
      {
        "accession": "SRS000001"
      }
    ],
