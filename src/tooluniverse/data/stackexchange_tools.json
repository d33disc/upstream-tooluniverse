[
  {
    "name": "StackExchange_search_questions",
    "description": "Search for questions on Stack Exchange sites (Stack Overflow, Super User, Server Fault, etc.) using the Stack Exchange API. Returns questions with title, score, answer count, and tags. No authentication required (rate limited to 300 requests/day without key). Useful for finding programming answers, tech questions, and knowledge discovery.",
    "parameter": {
      "type": "object",
      "properties": {
        "intitle": {
          "type": ["string", "null"],
          "description": "Search query to find in question titles. Examples: 'python list comprehension', 'git merge conflict', 'sql join performance'"
        },
        "tagged": {
          "type": ["string", "null"],
          "description": "Semicolon-separated tags to filter by. Examples: 'python', 'javascript;react', 'machine-learning;pytorch'"
        },
        "site": {
          "type": ["string", "null"],
          "description": "Stack Exchange site. Default: stackoverflow. Examples: 'stackoverflow', 'superuser', 'serverfault', 'unix', 'datascience'"
        },
        "sort": {
          "type": ["string", "null"],
          "description": "Sort order. Values: 'activity', 'votes', 'creation', 'relevance'. Default: 'activity'"
        },
        "order": {
          "type": ["string", "null"],
          "description": "Order direction. Values: 'desc', 'asc'. Default: 'desc'"
        },
        "pagesize": {
          "type": ["integer", "null"],
          "description": "Number of results per page (1-100). Default: 10"
        }
      },
      "required": []
    },
    "fields": {
      "endpoint": "https://api.stackexchange.com/2.3/search",
      "params": {"site": "stackoverflow"}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"intitle": "python list comprehension", "site": "stackoverflow", "sort": "votes", "pagesize": 5},
      {"tagged": "machine-learning", "sort": "votes", "pagesize": 5},
      {"intitle": "git merge conflict", "sort": "relevance", "pagesize": 5}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Stack Exchange question search results",
              "properties": {
                "items": {
                  "type": "array",
                  "description": "List of matching questions",
                  "items": {
                    "type": "object",
                    "properties": {
                      "question_id": {"type": "integer"},
                      "title": {"type": "string"},
                      "score": {"type": "integer", "description": "Vote score"},
                      "answer_count": {"type": "integer"},
                      "view_count": {"type": "integer"},
                      "is_answered": {"type": "boolean"},
                      "tags": {"type": "array", "items": {"type": "string"}},
                      "creation_date": {"type": "integer", "description": "Unix timestamp"},
                      "link": {"type": "string", "description": "Question URL"}
                    }
                  }
                },
                "has_more": {"type": "boolean"},
                "quota_remaining": {"type": "integer"}
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "StackExchange_get_top_questions",
    "description": "Get top-voted questions on Stack Exchange sites by tag or general site using the Stack Exchange API. No authentication required. Returns highly-voted programming questions with answers and scores.",
    "parameter": {
      "type": "object",
      "properties": {
        "tagged": {
          "type": ["string", "null"],
          "description": "Semicolon-separated tags to filter. Examples: 'python', 'javascript', 'sql', 'machine-learning'"
        },
        "site": {
          "type": ["string", "null"],
          "description": "Stack Exchange site. Default: stackoverflow. Values: 'stackoverflow', 'superuser', 'serverfault', 'datascience', 'stats'"
        },
        "pagesize": {
          "type": ["integer", "null"],
          "description": "Number of results (1-100). Default: 10"
        }
      },
      "required": []
    },
    "fields": {
      "endpoint": "https://api.stackexchange.com/2.3/questions",
      "params": {"site": "stackoverflow", "order": "desc", "sort": "votes"}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"tagged": "python", "pagesize": 5},
      {"tagged": "javascript", "site": "stackoverflow", "pagesize": 5},
      {"site": "datascience", "pagesize": 5}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Top-voted Stack Exchange questions",
              "properties": {
                "items": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "question_id": {"type": "integer"},
                      "title": {"type": "string"},
                      "score": {"type": "integer"},
                      "answer_count": {"type": "integer"},
                      "view_count": {"type": "integer"},
                      "is_answered": {"type": "boolean"},
                      "accepted_answer_id": {"type": ["integer", "null"]},
                      "tags": {"type": "array", "items": {"type": "string"}},
                      "link": {"type": "string"}
                    }
                  }
                },
                "has_more": {"type": "boolean"}
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
