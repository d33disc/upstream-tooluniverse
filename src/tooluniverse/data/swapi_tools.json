[
  {
    "name": "SWAPI_get_people",
    "description": "Get Star Wars characters (people) data using the Star Wars API (SWAPI). Returns character details including name, height, mass, birth year, homeworld, and films appeared in. No authentication required. Useful for Star Wars research, trivia, and fun applications.",
    "parameter": {
      "type": "object",
      "properties": {
        "search": {
          "type": ["string", "null"],
          "description": "Search by character name. Examples: 'luke', 'vader', 'leia', 'yoda', 'obi-wan', 'han'"
        },
        "page": {
          "type": ["integer", "null"],
          "description": "Page number (10 results per page). Default: 1"
        }
      },
      "required": []
    },
    "fields": {
      "endpoint": "https://swapi.dev/api/people/",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"search": "luke"},
      {"search": "vader"},
      {"search": "yoda"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Paginated Star Wars character results",
              "properties": {
                "count": {"type": "integer"},
                "results": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "name": {"type": "string"},
                      "height": {"type": "string"},
                      "mass": {"type": "string"},
                      "hair_color": {"type": "string"},
                      "skin_color": {"type": "string"},
                      "eye_color": {"type": "string"},
                      "birth_year": {"type": "string"},
                      "gender": {"type": "string"},
                      "homeworld": {"type": "string"},
                      "films": {"type": "array", "items": {"type": "string"}},
                      "species": {"type": "array", "items": {"type": "string"}}
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "SWAPI_get_films",
    "description": "Get Star Wars film data using the Star Wars API (SWAPI). Returns film title, episode ID, opening crawl, director, producer, release date, and character/planet/species lists. No authentication required.",
    "parameter": {
      "type": "object",
      "properties": {
        "search": {
          "type": ["string", "null"],
          "description": "Search by film title. Examples: 'hope', 'empire', 'jedi', 'phantom', 'clones', 'sith'"
        }
      },
      "required": []
    },
    "fields": {
      "endpoint": "https://swapi.dev/api/films/",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"search": "hope"},
      {"search": "empire"},
      {"search": "jedi"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Star Wars films",
              "properties": {
                "count": {"type": "integer"},
                "results": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "title": {"type": "string"},
                      "episode_id": {"type": "integer"},
                      "opening_crawl": {"type": "string"},
                      "director": {"type": "string"},
                      "producer": {"type": "string"},
                      "release_date": {"type": "string"},
                      "characters": {"type": "array", "items": {"type": "string"}},
                      "planets": {"type": "array", "items": {"type": "string"}}
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
