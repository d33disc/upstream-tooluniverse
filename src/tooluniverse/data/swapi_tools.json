[
  {
    "name": "SWAPI_search_people",
    "description": "Search for Star Wars characters by name. Returns character details including height, mass, hair/eye/skin color, birth year, gender, homeworld, films, species, vehicles, and starships. Data from the Star Wars API (SWAPI).",
    "parameter": {
      "type": "object",
      "properties": {
        "search": {
          "type": "string",
          "description": "Character name to search for (e.g., 'luke', 'darth vader', 'leia')"
        }
      },
      "required": ["search"]
    },
    "fields": {
      "endpoint": "https://swapi.dev/api/people/"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"search": "luke"},
      {"search": "darth"},
      {"search": "leia"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Star Wars character search results",
              "properties": {
                "count": {"type": "integer"},
                "results": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "name": {"type": "string"},
                      "height": {"type": "string"},
                      "mass": {"type": "string"},
                      "hair_color": {"type": "string"},
                      "skin_color": {"type": "string"},
                      "eye_color": {"type": "string"},
                      "birth_year": {"type": "string"},
                      "gender": {"type": "string"},
                      "homeworld": {"type": "string"},
                      "films": {"type": "array", "items": {"type": "string"}},
                      "species": {"type": "array"},
                      "vehicles": {"type": "array"},
                      "starships": {"type": "array"}
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {
            "error": {"type": "string"}
          },
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "SWAPI_get_person",
    "description": "Get detailed information about a specific Star Wars character by their SWAPI ID. Returns height, mass, appearance details, birth year, gender, homeworld URL, and lists of films, species, vehicles, and starships.",
    "parameter": {
      "type": "object",
      "properties": {
        "person_id": {
          "type": "integer",
          "description": "SWAPI person ID (e.g., 1 for Luke Skywalker, 4 for Darth Vader)"
        }
      },
      "required": ["person_id"]
    },
    "fields": {
      "endpoint": "https://swapi.dev/api/people/{person_id}/"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"person_id": 1},
      {"person_id": 4},
      {"person_id": 5}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Star Wars character details",
              "properties": {
                "name": {"type": "string"},
                "height": {"type": "string"},
                "mass": {"type": "string"},
                "hair_color": {"type": "string"},
                "skin_color": {"type": "string"},
                "eye_color": {"type": "string"},
                "birth_year": {"type": "string"},
                "gender": {"type": "string"},
                "homeworld": {"type": "string"},
                "films": {"type": "array"},
                "species": {"type": "array"},
                "vehicles": {"type": "array"},
                "starships": {"type": "array"}
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {
            "error": {"type": "string"}
          },
          "required": ["error"]
        }
      ]
    }
  },
