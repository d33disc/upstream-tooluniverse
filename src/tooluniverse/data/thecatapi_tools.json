[
  {
    "name": "TheCatAPI_search_breeds",
    "description": "Search for cat breeds by name using TheCatAPI. Returns breed information including temperament, origin, description, life span, and behavioral trait scores (1-5 scale for adaptability, affection, energy, intelligence, etc.). Useful for animal/pet research, breed comparison, and educational applications about feline diversity.",
    "parameter": {
      "type": "object",
      "properties": {
        "q": {
          "type": "string",
          "description": "Search query for breed name (partial match supported). Examples: 'persian', 'siam', 'bengal', 'maine'"
        }
      },
      "required": ["q"]
    },
    "fields": {
      "endpoint": "https://api.thecatapi.com/v1/breeds/search",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"q": "persian"},
      {"q": "siam"},
      {"q": "bengal"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "array",
              "description": "List of matching cat breeds",
              "items": {
                "type": "object",
                "properties": {
                  "id": {"type": "string", "description": "Breed ID code (e.g., 'pers', 'siam', 'beng')"},
                  "name": {"type": "string", "description": "Breed name (e.g., 'Persian', 'Siamese')"},
                  "temperament": {"type": "string", "description": "Comma-separated temperament traits"},
                  "origin": {"type": "string", "description": "Country/region of origin"},
                  "description": {"type": "string", "description": "Detailed breed description"},
                  "life_span": {"type": "string", "description": "Life span range in years (e.g., '12 - 15')"},
                  "weight": {
                    "type": "object",
                    "properties": {
                      "imperial": {"type": "string", "description": "Weight in pounds"},
                      "metric": {"type": "string", "description": "Weight in kilograms"}
                    }
                  },
                  "adaptability": {"type": "integer", "description": "Adaptability score (1-5)"},
                  "affection_level": {"type": "integer", "description": "Affection level score (1-5)"},
                  "child_friendly": {"type": "integer", "description": "Child friendliness (1-5)"},
                  "dog_friendly": {"type": "integer", "description": "Dog friendliness (1-5)"},
                  "energy_level": {"type": "integer", "description": "Energy level (1-5)"},
                  "grooming": {"type": "integer", "description": "Grooming needs (1-5)"},
                  "health_issues": {"type": "integer", "description": "Health issues tendency (1-5)"},
                  "intelligence": {"type": "integer", "description": "Intelligence level (1-5)"},
                  "shedding_level": {"type": "integer", "description": "Shedding level (1-5)"},
                  "social_needs": {"type": "integer", "description": "Social needs (1-5)"},
                  "stranger_friendly": {"type": "integer", "description": "Stranger friendliness (1-5)"},
                  "vocalisation": {"type": "integer", "description": "Vocalization tendency (1-5)"},
                  "wikipedia_url": {"type": ["string", "null"], "description": "Wikipedia article URL for the breed"},
                  "country_code": {"type": "string", "description": "ISO country code of origin"},
                  "alt_names": {"type": "string", "description": "Alternative breed names"},
                  "cfa_url": {"type": ["string", "null"], "description": "Cat Fanciers' Association URL"},
                  "vetstreet_url": {"type": ["string", "null"], "description": "VetStreet URL"},
                  "vcahospitals_url": {"type": ["string", "null"], "description": "VCA Hospitals URL"}
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "TheCatAPI_get_breed",
    "description": "Get detailed information about a specific cat breed by its ID from TheCatAPI. Returns comprehensive breed data including physical characteristics, temperament traits, behavioral scores, origin, life span, and links to breed resources. Use TheCatAPI_search_breeds to find breed IDs first.",
    "parameter": {
      "type": "object",
      "properties": {
        "breed_id": {
          "type": "string",
          "description": "Breed ID code (e.g., 'abys' for Abyssinian, 'pers' for Persian, 'siam' for Siamese, 'beng' for Bengal, 'ragd' for Ragdoll, 'mcoo' for Maine Coon)"
        }
      },
      "required": ["breed_id"]
    },
    "fields": {
      "endpoint": "https://api.thecatapi.com/v1/breeds/{breed_id}",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"breed_id": "abys"},
      {"breed_id": "pers"},
      {"breed_id": "siam"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Detailed cat breed information",
              "properties": {
                "id": {"type": "string", "description": "Breed ID code"},
                "name": {"type": "string", "description": "Breed name"},
                "temperament": {"type": "string", "description": "Comma-separated temperament traits"},
                "origin": {"type": "string", "description": "Country/region of origin"},
                "description": {"type": "string", "description": "Detailed breed description"},
                "life_span": {"type": "string", "description": "Life span range in years"},
                "weight": {
                  "type": "object",
                  "properties": {
                    "imperial": {"type": "string"},
                    "metric": {"type": "string"}
                  }
                },
                "adaptability": {"type": "integer", "description": "Adaptability score (1-5)"},
                "affection_level": {"type": "integer", "description": "Affection level (1-5)"},
                "child_friendly": {"type": "integer", "description": "Child friendliness (1-5)"},
                "dog_friendly": {"type": "integer", "description": "Dog friendliness (1-5)"},
                "energy_level": {"type": "integer", "description": "Energy level (1-5)"},
                "grooming": {"type": "integer", "description": "Grooming needs (1-5)"},
                "health_issues": {"type": "integer", "description": "Health issues tendency (1-5)"},
                "intelligence": {"type": "integer", "description": "Intelligence (1-5)"},
                "shedding_level": {"type": "integer", "description": "Shedding level (1-5)"},
                "social_needs": {"type": "integer", "description": "Social needs (1-5)"},
                "stranger_friendly": {"type": "integer", "description": "Stranger friendliness (1-5)"},
                "vocalisation": {"type": "integer", "description": "Vocalization tendency (1-5)"},
                "indoor": {"type": "integer", "description": "Indoor preference (0 or 1)"},
                "lap": {"type": ["integer", "null"], "description": "Lap cat tendency (0 or 1)"},
                "hairless": {"type": "integer", "description": "Whether breed is hairless (0 or 1)"},
                "natural": {"type": "integer", "description": "Whether breed is natural (0 or 1)"},
                "rare": {"type": "integer", "description": "Whether breed is rare (0 or 1)"},
                "hypoallergenic": {"type": "integer", "description": "Whether breed is hypoallergenic (0 or 1)"},
                "wikipedia_url": {"type": ["string", "null"], "description": "Wikipedia article URL"},
                "reference_image_id": {"type": ["string", "null"], "description": "Reference image ID for the breed"}
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "TheCatAPI_list_breeds",
    "description": "List all available cat breeds from TheCatAPI with pagination support. Returns breed names, IDs, descriptions, and trait scores for all 67 registered breeds. Useful for browsing the complete cat breed catalog or building breed selection interfaces.",
    "parameter": {
      "type": "object",
      "properties": {
        "limit": {
          "type": ["integer", "null"],
          "description": "Number of breeds to return per page (default returns all ~67 breeds)"
        },
        "page": {
          "type": ["integer", "null"],
          "description": "Page number for pagination (0-indexed, default: 0). Use with limit parameter."
        }
      },
      "required": []
    },
    "fields": {
      "endpoint": "https://api.thecatapi.com/v1/breeds",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {},
      {"limit": 5, "page": 0},
      {"limit": 10, "page": 1}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "array",
              "description": "List of cat breeds",
              "items": {
                "type": "object",
                "properties": {
                  "id": {"type": "string", "description": "Breed ID code"},
                  "name": {"type": "string", "description": "Breed name"},
                  "temperament": {"type": "string", "description": "Temperament traits"},
                  "origin": {"type": "string", "description": "Country/region of origin"},
                  "description": {"type": "string", "description": "Breed description"},
                  "life_span": {"type": "string", "description": "Life span range"},
                  "weight": {"type": "object"},
                  "intelligence": {"type": "integer"},
                  "energy_level": {"type": "integer"},
                  "affection_level": {"type": "integer"}
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "TheCatAPI_search_images",
    "description": "Search for cat images from TheCatAPI. Returns random cat image URLs optionally filtered by breed. No API key required for basic image search. Useful for random cat images, breed-specific photos, or building cat-related applications.",
    "parameter": {
      "type": "object",
      "properties": {
        "limit": {
          "type": ["integer", "null"],
          "description": "Number of images to return (1-10, default: 1)"
        },
        "breed_ids": {
          "type": ["string", "null"],
          "description": "Filter by breed ID(s), comma-separated. Examples: 'pers' (Persian), 'siam' (Siamese), 'beng' (Bengal), 'ragd' (Ragdoll), 'mcoo' (Maine Coon)"
        }
      },
      "required": []
    },
    "fields": {
      "endpoint": "https://api.thecatapi.com/v1/images/search",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"limit": 3},
      {"breed_ids": "pers", "limit": 2},
      {"breed_ids": "siam", "limit": 1}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "array",
              "description": "List of cat images",
              "items": {
                "type": "object",
                "properties": {
                  "id": {"type": "string", "description": "Image ID"},
                  "url": {"type": "string", "description": "Direct URL to the cat image"},
                  "width": {"type": "integer", "description": "Image width in pixels"},
                  "height": {"type": "integer", "description": "Image height in pixels"},
                  "breeds": {
                    "type": "array",
                    "description": "Breed information for the cat in the image (if filtered by breed)",
                    "items": {
                      "type": "object",
                      "properties": {
                        "id": {"type": "string"},
                        "name": {"type": "string"},
                        "temperament": {"type": "string"}
                      }
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
