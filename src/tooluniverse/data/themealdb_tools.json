  {
    "name": "TheMealDB_filter_meals",
    "description": "Filter meals from TheMealDB by main ingredient, category, or cuisine area. Returns an abbreviated list of matching meals (name, thumbnail, and ID only -- not full recipes). Use TheMealDB_lookup_meal with the returned idMeal to get full recipe details. Useful for discovering meals by ingredient, exploring category-specific recipes, or browsing cuisine-specific dishes.",
    "parameter": {
      "type": "object",
      "properties": {
        "i": {
          "type": ["string", "null"],
          "description": "Filter by main ingredient name. Examples: 'chicken_breast', 'salmon', 'rice', 'avocado', 'bacon', 'beef', 'pasta'"
        },
        "c": {
          "type": ["string", "null"],
          "description": "Filter by category. Values: 'Beef', 'Chicken', 'Dessert', 'Lamb', 'Miscellaneous', 'Pasta', 'Pork', 'Seafood', 'Side', 'Starter', 'Vegan', 'Vegetarian', 'Breakfast', 'Goat'"
        },
        "a": {
          "type": ["string", "null"],
          "description": "Filter by cuisine area. Values: 'Italian', 'Japanese', 'Mexican', 'Indian', 'French', 'Chinese', 'American', 'British', 'Greek', 'Spanish', 'Thai', 'Turkish', 'Canadian', 'Vietnamese', 'Dutch', 'Egyptian', 'Filipino', 'Jamaican', 'Kenyan', 'Malaysian', 'Polish', 'Portuguese', 'Russian'"
        }
      },
      "required": []
    },
    "fields": {
      "endpoint": "https://www.themealdb.com/api/json/v1/1/filter.php"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"i": "chicken_breast"},
      {"c": "Seafood"},
      {"a": "Japanese"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Filtered meal list (abbreviated -- name, thumbnail, and ID only)",
              "properties": {
                "meals": {
                  "type": ["array", "null"],
                  "description": "List of matching meals (null if no results). Use TheMealDB_lookup_meal for full details.",
                  "items": {
                    "type": "object",
                    "properties": {
                      "strMeal": {"type": "string", "description": "Meal name"},
                      "strMealThumb": {"type": "string", "description": "Meal thumbnail image URL"},
                      "idMeal": {"type": "string", "description": "Meal ID (use with TheMealDB_lookup_meal for full recipe)"}
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "TheMealDB_lookup_meal",
    "description": "Look up the full details of a specific meal by its ID from TheMealDB. Returns the complete recipe including all ingredients (up to 20), measurements, cooking instructions, category, cuisine area, tags, and YouTube video link. Use this after finding meal IDs from search or filter results.",
    "parameter": {
      "type": "object",
      "properties": {
        "i": {
          "type": "string",
          "description": "Meal ID to look up. Examples: '52772' (Teriyaki Chicken Casserole), '52940' (Brown Stew Chicken), '52959' (Baked salmon with fennel & tomatoes), '53013' (Big Mac), '52855' (Banana Pancakes)"
        }
      },
      "required": ["i"]
    },
    "fields": {
      "endpoint": "https://www.themealdb.com/api/json/v1/1/lookup.php"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"i": "52772"},
      {"i": "52940"},
      {"i": "52855"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Meal lookup result",
              "properties": {
                "meals": {
                  "type": ["array", "null"],
                  "description": "Array with single meal object (null if ID not found)",
                  "items": {
                    "type": "object",
                    "properties": {
                      "idMeal": {"type": "string", "description": "Meal ID"},
                      "strMeal": {"type": "string", "description": "Meal name"},
                      "strCategory": {"type": ["string", "null"], "description": "Food category (e.g., Chicken, Seafood, Dessert)"},
                      "strArea": {"type": ["string", "null"], "description": "Cuisine origin area (e.g., Japanese, Italian)"},
                      "strInstructions": {"type": ["string", "null"], "description": "Full cooking instructions"},
                      "strMealThumb": {"type": ["string", "null"], "description": "Meal photo URL"},
                      "strTags": {"type": ["string", "null"], "description": "Comma-separated tags"},
                      "strYoutube": {"type": ["string", "null"], "description": "YouTube recipe video URL"},
                      "strSource": {"type": ["string", "null"], "description": "Recipe source URL"},
                      "strIngredient1": {"type": ["string", "null"]},
                      "strMeasure1": {"type": ["string", "null"]},
                      "strIngredient2": {"type": ["string", "null"]},
                      "strMeasure2": {"type": ["string", "null"]},
                      "strIngredient3": {"type": ["string", "null"]},
                      "strMeasure3": {"type": ["string", "null"]},
                      "strIngredient4": {"type": ["string", "null"]},
                      "strMeasure4": {"type": ["string", "null"]},
                      "strIngredient5": {"type": ["string", "null"]},
                      "strMeasure5": {"type": ["string", "null"]}
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
