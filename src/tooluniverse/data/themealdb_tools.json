[
  {
    "name": "TheMealDB_search_meals",
    "description": "Search for meal recipes in TheMealDB, a free food recipe database with 300+ international recipes. Returns meals with full ingredients list, cooking instructions, category (Beef, Chicken, Seafood, Dessert, etc.), cuisine area (Italian, Indian, Japanese, Mexican, etc.), and YouTube tutorial links. Useful for food science research, culinary AI applications, and cultural food studies.",
    "parameter": {
      "type": "object",
      "properties": {
        "s": {
          "type": ["string", "null"],
          "description": "Search by meal name. Examples: 'chicken', 'pasta', 'sushi', 'beef stew', 'chocolate cake'"
        },
        "f": {
          "type": ["string", "null"],
          "description": "Search by first letter of meal name. Single character: 'a', 'b', 'c', etc."
        }
      },
      "required": []
    },
    "fields": {
      "endpoint": "https://www.themealdb.com/api/json/v1/1/search.php"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"s": "chicken"},
      {"s": "pasta"},
      {"f": "b"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Meal recipe search results",
              "properties": {
                "meals": {
                  "type": ["array", "null"],
                  "description": "List of matching meals (null if no results)",
                  "items": {
                    "type": "object",
                    "properties": {
                      "idMeal": {"type": "string", "description": "Meal ID"},
                      "strMeal": {"type": "string", "description": "Meal name"},
                      "strCategory": {"type": ["string", "null"], "description": "Food category"},
                      "strArea": {"type": ["string", "null"], "description": "Cuisine origin area"},
                      "strInstructions": {"type": ["string", "null"], "description": "Full cooking instructions"},
                      "strMealThumb": {"type": ["string", "null"], "description": "Meal photo URL"},
                      "strTags": {"type": ["string", "null"], "description": "Comma-separated tags"},
                      "strYoutube": {"type": ["string", "null"], "description": "YouTube recipe video URL"},
                      "strIngredient1": {"type": ["string", "null"], "description": "First ingredient"},
                      "strMeasure1": {"type": ["string", "null"], "description": "First ingredient measure"},
                      "strIngredient2": {"type": ["string", "null"]},
                      "strIngredient3": {"type": ["string", "null"]},
                      "strIngredient4": {"type": ["string", "null"]},
                      "strIngredient5": {"type": ["string", "null"]}
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
