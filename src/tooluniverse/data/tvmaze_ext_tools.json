[
  {
    "name": "TVmaze_get_show_episodes",
    "description": "Get all episodes of a TV show by TVmaze show ID using the TVmaze API. Returns episode list with names, season/episode numbers, air dates, runtimes, and summaries. Use TVmaze_search_shows to find show IDs. No authentication required.",
    "parameter": {
      "type": "object",
      "properties": {
        "show_id": {
          "type": "integer",
          "description": "TVmaze show ID. Examples: 169 (Game of Thrones), 82 (Game of Thrones alt), 66 (Lost), 1668 (Stranger Things), 143 (Breaking Bad)"
        },
        "specials": {
          "type": ["integer", "null"],
          "description": "Include special episodes (1=yes, 0=no). Default: 0"
        }
      },
      "required": ["show_id"]
    },
    "fields": {
      "endpoint": "https://api.tvmaze.com/shows/{show_id}/episodes",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"show_id": 169},
      {"show_id": 143},
      {"show_id": 1668}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "array",
              "description": "List of all episodes for the show",
              "items": {
                "type": "object",
                "properties": {
                  "id": {"type": "integer"},
                  "name": {"type": "string"},
                  "season": {"type": "integer"},
                  "number": {"type": ["integer", "null"]},
                  "airdate": {"type": ["string", "null"]},
                  "runtime": {"type": ["integer", "null"]},
                  "rating": {"type": "object", "properties": {"average": {"type": ["number", "null"]}}},
                  "summary": {"type": ["string", "null"]}
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "TVmaze_get_schedule",
    "description": "Get TV show schedule for a specific date and country using the TVmaze API. Returns list of episodes airing that day with show name, network, time, and episode details. No authentication required. Useful for TV listings and programming guides.",
    "parameter": {
      "type": "object",
      "properties": {
        "date": {
          "type": ["string", "null"],
          "description": "Date in YYYY-MM-DD format. Default: today. Examples: '2024-01-15', '2025-03-01'"
        },
        "country": {
          "type": ["string", "null"],
          "description": "ISO 3166-1 country code. Default: US. Examples: 'US', 'GB', 'AU', 'CA', 'DE'"
        }
      },
      "required": []
    },
    "fields": {
      "endpoint": "https://api.tvmaze.com/schedule",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"date": "2024-01-15", "country": "US"},
      {"date": "2024-06-01", "country": "GB"},
      {"country": "US"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "array",
              "description": "TV schedule entries for the specified date and country",
              "items": {
                "type": "object",
                "properties": {
                  "id": {"type": "integer"},
                  "name": {"type": "string"},
                  "season": {"type": "integer"},
                  "number": {"type": ["integer", "null"]},
                  "airdate": {"type": "string"},
                  "airtime": {"type": "string"},
                  "runtime": {"type": ["integer", "null"]},
                  "show": {
                    "type": "object",
                    "properties": {
                      "id": {"type": "integer"},
                      "name": {"type": "string"},
                      "genres": {"type": "array", "items": {"type": "string"}},
                      "network": {"type": ["object", "null"]}
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
