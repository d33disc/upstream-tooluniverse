[
  {
    "name": "TVmaze_search_shows",
    "description": "Search for TV shows in the TVmaze database, which covers 45,000+ shows with ratings, genres, network, and episode information. Returns show metadata including title, genre, language, status, premiere/end dates, and ratings. Useful for media research, entertainment analytics, and cultural studies.",
    "parameter": {
      "type": "object",
      "properties": {
        "q": {
          "type": "string",
          "description": "Search query (show title). Examples: 'Breaking Bad', 'Game of Thrones', 'The Wire', 'Chernobyl'"
        }
      },
      "required": ["q"]
    },
    "fields": {
      "endpoint": "https://api.tvmaze.com/search/shows"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"q": "Breaking Bad"},
      {"q": "Planet Earth"},
      {"q": "The Wire"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "array",
              "description": "TV show search results",
              "items": {
                "type": "object",
                "properties": {
                  "score": {"type": "number", "description": "Relevance score"},
                  "show": {
                    "type": "object",
                    "description": "TV show details",
                    "properties": {
                      "id": {"type": "integer", "description": "TVmaze show ID"},
                      "url": {"type": "string", "description": "TVmaze URL"},
                      "name": {"type": "string", "description": "Show title"},
                      "type": {"type": ["string", "null"], "description": "Show type (Scripted, Reality, etc.)"},
                      "language": {"type": ["string", "null"], "description": "Primary language"},
                      "genres": {"type": "array", "items": {"type": "string"}, "description": "Genre list"},
                      "status": {"type": ["string", "null"], "description": "Show status (Running, Ended, etc.)"},
                      "runtime": {"type": ["integer", "null"], "description": "Episode runtime in minutes"},
                      "premiered": {"type": ["string", "null"], "description": "First air date (YYYY-MM-DD)"},
                      "ended": {"type": ["string", "null"], "description": "Final air date"},
                      "officialSite": {"type": ["string", "null"], "description": "Official website URL"},
                      "rating": {
                        "type": "object",
                        "properties": {"average": {"type": ["number", "null"], "description": "Average user rating"}}
                      },
                      "network": {
                        "type": ["object", "null"],
                        "description": "Broadcast network",
                        "properties": {
                          "name": {"type": "string"},
                          "country": {"type": ["object", "null"]}
                        }
                      },
                      "summary": {"type": ["string", "null"], "description": "Show synopsis"}
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "TVmaze_get_show",
    "description": "Get detailed information about a specific TV show from TVmaze using its ID. Returns comprehensive show metadata including all genres, cast, crew, episodes, network, and rating. Use TVmaze_search_shows to find show IDs first.",
    "parameter": {
      "type": "object",
      "properties": {
        "show_id": {
          "type": "integer",
          "description": "TVmaze show ID. Common IDs: 169 (Breaking Bad), 82 (Game of Thrones), 1871 (Chernobyl), 1236 (Planet Earth)"
        }
      },
      "required": ["show_id"]
    },
    "fields": {
      "endpoint": "https://api.tvmaze.com/shows/{show_id}"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"show_id": 169},
      {"show_id": 82},
      {"show_id": 1871}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "TV show details",
              "properties": {
                "id": {"type": "integer"},
                "name": {"type": "string"},
                "type": {"type": ["string", "null"]},
                "language": {"type": ["string", "null"]},
                "genres": {"type": "array", "items": {"type": "string"}},
                "status": {"type": ["string", "null"]},
                "runtime": {"type": ["integer", "null"]},
                "premiered": {"type": ["string", "null"]},
                "ended": {"type": ["string", "null"]},
                "officialSite": {"type": ["string", "null"]},
                "rating": {"type": "object"},
                "network": {"type": ["object", "null"]},
                "summary": {"type": ["string", "null"]},
                "updated": {"type": "integer"}
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
