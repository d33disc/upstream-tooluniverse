[
  {
    "name": "University_search",
    "description": "Search for universities worldwide by name and/or country. Returns university name, country, web pages, and domain names. Data sourced from the Hipo Labs University Domains API covering universities across the globe.",
    "parameter": {
      "type": "object",
      "properties": {
        "name": {
          "type": ["string", "null"],
          "description": "University name to search for (e.g., 'Harvard', 'Oxford', 'MIT')"
        },
        "country": {
          "type": ["string", "null"],
          "description": "Country name to filter by (e.g., 'United States', 'United Kingdom', 'Germany')"
        }
      },
      "required": []
    },
    "fields": {
      "endpoint": "http://universities.hipolabs.com/search"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"name": "Harvard"},
      {"name": "Oxford", "country": "United Kingdom"},
      {"country": "Switzerland", "name": "ETH"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "array",
              "description": "List of matching universities",
              "items": {
                "type": "object",
                "properties": {
                  "name": {"type": "string", "description": "Full university name"},
                  "country": {"type": "string"},
                  "alpha_two_code": {"type": "string", "description": "ISO 3166 country code"},
                  "web_pages": {"type": "array", "items": {"type": "string"}, "description": "University website URLs"},
                  "domains": {"type": "array", "items": {"type": "string"}, "description": "University domain names"},
                  "state-province": {"type": ["string", "null"]}
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {
            "error": {"type": "string"}
          },
          "required": ["error"]
        }
      ]
    }
  }
]
