[
  {
    "name": "UrbanDictionary_define",
    "description": "Look up slang terms, informal expressions, and internet jargon on Urban Dictionary. Returns crowd-sourced definitions with examples, author, upvotes/downvotes, and permalink. Urban Dictionary is the go-to resource for understanding informal language, memes, acronyms, and cultural slang. No authentication required. Useful for understanding colloquial language, internet culture, and informal expressions.",
    "parameter": {
      "type": "object",
      "properties": {
        "term": {
          "type": "string",
          "description": "Slang term or phrase to define (e.g., 'YOLO', 'slay', 'sigma', 'rizz', 'gaslighting', 'vibe check', 'touch grass')"
        }
      },
      "required": ["term"]
    },
    "fields": {
      "endpoint": "https://api.urbandictionary.com/v0/define"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"term": "YOLO"},
      {"term": "slay"},
      {"term": "touch grass"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Urban Dictionary definitions",
              "properties": {
                "list": {
                  "type": "array",
                  "description": "Definitions sorted by relevance/votes",
                  "items": {
                    "type": "object",
                    "properties": {
                      "word": {"type": "string", "description": "The defined term"},
                      "definition": {"type": "string", "description": "Definition text (may contain [bracketed] links to other terms)"},
                      "example": {"type": "string", "description": "Usage example"},
                      "author": {"type": "string", "description": "Definition author username"},
                      "thumbs_up": {"type": "integer", "description": "Number of upvotes"},
                      "thumbs_down": {"type": "integer", "description": "Number of downvotes"},
                      "defid": {"type": "integer", "description": "Unique definition ID"},
                      "permalink": {"type": "string", "description": "Permanent URL to this definition"},
                      "written_on": {"type": "string", "description": "Date written (ISO 8601)"}
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "UrbanDictionary_random",
    "description": "Get random slang term definitions from Urban Dictionary. Returns a set of random definitions, useful for discovering new slang, internet jargon, and informal language. No authentication required. Each call returns different random terms.",
    "parameter": {
      "type": "object",
      "properties": {},
      "required": []
    },
    "fields": {
      "endpoint": "https://api.urbandictionary.com/v0/random"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Random Urban Dictionary definitions",
              "properties": {
                "list": {
                  "type": "array",
                  "description": "Random definitions",
                  "items": {
                    "type": "object",
                    "properties": {
                      "word": {"type": "string"},
                      "definition": {"type": "string"},
                      "example": {"type": "string"},
                      "author": {"type": "string"},
                      "thumbs_up": {"type": "integer"},
                      "thumbs_down": {"type": "integer"},
                      "defid": {"type": "integer"},
                      "permalink": {"type": "string"},
                      "written_on": {"type": "string"}
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
