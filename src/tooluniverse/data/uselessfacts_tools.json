[
  {
    "name": "UselessFact_get_random",
    "description": "Get a random useless fact from the Useless Facts API. Returns an interesting but trivial fact with source attribution and permalink. No authentication required. Useful for trivia apps, entertainment, daily fun facts, or icebreaker content.",
    "parameter": {
      "type": "object",
      "properties": {
        "language": {
          "type": ["string", "null"],
          "description": "Language for the fact. Options: 'en' (English), 'de' (German). Default: 'en'"
        }
      },
      "required": []
    },
    "fields": {
      "endpoint": "https://uselessfacts.jsph.pl/api/v2/facts/random",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {},
      {"language": "en"},
      {"language": "de"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Random useless fact response",
              "properties": {
                "id": {"type": "string", "description": "Unique fact ID (hash)"},
                "text": {"type": "string", "description": "The useless fact text"},
                "source": {"type": "string", "description": "Source name"},
                "source_url": {"type": "string", "description": "URL of the source"},
                "language": {"type": "string", "description": "Language of the fact (en or de)"},
                "permalink": {"type": "string", "description": "Permanent link to this fact"}
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
