[
  {
    "name": "WhereTheISSAt_get_position",
    "description": "Get the current position and velocity of the International Space Station (ISS) using the Where the ISS At API. Returns real-time latitude, longitude, altitude (km), velocity (km/h), and visibility (daylight/eclipse). No authentication required. Updates in near real-time.",
    "parameter": {
      "type": "object",
      "properties": {
        "units": {
          "type": ["string", "null"],
          "description": "Unit system for distance/velocity. Values: 'kilometers', 'miles'. Default: kilometers"
        }
      },
      "required": []
    },
    "fields": {
      "endpoint": "https://api.wheretheiss.at/v1/satellites/25544",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {},
      {"units": "kilometers"},
      {"units": "miles"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Current ISS position and orbital data",
              "properties": {
                "name": {"type": "string", "description": "Satellite name (iss)"},
                "id": {"type": "integer", "description": "NORAD catalog ID (25544)"},
                "latitude": {"type": "number", "description": "Current latitude (-90 to 90)"},
                "longitude": {"type": "number", "description": "Current longitude (-180 to 180)"},
                "altitude": {"type": "number", "description": "Altitude in km above sea level"},
                "velocity": {"type": "number", "description": "Orbital velocity in km/h"},
                "visibility": {"type": "string", "description": "daylight or eclipsed"},
                "footprint": {"type": "number", "description": "Diameter of ISS visibility footprint (km)"},
                "timestamp": {"type": "integer", "description": "Unix timestamp"},
                "solar_lat": {"type": "number"},
                "solar_lon": {"type": "number"},
                "units": {"type": "string"}
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
