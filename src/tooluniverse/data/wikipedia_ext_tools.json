[
  {
    "name": "Wikipedia_get_featured_content",
    "description": "Get Wikipedia's featured content for a specific date including the featured article of the day, most-read articles, picture of the day, and on-this-day events using the Wikipedia REST API. No authentication required. Useful for daily briefings and trending content discovery.",
    "parameter": {
      "type": "object",
      "properties": {
        "year": {
          "type": "integer",
          "description": "Year. Examples: 2023, 2024"
        },
        "month": {
          "type": "integer",
          "description": "Month number (1-12). Examples: 1, 6, 12"
        },
        "day": {
          "type": "integer",
          "description": "Day of month (1-31). Examples: 1, 15, 25"
        }
      },
      "required": ["year", "month", "day"]
    },
    "fields": {
      "endpoint": "https://en.wikipedia.org/api/rest_v1/feed/featured/{year}/{month}/{day}",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"year": 2024, "month": 1, "day": 15},
      {"year": 2024, "month": 7, "day": 4},
      {"year": 2023, "month": 12, "day": 25}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Wikipedia featured content for the specified date",
              "properties": {
                "tfa": {
                  "type": "object",
                  "description": "Today's featured article",
                  "properties": {
                    "title": {"type": "string"},
                    "extract": {"type": "string"},
                    "description": {"type": ["string", "null"]}
                  }
                },
                "mostread": {
                  "type": "object",
                  "description": "Most-read articles of the day",
                  "properties": {
                    "articles": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "title": {"type": "string"},
                          "views": {"type": "integer"},
                          "description": {"type": ["string", "null"]}
                        }
                      }
                    }
                  }
                },
                "onthisday": {
                  "type": "array",
                  "description": "On-this-day historical events",
                  "items": {
                    "type": "object",
                    "properties": {
                      "year": {"type": "integer"},
                      "text": {"type": "string"}
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
