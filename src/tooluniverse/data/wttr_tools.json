[
  {
    "name": "Wttr_get_weather",
    "description": "Get current weather conditions and 3-day forecast for any location worldwide using wttr.in. Returns temperature, humidity, wind speed/direction, cloud cover, precipitation, UV index, visibility, sunrise/sunset times, and moon phase. Supports city names, airport codes, GPS coordinates, and landmarks. No authentication required.",
    "parameter": {
      "type": "object",
      "properties": {
        "location": {
          "type": "string",
          "description": "Location to get weather for. Supports: city names ('London', 'New York'), airport codes ('JFK'), coordinates ('48.8566,2.3522'), landmarks ('Eiffel Tower'), IP addresses, or domain names."
        }
      },
      "required": ["location"]
    },
    "fields": {
      "endpoint": "https://wttr.in/{location}",
      "params": {
        "format": "j1"
      }
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"location": "London"},
      {"location": "Tokyo"},
      {"location": "New York"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Weather data with current conditions and forecast",
              "properties": {
                "current_condition": {
                  "type": "array",
                  "description": "Current weather conditions (single element array)",
                  "items": {
                    "type": "object",
                    "properties": {
                      "temp_C": {"type": "string", "description": "Temperature in Celsius"},
                      "temp_F": {"type": "string", "description": "Temperature in Fahrenheit"},
                      "FeelsLikeC": {"type": "string", "description": "Feels-like temperature in Celsius"},
                      "FeelsLikeF": {"type": "string", "description": "Feels-like temperature in Fahrenheit"},
                      "humidity": {"type": "string", "description": "Humidity percentage"},
                      "windspeedKmph": {"type": "string", "description": "Wind speed in km/h"},
                      "windspeedMiles": {"type": "string", "description": "Wind speed in mph"},
                      "winddir16Point": {"type": "string", "description": "Wind direction (e.g., 'NNW', 'SE')"},
                      "winddirDegree": {"type": "string", "description": "Wind direction in degrees"},
                      "weatherDesc": {"type": "array", "items": {"type": "object", "properties": {"value": {"type": "string"}}}},
                      "weatherCode": {"type": "string"},
                      "cloudcover": {"type": "string", "description": "Cloud cover percentage"},
                      "precipMM": {"type": "string", "description": "Precipitation in mm"},
                      "pressure": {"type": "string", "description": "Atmospheric pressure in mb"},
                      "visibility": {"type": "string", "description": "Visibility in km"},
                      "uvIndex": {"type": "string", "description": "UV index"},
                      "observation_time": {"type": "string", "description": "Time of observation"}
                    }
                  }
                },
                "nearest_area": {
                  "type": "array",
                  "description": "Nearest area information",
                  "items": {
                    "type": "object",
                    "properties": {
                      "areaName": {"type": "array", "items": {"type": "object", "properties": {"value": {"type": "string"}}}},
                      "country": {"type": "array", "items": {"type": "object", "properties": {"value": {"type": "string"}}}},
                      "region": {"type": "array", "items": {"type": "object", "properties": {"value": {"type": "string"}}}},
                      "latitude": {"type": "string"},
                      "longitude": {"type": "string"}
                    }
                  }
                },
                "weather": {
                  "type": "array",
                  "description": "3-day weather forecast",
                  "items": {
                    "type": "object",
                    "properties": {
                      "date": {"type": "string"},
                      "maxtempC": {"type": "string"},
                      "mintempC": {"type": "string"},
                      "maxtempF": {"type": "string"},
                      "mintempF": {"type": "string"},
                      "avgtempC": {"type": "string"},
                      "avgtempF": {"type": "string"},
                      "totalSnow_cm": {"type": "string"},
                      "sunHour": {"type": "string"},
                      "uvIndex": {"type": "string"},
                      "astronomy": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "sunrise": {"type": "string"},
                            "sunset": {"type": "string"},
                            "moonrise": {"type": "string"},
                            "moonset": {"type": "string"},
                            "moon_phase": {"type": "string"},
                            "moon_illumination": {"type": "string"}
                          }
                        }
                      },
                      "hourly": {"type": "array", "description": "Hourly forecast data"}
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
