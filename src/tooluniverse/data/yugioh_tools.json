[
  {
    "name": "YuGiOh_search_cards",
    "description": "Search for Yu-Gi-Oh! trading card game cards using the YGOPRODeck API. Supports fuzzy name matching and filtering by type, attribute, level, race (monster subtype), archetype, and more. Returns card details including stats, descriptions, images, and card set appearances. Database contains 13,000+ unique cards. No authentication required.",
    "parameter": {
      "type": "object",
      "properties": {
        "fname": {
          "type": ["string", "null"],
          "description": "Fuzzy card name search (partial match). Examples: 'dragon', 'dark magician', 'exodia'. Use this for broad searches."
        },
        "name": {
          "type": ["string", "null"],
          "description": "Exact card name. Examples: 'Blue-Eyes White Dragon', 'Dark Magician', 'Pot of Greed'. Use this when you know the exact name."
        },
        "type": {
          "type": ["string", "null"],
          "description": "Card type filter. Values: 'Normal Monster', 'Effect Monster', 'Fusion Monster', 'Ritual Monster', 'Synchro Monster', 'XYZ Monster', 'Link Monster', 'Spell Card', 'Trap Card', etc."
        },
        "attribute": {
          "type": ["string", "null"],
          "description": "Monster attribute. Values: 'DARK', 'LIGHT', 'EARTH', 'WATER', 'FIRE', 'WIND', 'DIVINE'"
        },
        "race": {
          "type": ["string", "null"],
          "description": "Monster race/subtype. Examples: 'Dragon', 'Spellcaster', 'Warrior', 'Machine', 'Fiend', 'Fairy', 'Aqua'. For Spells: 'Normal', 'Continuous', 'Quick-Play', 'Field', 'Equip', 'Ritual'"
        },
        "archetype": {
          "type": ["string", "null"],
          "description": "Card archetype. Examples: 'Blue-Eyes', 'Dark Magician', 'HERO', 'Exodia', 'Cyber Dragon', 'Stardust'"
        },
        "level": {
          "type": ["integer", "null"],
          "description": "Monster level/rank (1-12). Example: 8 for Level 8 monsters"
        },
        "atk": {
          "type": ["integer", "null"],
          "description": "Exact ATK value. Example: 3000"
        },
        "def": {
          "type": ["integer", "null"],
          "description": "Exact DEF value. Example: 2500"
        },
        "num": {
          "type": ["integer", "null"],
          "description": "Number of results to return. Default: 20"
        },
        "offset": {
          "type": ["integer", "null"],
          "description": "Offset for pagination. Default: 0"
        }
      },
      "required": []
    },
    "fields": {
      "endpoint": "https://db.ygoprodeck.com/api/v7/cardinfo.php",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"fname": "dragon", "num": 5},
      {"name": "Blue-Eyes White Dragon"},
      {"type": "Fusion Monster", "attribute": "DARK", "num": 5},
      {"archetype": "HERO", "num": 5}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "Yu-Gi-Oh card search results",
              "properties": {
                "data": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {"type": "integer", "description": "Unique card database ID"},
                      "name": {"type": "string"},
                      "type": {"type": "string", "description": "Card type (Normal Monster, Spell Card, etc.)"},
                      "humanReadableCardType": {"type": "string"},
                      "frameType": {"type": "string"},
                      "desc": {"type": "string", "description": "Card description/effect text"},
                      "race": {"type": "string", "description": "Monster subtype or Spell/Trap type"},
                      "atk": {"type": ["integer", "null"], "description": "ATK value (monsters only)"},
                      "def": {"type": ["integer", "null"], "description": "DEF value (monsters only)"},
                      "level": {"type": ["integer", "null"], "description": "Monster level/rank"},
                      "attribute": {"type": ["string", "null"], "description": "Monster attribute (DARK, LIGHT, etc.)"},
                      "archetype": {"type": ["string", "null"]},
                      "card_sets": {"type": "array", "description": "Sets this card appears in with rarity and prices"},
                      "card_images": {"type": "array", "description": "Card image URLs"},
                      "card_prices": {"type": "array", "description": "Market prices from various sources"}
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "YuGiOh_get_card_sets",
    "description": "List all Yu-Gi-Oh! card sets from the YGOPRODeck API. Returns set names, codes, number of cards, and release dates. There are 1000+ sets spanning from the original Legend of Blue Eyes (2002) to modern releases. No authentication required.",
    "parameter": {
      "type": "object",
      "properties": {},
      "required": []
    },
    "fields": {
      "endpoint": "https://db.ygoprodeck.com/api/v7/cardsets.php",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "array",
              "description": "List of all Yu-Gi-Oh card sets",
              "items": {
                "type": "object",
                "properties": {
                  "set_name": {"type": "string", "description": "Full set name"},
                  "set_code": {"type": "string", "description": "Set abbreviation code"},
                  "num_of_cards": {"type": "integer"},
                  "tcg_date": {"type": ["string", "null"], "description": "TCG release date"}
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  },
  {
    "name": "YuGiOh_get_archetypes",
    "description": "List all Yu-Gi-Oh! card archetypes from the YGOPRODeck API. Archetypes are groups of related cards that share a common naming theme and often have synergistic effects (e.g., 'Blue-Eyes', 'HERO', 'Cyber Dragon'). Returns 600+ archetypes. No authentication required.",
    "parameter": {
      "type": "object",
      "properties": {},
      "required": []
    },
    "fields": {
      "endpoint": "https://db.ygoprodeck.com/api/v7/archetypes.php",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "array",
              "description": "List of all Yu-Gi-Oh archetypes",
              "items": {
                "type": "object",
                "properties": {
                  "archetype_name": {"type": "string", "description": "Name of the archetype"}
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
