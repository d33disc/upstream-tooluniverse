[
  {
    "name": "ZINC_get_substance",
    "description": "Get compound information from ZINC by ID. Returns SMILES, molecular properties, purchasability, and vendor information. ZINC contains 750M+ purchasable compounds for virtual screening.",
    "type": "ZINCTool",
    "parameter": {
      "type": "object",
      "properties": {
        "operation": {"type": "string", "const": "get_substance"},
        "zinc_id": {
          "type": "string",
          "description": "ZINC ID (e.g., ZINC000000000001)"
        }
      },
      "required": ["operation", "zinc_id"]
    },
    "return_schema": {
      "type": "object",
      "properties": {
        "status": {"type": "string"},
        "data": {"type": "object"}
      }
    },
    "test_examples": [
      {"operation": "get_substance", "zinc_id": "ZINC000000000001"}
    ]
  },
  {
    "name": "ZINC_search_by_name",
    "description": "Search ZINC for compounds by name. Returns matching ZINC IDs with basic properties. Useful for finding purchasable versions of known compounds.",
    "type": "ZINCTool",
    "parameter": {
      "type": "object",
      "properties": {
        "operation": {"type": "string", "const": "search_by_name"},
        "name": {
          "type": "string",
          "description": "Compound name or partial name"
        },
        "max_results": {
          "type": "integer",
          "description": "Maximum results (default: 20)",
          "default": 20
        }
      },
      "required": ["operation", "name"]
    },
    "return_schema": {
      "type": "object",
      "properties": {
        "status": {"type": "string"},
        "data": {"type": "object"}
      }
    },
    "test_examples": [
      {"operation": "search_by_name", "name": "aspirin"}
    ]
  },
  {
    "name": "ZINC_search_by_smiles",
    "description": "Search ZINC by chemical structure (SMILES). Supports exact match, substructure, and similarity search. Essential for finding purchasable analogs of hit compounds.",
    "type": "ZINCTool",
    "parameter": {
      "type": "object",
      "properties": {
        "operation": {"type": "string", "const": "search_by_smiles"},
        "smiles": {
          "type": "string",
          "description": "SMILES string for the query compound"
        },
        "search_type": {
          "type": "string",
          "description": "Search type: exact, substructure, similarity (default: similarity)",
          "default": "similarity"
        },
        "max_results": {
          "type": "integer",
          "description": "Maximum results (default: 20)",
          "default": 20
        }
      },
      "required": ["operation", "smiles"]
    },
    "return_schema": {
      "type": "object",
      "properties": {
        "status": {"type": "string"},
        "data": {"type": "object"}
      }
    },
    "test_examples": [
      {"operation": "search_by_smiles", "smiles": "CC(=O)Oc1ccccc1C(=O)O", "search_type": "similarity"}
    ]
  },
  {
    "name": "ZINC_get_catalogs",
    "description": "Get available ZINC compound catalogs and libraries. Returns list of screening libraries like In-Stock, Make-on-demand, Drug-like, Lead-like, and Fragment collections.",
    "type": "ZINCTool",
    "parameter": {
      "type": "object",
      "properties": {
        "operation": {"type": "string", "const": "get_catalogs"}
      },
      "required": ["operation"]
    },
    "return_schema": {
      "type": "object",
      "properties": {
        "status": {"type": "string"},
        "data": {"type": "object"}
      }
    },
    "test_examples": [
      {"operation": "get_catalogs"}
    ]
  }
]
