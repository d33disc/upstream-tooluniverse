[
  {
    "name": "Zippopotam_lookup_zipcode",
    "description": "Look up geographic information for a postal/ZIP code using the Zippopotam.us API. Returns city name, state/province, latitude, and longitude for postal codes in 60+ countries. No authentication required. Useful for address validation, geographic analysis, and location-based services.",
    "parameter": {
      "type": "object",
      "properties": {
        "country": {
          "type": "string",
          "description": "Two-letter ISO country code. Examples: 'us' (United States), 'gb' (UK), 'de' (Germany), 'ca' (Canada), 'au' (Australia), 'fr' (France), 'jp' (Japan)"
        },
        "zipcode": {
          "type": "string",
          "description": "Postal/ZIP code to look up. Examples: '90210' (Beverly Hills CA), 'SW1A 1AA' (London), '10001' (New York), '10115' (Berlin), 'M5H 2N2' (Toronto)"
        }
      },
      "required": ["country", "zipcode"]
    },
    "fields": {
      "endpoint": "https://api.zippopotam.us/{country}/{zipcode}",
      "params": {}
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {"country": "us", "zipcode": "90210"},
      {"country": "us", "zipcode": "10001"},
      {"country": "de", "zipcode": "10115"}
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "description": "ZIP/postal code geographic information",
              "properties": {
                "post code": {"type": "string", "description": "The postal code"},
                "country": {"type": "string", "description": "Full country name"},
                "country abbreviation": {"type": "string", "description": "ISO country code"},
                "places": {
                  "type": "array",
                  "description": "Places associated with this postal code",
                  "items": {
                    "type": "object",
                    "properties": {
                      "place name": {"type": "string", "description": "City/town name"},
                      "longitude": {"type": "string", "description": "Longitude"},
                      "latitude": {"type": "string", "description": "Latitude"},
                      "state": {"type": "string", "description": "State/province name"},
                      "state abbreviation": {"type": "string", "description": "State/province code"}
                    }
                  }
                }
              }
            },
            "metadata": {"type": "object"}
          },
          "required": ["data"]
        },
        {
          "type": "object",
          "properties": {"error": {"type": "string"}},
          "required": ["error"]
        }
      ]
    }
  }
]
